<div class='xo-order-bill'>
  <div>
    <xo-animate xo-cascade class='xo-order-bill__nav-title'>
      <h6>{{ 'customer.order.billing_address' | t }}</h6>
    </xo-animate>
    <xo-animate
      xo-cascade
      class='xo-order-bill__payment-status'
    >
      <span class='xo-order-bill__payment-status-text'> {{ 'customer.order.payment_status' | t }}: </span>
      {{ order.financial_status_label }}
    </xo-animate>
    <xo-animate xo-cascade class='xo-order-bill__name'>
      <div class='xo-order-bill__name-icon'>
        {% render 'icon', name: 'user', size: '18' %}
      </div>
      <div class='xo-order-bill__name-user'>
        {{ customer.default_address.first_name | capitalize }}
        {{ customer.default_address.last_name | capitalize }}
      </div>
    </xo-animate>
    <xo-animate xo-cascade class='xo-order-bill__phone'>
      <div class='xo-order-bill__phone-icon'>
        {% render 'icon', name: 'phone', size: '24' %}
      </div>
      <div class='xo-order-bill__phone-number'>{{ customer.default_address.phone }}</div>
    </xo-animate>
    <xo-animate xo-cascade class='xo-order-bill__address'>
      <div class='xo-order-bill__address-icon'>
        {% render 'icon', name: 'location', size: '24' %}
      </div>
      <div class='xo-order-bill__address-info'>
        {{- customer.default_address.company }}
        {{ customer.default_address.street }}
        {{ customer.default_address.city | capitalize }}
        {{ customer.default_address.country -}}
      </div>
    </xo-animate>
  </div>

  <div class='xo-order-bill__ship-address'>
    <xo-animate xo-cascade class='xo-order-bill__nav-title'>
      <h6>{{ 'customer.order.shipping_address' | t }}</h6>
    </xo-animate>
    <xo-animate
      xo-cascade
      class='xo-order-bill__payment-status'
    >
      <span class='xo-order-bill__payment-status-text'>{{ 'customer.order.fulfillment_status' | t }}:</span>
      {{ order.fulfillment_status_label }}
    </xo-animate>
    <xo-animate xo-cascade class='xo-order-bill__name'>
      <div class='xo-order-bill__name-icon'>
        {% render 'icon', name: 'user', size: '18' %}
      </div>
      <div class='xo-order-bill__name-user'>
        {{ order.shipping_address.first_name | capitalize }}
        {{ order.shipping_address.last_name | capitalize }}
      </div>
    </xo-animate>
    <xo-animate xo-cascade class='xo-order-bill__phone'>
      <div class='xo-order-bill__phone-icon'>
        {% render 'icon', name: 'phone', size: '24' %}
      </div>
      <div class='xo-order-bill__phone-number'>{{ order.shipping_address.phone }}</div>
    </xo-animate>
    <xo-animate xo-cascade class='xo-order-bill__address'>
      <div class='xo-order-bill__address-icon'>
        {% render 'icon', name: 'location', size: '24' %}
      </div>
      <div class='xo-order-bill__address-info'>
        {{- order.shipping_address.company }}
        {{ order.shipping_address.street }}
        {{ order.shipping_address.city | capitalize }}
        {{ order.shipping_address.country -}}
      </div>
    </xo-animate>
  </div>
</div>
