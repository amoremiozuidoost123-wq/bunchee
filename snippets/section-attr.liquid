{% comment %}
  Renders a section attribute

  Usage:
  {% render 'section-attr' %}
{% endcomment %}

{% liquid
  assign class_name = 'xo-section xo-section--' | append: section.id
  if section.settings.background_color != blank
    assign background_color = '--bg-color: ' | append: section.settings.background_color | append: ';'
  endif
  if section.settings.background_gradient != blank
    assign background_gradient = '--bg-gradient: ' | append: section.settings.background_gradient | append: ';'
  endif
  if section.settings.padding_top != null
    assign padding_top = '--pt: ' | append: section.settings.padding_top | append: ';'
  endif
  if section.settings.padding_bottom != null
    assign padding_bottom = '--pb: ' | append: section.settings.padding_bottom | append: ';'
  endif
  if section.settings.padding_top_mobile != null
    assign padding_top_mobile = '--pt-mb: ' | append: section.settings.padding_top_mobile | append: ';'
  endif
  if section.settings.padding_bottom_mobile != null
    assign padding_bottom_mobile = '--pb-mb: ' | append: section.settings.padding_bottom_mobile | append: ';'
  endif
  unless style
    assign style = ''
  endunless
%}

class="{{ class_name -}}
{%- if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}" style="{{ background_color -}}
{{- background_gradient -}}
{{- background_image -}}
{{- padding_top -}}
{{- padding_bottom }}
{{- padding_top_mobile -}}
{{- padding_bottom_mobile }}
{{- style }}"
