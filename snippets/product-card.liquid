{% comment %}
  Renders a product card

  Accepts:
  - product: {Object} Product Liquid object (optional)
  - media_aspect_ratio:  {String} The setting changes the aspect ratio of the article image, if shown
  - show_image: {Boolean} The setting either show the article image or not. If it's not included it will show the image by default
  - show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
  - show_vendor: {Boolean} Show the product vendor. Default: false (optional)
  - show_description: {Boolean} Show the description. Default: false (optional)
  - show_price: {Boolean} Show the product price. Default: true (optional)
  - show_badge: {Boolean} Show the product badge. Default: true (optional)
  - turn_off_variant: {Boolean} show the product variant. Default: true (optional)
  - placeholder_image: {String} The placeholder image to use when no product exists. Default: 'product-apparel-1' (optional)
  - color_scheme: {String} The color scheme to use (optional)
  - animate_enabled: {Boolean} Enable animation. Default: true (optional)

  Usage:
  {% render 'product-card',
    product: product,
    show_image: product_card_show_image,
    show_secondary_image: product_card_show_secondary_image,
    show_vendor: product_card_show_vendor,
    show_description: product_card_show_description,
    show_price: product_card_show_price,
    show_badge: product_card_show_badge,
    media_aspect_ratio: product_card_aspect_ratio,
    color_scheme: card_color_scheme,
    placeholder_image: placeholder_image,
    turn_off_variant: true,
    animate_enabled: true
  %}
{% endcomment %}

{% liquid
  if animate_enabled == null
    assign animate_enabled = true
  endif
  assign tag_name = 'div'
  if animate_enabled
    assign tag_name = 'xo-animate'
  endif
  if show_quick_add == null
    assign show_quick_add = true
  endif
  if show_quick_view == null
    assign show_quick_view = true
  endif
  if turn_off_variant == null or turn_off_variant == false
    assign turn_off_variant = false
  else
    assign turn_off_variant = true
  endif
%}

{% if variant_modal_placement == 'center' %}
  {% capture modal_attr %}
    xo-placement="center"
  {% endcapture %}
{% elsif variant_modal_placement == 'top-left' %}
  {% capture modal_attr %}
    xo-placement="top-left" xo-animate="slide-right"
  {% endcapture %}
{% elsif variant_modal_placement == 'top-right' %}
  {% capture modal_attr %}
    xo-placement="top-right" xo-animate="slide-left"
  {% endcapture %}
{% elsif variant_modal_placement == 'bottom-left' %}
  {% capture modal_attr %}
    xo-placement="bottom-left" xo-animate="slide-right"
  {% endcapture %}
{% elsif variant_modal_placement == 'bottom-right' %}
  {% capture modal_attr %}
    xo-placement="bottom-right" xo-animate="slide-left"
  {% endcapture %}
{% endif %}

{% if product and product != empty %}
  <xo-product
    xo-product-id='{{ product.id }}'
    xo-section-id='{{ section.id }}'
    xo-selected-or-first-available-variant-id="{{ product.selected_or_first_available_variant.id }}"
    class='product-card'
  >
    {% capture render_header %}
    <div class="product-card__header">
      {% if show_image %}
        <a href='{{ product.url }}'>
          {% render 'product-image', product: product, show_secondary_image: show_secondary_image, aspect_ratio: media_aspect_ratio, lazyload: lazyload %}
        </a>
      {% endif %}
      <div class='product-card__actions'>
        {% if product.options_with_values.size > 0 and product.has_only_default_variant == false %}
          {% assign button_text = 'products.product.add_to_cart' | t %}
          <xo-tooltip xo-title="{{ button_text }}">
            <xo-product-quick-view-trigger xo-modal-name='quick-view' xo-product-url='{{ shop.url }}/products/{{ product.handle }}/?section_id=quick-view-content' class="product-card__quick-view-btn">
              {% render 'button', icon: 'add-to-cart', style: 'primary', size: 'sm', icon_size: '26', product_card: true %}
            </xo-product-quick-view-trigger>
          </xo-tooltip>
        {% elsif product.has_only_default_variant == true %}
          {% if show_quick_add %}
            <div class='product-card__add'>
              {% if product.selected_or_first_available_variant.available == true %}
                {% assign button_text = 'products.product.add_to_cart' | t %}
                {% assign sold_out = false %}
              {% elsif product.selected_or_first_available_variant.available == false %}
                {% assign button_text = 'products.product.sold_out' | t %}
                {% assign sold_out = true %}
              {% endif %}
              <div
                class='add-button add-button--available add-to-cart__sold-out'
                sold-out='{{ sold_out }}'
              >
                <xo-tooltip xo-title="{{ button_text }}">
                  <div
                    class='add-button__inside'
                    {% if product.selected_or_first_available_variant.available == false %}
                      xo-disabled
                    {% endif %}
                  >
                    <xo-cart-add class='add-button__cart'>
                      {% render 'button', size: 'md', block: true, style: 'primary', icon: 'add-to-cart', icon_position: 'left', icon_size: '26', product_card: true %}
                    </xo-cart-add>
                  </div>
                </xo-tooltip>
              </div>
            </div>
          {% endif %}
        {% endif %}
        {% if show_quick_view %}
            <xo-tooltip xo-title="{{ 'general.quick_view' | t }}">
              <xo-product-quick-view-trigger xo-modal-name='quick-view' xo-product-url='{{ shop.url }}/products/{{ product.handle }}/?section_id=quick-view-content' class="product-card__quick-view-btn">
                {% render 'button', icon: 'eye', style: 'primary', size: 'sm', icon_size: '26', product_card: true %}
              </xo-product-quick-view-trigger>
            </xo-tooltip>
        {% endif %}
      </div>
    </div>
  {% endcapture %}

    {% capture render_information %}
    <div class='product-card__information'>
      {% if show_badge %}
        <div class='product-card__badge'>
          {% render 'badge-sale', product: product, use_variant: true %}
          {% render 'badge-sold-out', product: product, use_variant: true %}
          {% render 'badge-new', product:product  %}
        </div>
      {% endif %}
      {% if show_vendor %}
        <div class='product-card__vendor'>
          {{ product.vendor }}
        </div>
      {% endif %}

      <h2 class='product-card__title h5'>
        <a href='{{ product.url }}'>
          {{ product.title | escape }}
        </a>
      </h2>

      {% if show_description %}
        <div class='product-card__description'>
          {{ product.description | strip_html }}
        </div>
      {% endif %}

      {% if show_price %}
        <div class='product-card__price'>
          <div class='product-card__price-inner'>
            {% if product.price_varies %}
              <div class='product-card__price-varies'>
                {% if settings.currency_code_enabled %}
                  <span>{{ product.price_min | money_with_currency }}</span>
                  <span>-</span>
                  <span>{{ product.price_max | money_with_currency }}</span>
                {% else %}
                  <span>{{ product.price_min | money }}</span>
                  <span>-</span>
                  <span>{{ product.price_max | money }}</span>
                {% endif %}
              </div>
              {% render 'unit-price', product: product %}
            {% else %}
              <div>
                {% render 'price', product: product, use_variant: true, reverse: true %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}


      {% if product.has_only_default_variant == false and turn_off_variant == false %}
        {% if product.options_with_values.size == 1 %}
          <div class="product-card__variant product-card__variant--one variant-list">
            {%- for option in product.options_with_values -%}
              <xo-animate xo-cascade>
                {% if option.name == 'Color' %}
                  {% render 'product-variant', option: option, style: 'color', product: product %}
                {% else %}
                  {% render 'product-variant', option: option, style: 'boxed', truncate: true, product: product %}
                {% endif %}
              </xo-animate>
            {%- endfor -%}
          </div>
        {% endif %}
      {% endif %}
      <div class="product-card__mobile">
        {% if show_quick_add %}
          {% if product.options_with_values.size > 0 and product.has_only_default_variant == false %}
            {% assign button_text = 'products.product.add_to_cart' | t %}
            <xo-tooltip xo-title="{{ button_text }}">
              <xo-product-quick-view-trigger xo-modal-name='quick-view' xo-product-url='{{ shop.url }}/products/{{ product.handle }}/?section_id=quick-view-content' class="product-card__quick-view-btn">
                {% render 'button', icon: 'add-to-cart', style: 'primary', size: 'md', icon_size: '20', product_card: true %}
              </xo-product-quick-view-trigger>
            </xo-tooltip>
          {% elsif product.has_only_default_variant == true %}
            <div class='product-card__add'>
              {% if product.selected_or_first_available_variant.available == true %}
                {% assign button_text = 'products.product.add_to_cart' | t %}
                {% assign sold_out = false %}
              {% elsif product.selected_or_first_available_variant.available == false %}
                {% assign button_text = 'products.product.sold_out' | t %}
                {% assign sold_out = true %}
              {% endif %}
              <div
                class='add-button add-button--available add-to-cart__sold-out'
                sold-out='{{ sold_out }}'
              >
                <xo-tooltip xo-title="{{ button_text }}">
                  <div
                    class='add-button__inside'
                    {% if product.selected_or_first_available_variant.available == false %}
                      xo-disabled
                    {% endif %}
                  >
                    <xo-cart-add class='add-button__cart'>
                      {% render 'button', size: 'md', block: true, style: 'primary', icon: 'add-to-cart', icon_position: 'left', icon_size: '20', product_card: true %}
                    </xo-cart-add>
                  </div>
                </xo-tooltip>
              </div>
            </div>
          {% endif %}
        {% endif %}
        {% if show_quick_view %}
          <xo-tooltip xo-title="{{ 'general.quick_view' | t }}">
            <xo-product-quick-view-trigger xo-modal-name='quick-view' xo-product-url='{{ shop.url }}/products/{{ product.handle }}/?section_id=quick-view-content' class="product-card__quick-view-btn">
                {% render 'button', icon: 'eye', style: 'primary', size: 'sm', icon_size: '20', product_card: true %}
            </xo-product-quick-view-trigger>
          </xo-tooltip>
        {% endif %}
      </div>
    </div>
  {% endcapture %}

    <{{ tag_name }}
      xo-cascade
      {% if animate_constant %}
        xo-constant='{{ animate_constant }}'
      {% endif %}
      class='product-card__container{% if color_scheme %} color-{{ color_scheme }}{% endif %}'
    >
      {{ render_header }}
      {{ render_information }}
      <xo-product-liquid-static>
        <script type='application/json'>
          {
            {% for variant in product.variants
            %}
              {{ variant.id }}: {
                price: `{% render 'price', variant: variant, reverse: false %}`,
                img: `<a href='{{ product.url }}'>{% render 'product-image', product: product, variant: variant, show_secondary_image: show_secondary_image, aspect_ratio: media_aspect_ratio %}
                </a>`,
                soldOut: `{%- if variant.inventory_quantity > 0  or variant.inventory_policy == 'continue' -%}false{%- elsif variant.inventory_quantity == 0 and variant.inventory_policy == 'deny' -%}true{%- endif -%}`,
                variantId: {{ variant.id }},
                saleEnabled: `{% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %}`
              },
            {% endfor %}
          }
        </script>
      </xo-product-liquid-static>
      {% render 'product-data', product: product %}
    </{{ tag_name }}>
  </xo-product>
{% else %}
  {% render 'product-card-placeholder',
    placeholder_image: placeholder_image,
    show_quick_add: show_quick_add,
    show_quick_view: show_quick_view,
    show_image: show_image,
    show_badge: show_badge,
    show_vendor: show_vendor,
    show_description: show_description,
    show_price: show_price,
    color_scheme: color_scheme,
    animate_enabled: animate_enabled
  %}
{% endif %}
