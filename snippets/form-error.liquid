{% comment %}
  Renders a form error

  Accepts:
  - form: {Object} Form object (optional)
  - with_recipient_form: {Boolean} Whether to render the form with the recipient form (optional)

  Usage:
  {% render 'form-error',
    form: form
  %}
{% endcomment %}

{% if with_recipient_form %}
  <div class='xo-form-error'>
    {% render 'icon', name: 'error' %}
    {% if form.errors %}
      <div class='xo-form-error__message'>{{ form.errors | default_errors }}</div>
    {% else %}
      <xo-product-recipient-form-error class='xo-form-error__message'>
        {%- for error in form.errors %}
          <div>
            {% if error == 'form' %}
              {{ form.errors.messages[error] }}
            {% else %}
              {{ form.errors.translated_fields[error] }} - {{ form.errors.messages[error] }}
            {% endif %}
          </div>
        {% endfor -%}
      </xo-product-recipient-form-error>
    {% endif %}
  </div>
{% else %}
  {% if form.errors %}
    <div class='xo-form-error'>
      {% render 'icon', name: 'error' %}
      <div class='xo-form-error__message'>{{ form.errors | default_errors }}</div>
    </div>
  {% endif %}
{% endif %}
