        <defs>
          <linearGradient id="paint0_linear_11410_87750" x1="0" y1="121.754" x2="1920" y2="121.754" gradientUnits="userSpaceOnUse">
            <stop stop-opacity="0" class="image-banner-type-1__linear"/>
