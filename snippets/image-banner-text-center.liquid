{% comment %}
   Renders a image banner text center

  Accepts:
  - background_svg: {Option} Background svg
  - image_1: {Image} Image
  - image_2: {Image} Image
  - image_3: {Image} Image
  - image_decor: {Image} Image decoraction
  - color_background: {Color} Background color

  Usage:
  {% render 'image-banner-text-center',
        background_svg: background_svg,
        image_1: section.settings.image_1,
        image_2: section.settings.image_2,
        image_3: section.settings.image_3,
        image_decor: section.settings.image_decor,
        color_background: section.settings.color_background
      %}
{% endcomment %}

<div class='image-banner-type-1__wrap'>
  <div class='image-banner-type-1__background'>
    <div class='image-banner-type-1__container'>
      <div class='image-banner-type-1__button'>
        {% render 'button',
          text: section.settings.button_text,
          link: section.settings.button_link,
          size: section.settings.button_size,
          style: section.settings.button_style,
          icon: 'arrow-testimonial-right',
          icon_position: 'right',
          icon_size: '24'
        %}
      </div>
      <div class='image-banner-type-1__middle'>
        <div class='image-banner-type-1__heading'>
          {% render 'text',
            text: section.settings.text_heading,
            tag_name: section.settings.text_tag_name,
            duration: section.settings.text_duration,
            effect: section.settings.text_effect
          %}
        </div>
      </div>
    </div>
  </div>
  <xo-animate class='image-banner-type-1__image-1' xo-type='zoom-in' xo-cascade>
    {% render 'image', image: image_1, placeholder: 'product-1', lazyload: false %}
  </xo-animate>
  <xo-animate class='image-banner-type-1__image-2' xo-type='zoom-in' xo-cascade>
    {% render 'image', image: image_2, placeholder: 'product-2', lazyload: false %}
  </xo-animate>
  <xo-animate class='image-banner-type-1__image-3' xo-type='zoom-in' xo-cascade>
    <div class='image-banner-type-1__decor'>
      {% render 'image', image: image_decor, placeholder: 'product-4', lazyload: false %}
    </div>
    {% render 'image', image: image_3, placeholder: 'product-3', lazyload: false %}
  </xo-animate>
  <div class='image-banner-type-1__svg' style='--color: {{ color_background }}'>
    {% if background_svg == 'type-1' %}
      <div class='image-banner-type-1__svg-container'></div>
    {% elsif background_svg == 'type-2' %}
      <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1920 245'>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M0 102.504C63.6833 142.004 252.266 194.804 497.129 90.0037C803.209 -40.9963 929.742 -0.496277 1021.77 41.5037C1053.2 55.8501 1075.94 74.3381 1100.81 94.5567C1148.74 133.53 1204.58 178.933 1345.85 213.5C1535.37 259.873 1626.79 243.599 1693.53 231.72C1703.28 229.983 1712.52 228.34 1721.45 227C1791.47 216.5 1867.99 187.5 1920 146V0H0V102.504Z"/>
      </svg>
    {% elsif background_svg == 'type-3' %}
      <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1920 283'>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M458.5 211.037C545.322 236.53 633.703 234.278 714.147 209.466C784.343 255.938 868.511 283 959 283C1049.48 283 1133.65 255.941 1203.84 209.475C1284.28 234.288 1372.67 236.541 1459.49 211.048C1546.32 185.552 1619.46 135.868 1673.72 71.4956C1757.9 72.6405 1843.87 48.9226 1920 0H0C75.7584 48.2789 160.646 72.6448 244.289 71.5059C298.547 135.869 371.68 185.545 458.5 211.037Z"/>
