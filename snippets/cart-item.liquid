{% comment %}
  Renders a cart item

  Accepts:
  - item: {Object} cart item

  Usage:
  {% render 'cart-item',
    item: item
  %}
{% endcomment %}
{%- liquid
  if use_variant
    assign target = item.product.selected_or_first_available_variant
  else
    assign target = item.product
  endif

  assign compare_at_price = target.compare_at_price
  assign price = item.original_price | default: 1999
  assign money_price = price | money
  if settings.currency_code_enabled
    assign money_price = price | money_with_currency
  endif

  if target == item.product and item.product.price_varies
    assign money_price = 'products.product.price.from_price_html' | t: price: money_price
  endif
-%}

<div class='xo-cart-item'>
  {% if item.image != blank %}
    <a href='{{ item.url }}' class='xo-cart-item__image'>
      {% render 'image', image: item.image %}
    </a>
  {% endif %}
  <div class='xo-cart-item__content'>
    {%- if settings.show_vendor -%}
      <span class='xo-cart-item__vendor'>{{ item.product.vendor }}</span>
    {%- endif -%}
    <a href='{{ item.url }}' class='xo-cart-item__title'>
      {{ item.title | escape }}
    </a>

    <div class='xo-cart-item__price'>
      {%- if compare_at_price > price -%}
        <div class='xo-cart-item__discounted-prices'>
          {%- unless target.price_varies == false and target.compare_at_price_varies %}
            <span class='xo-visually-hidden'>
              {{ 'products.product.price.regular_price' | t }}
            </span>
            <s class='xo-cart-item__old-price'>
              {% if settings.currency_code_enabled %}
                {{ compare_at_price | money_with_currency }}
              {% else %}
                {{ compare_at_price | money }}
              {% endif %}
            </s>
          {%- endunless -%}
          <span class='xo-visually-hidden'>
            {{ 'products.product.price.sale_price' | t }}
          </span>
          <strong class='xo-cart-item__final-price'>
            {{ money_price }}
          </strong>
        </div>
      {%- else -%}
        <div class='xo-cart-item__final-price'>
          {{ money_price }}
        </div>
      {%- endif -%}
      {% render 'unit-price', product: item.product %}
    </div>
    {% if item.product.has_only_default_variant == false %}
      {%- if item.properties.size != 0 or item.selling_plan_allocation != null -%}
        <div class='xo-cart-item__options'>
          {%- for option in item.options_with_values -%}
            <div class='xo-cart-item__option'>
              <span class='xo-cart-item__option-name'>{{ option.name }}:</span>
              <span class='xo-cart-item__option-value'>{{ option.value -}}</span>
            </div>
          {%- endfor -%}
          {%- for property in item.properties -%}
            {%- assign property_first_char = property.first | slice: 0 -%}
            {%- if property.last != blank and property_first_char != '_' -%}
              <div class='xo-cart-item__option'>
                <span class='xo-cart-item__option-name'>{{ property.first }}:</span>
                <span class='xo-cart-item__option-value'>
                  {%- if property.last contains '/uploads/' -%}
                    {% assign text = property.last | split: '/' | last %}
                    {% capture attrs %}target='_blank' aria-describedby='a11y-new-window-message'{% endcapture %}
                    {% render 'button', text: text, link: property.last, style: 'link', attrs: attrs %}
                  {%- else -%}
                    {{ property.last }}
                  {%- endif -%}
                </span>
              </div>
            {%- endif -%}
          {%- endfor -%}
          <p class='xo-cart-item__option'>{{ item.plan.selling_plan.name }}</p>
        </div>
      {%- endif -%}
    {% endif %}
    {% if item.selling_plan_allocation.selling_plan %}
      <p class='xo-cart-item__selling-plan'>{{ item.selling_plan_allocation.selling_plan.name }}</p>
    {% endif %}
    <ul class='xo-cart-item__detail-discounts list-unstyled' role='list' aria-label='{{ 'customer.order.discount' | t }}'>
      {%- for discount in item.line_level_discount_allocations -%}
        <li class='xo-cart-item__detail-discount'>
          {% render 'badge-discount', label: discount.discount_application.title %}
        </li>
      {%- endfor -%}
    </ul>
    <div class='xo-cart-item__quantity'>
      {% render 'quantity', value: item.quantity %}
    </div>
    <xo-cart-remove>
      {% assign delete_label = 'sections.cart.delete' | t %}
      <div class='xo-cart-item__remove'>
        {{ delete_label }}
      </div>
    </xo-cart-remove>
    <xo-cart-change-fallback>{% render 'loader-2' %}</xo-cart-change-fallback>
  </div>
</div>
