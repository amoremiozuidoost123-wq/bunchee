{% comment %}
  Renders a product card placeholder.

  Accepts:
  - media_aspect_ratio:  {String} The setting changes the aspect ratio of the article image, if shown
  - show_image: {Boolean} The setting either show the article image or not. If it's not included it will show the image by default
  - show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
  - show_vendor: {Boolean} Show the product vendor. Default: false (optional)
  - show_description: {Boolean} Show the description. Default: false (optional)
  - show_quick_add: {Boolean} Show the quick add button. Default: false (optional)
  - show_quick_view: {Boolean} Show the quick view button. Default: false (optional)
  - show_price: {Boolean} Show the product price. Default: true (optional)
  - show_badge: {Boolean} Show the product badge. Default: true (optional)
  - placeholder_image: {String} The placeholder image to use when no product exists. Default: 'product-apparel-1' (optional)
  - color_scheme: {String} The color scheme to use (optional)
  - animate_enabled: {Boolean} Enable animation. Default: true (optional)
  - strength: {String} xo-strength for parallax 3d

  Usage:
  {% render 'product-card-3d-placeholder',
    placeholder_image: placeholder_image,
    show_image: show_image,
    show_badge: show_badge,
    show_quick_view: show_quick_view,
    show_quick_add: show_quick_add,
    show_vendor: show_vendor,
    show_description: show_description,
    show_price: show_price,
    animate_enabled: animate_enabled,
    strength: xo-strength, %}
{% endcomment %}

{% liquid
  if animate_enabled == null
    assign animate_enabled = true
  endif
  assign tag_name = 'div'
  if animate_enabled
    assign tag_name = 'xo-animate'
  endif
%}
<div class='product-card-3d'>
  <{{ tag_name }}
    xo-cascade
    {% if animate_constant %}
      xo-constant='{{ animate_constant }}'
    {% endif %}
    class='product-card-3d__container{% if color_scheme %} color-{{ color_scheme }}{% endif %}'
  >
    <xo-parallax-hover xo-3d xo-strength='{{ strength }}'>
      <div class='product-card-3d__header'>
        {% if show_image %}
          <div xo-binding='img' class='product-card-3d__image' style='position: relative;'>
            <a href='#'>
              <div class='xo-product-image' tabindex='-1'>
                {{ placeholder | default: 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </a>
            {% if image_decor %}
              <div class='product-card-3d__decor'>
                {% render 'image', image: image_decor %}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if show_badge %}
          <div class='product-card-3d__badge'>
            {% render 'badge-sale', product: product, use_variant: true %}
            {% render 'badge-sold-out', product: product, use_variant: true %}
            {% render 'badge-new', product: product %}
          </div>
        {% endif %}

        <div class='product-card-3d__actions product-card-3d__actions--desktop'>
          <div class='product-card-3d__add'>
            {% assign button_text = 'products.product.sold_out' | t %}
            <xo-tooltip xo-title='{{ button_text }}'>
              <xo-cart-add
                sold-out='true'
                xo-binding='addToCartText:.xo-btn__text'
                class='product-card-3d__add-inside'
              >
                {% render 'button',
                  size: 'sm',
                  data-text-unavailable: button_text_unavailable,
                  style: 'primary',
                  icon: 'add-to-cart',
                  icon_position: 'left',
                  icon_size: '26',
                  product_card: true
                %}
              </xo-cart-add>
            </xo-tooltip>
          </div>
          <xo-tooltip xo-title='{{ 'general.quick_view' | t }}'>
            <xo-product-quick-view-trigger
              xo-modal-name='quick-view'
              xo-product-url='{{ shop.url }}/products/{{ product.handle }}/?section_id=quick-view-content'
              class='product-card-3d__quick-view-btn'
            >
              {% render 'button', icon: 'eye', size: 'sm', icon_size: '26', product_card: true %}
            </xo-product-quick-view-trigger>
          </xo-tooltip>
        </div>
      </div>
    </xo-parallax-hover>

    <div class='product-card-3d__information'>
      {% if show_vendor %}
        <div class='product-card-3d__vendor'>
          {{ 'products.product.vendor' | t }}
        </div>
      {% endif %}
      <h2 class='product-card-3d__title h5'>
        <a rel='preload' role='link' aria-disabled='true' class='product-card-3d__title'>
          {{ 'products.product.title' | t }}
        </a>
      </h2>
      {% if show_description %}
        <div class='product-card-3d__description'>
          {{ 'products.product.description' | t }}
        </div>
      {% endif %}

      {% if show_price %}
        <div class='product-card-3d__price'>
          <div class='product-card-3d__price-inner'>
            {% render 'price', product: false %}
          </div>
        </div>
      {% endif %}
      <div class='product-card-3d__actions product-card-3d__actions--mobile'>
        <div class='product-card-3d__add'>
          {% assign button_text = 'products.product.sold_out' | t %}
          <xo-tooltip xo-title='{{ button_text }}'>
            <xo-cart-add
              sold-out='true'
              xo-binding='addToCartText:.xo-btn__text'
              class='product-card-3d__add-inside'
            >
              {% render 'button',
                size: 'sm',
                data-text-unavailable: button_text_unavailable,
                style: 'primary',
                icon: 'add-to-cart',
                icon_position: 'left',
                icon_size: '20',
                product_card: true
              %}
            </xo-cart-add>
          </xo-tooltip>
        </div>
        <xo-tooltip xo-title='{{ 'general.quick_view' | t }}'>
          <xo-product-quick-view-trigger
            xo-modal-name='quick-view'
            xo-product-url='{{ shop.url }}/products/{{ product.handle }}/?section_id=quick-view-content'
            class='product-card-3d__quick-view-btn'
          >
            {% render 'button', icon: 'eye', size: 'sm', icon_size: '20', product_card: true %}
          </xo-product-quick-view-trigger>
        </xo-tooltip>
      </div>
    </div>
  </{{ tag_name }}>
</div>
