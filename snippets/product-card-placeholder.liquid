{% comment %}
  Renders a product card placeholder.

  Accepts:
  - media_aspect_ratio:  {String} The setting changes the aspect ratio of the article image, if shown
  - show_image: {Boolean} The setting either show the article image or not. If it's not included it will show the image by default
  - show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
  - show_vendor: {Boolean} Show the product vendor. Default: false (optional)
  - show_description: {Boolean} Show the description. Default: false (optional)
  - show_quick_add: {Boolean} Show the quick add button. Default: false (optional)
  - show_quick_view: {Boolean} Show the quick view button. Default: false (optional)
  - show_price: {Boolean} Show the product price. Default: true (optional)
  - show_badge: {Boolean} Show the product badge. Default: true (optional)
  - placeholder_image: {String} The placeholder image to use when no product exists. Default: 'product-apparel-1' (optional)
  - color_scheme: {String} The color scheme to use (optional)
  - animate_enabled: {Boolean} Enable animation. Default: true (optional)
  Usage:
  {% render 'product-card-placeholder',
    placeholder_image: placeholder_image,
    show_image: show_image,
    show_badge: show_badge,
    show_quick_view: show_quick_view,
    show_quick_add: show_quick_add,
    show_vendor: show_vendor,
    show_description: show_description,
    show_price: show_price,
    animate_enabled: animate_enabled %}
{% endcomment %}

{% liquid
  if animate_enabled == null
    assign animate_enabled = true
  endif
  assign tag_name = 'div'
  if animate_enabled
    assign tag_name = 'xo-animate'
  endif
%}
<div class='product-card'>
  <{{ tag_name }}
    xo-cascade
    {% if animate_constant %}
      xo-constant='{{ animate_constant }}'
    {% endif %}
    class='product-card__container{% if color_scheme %} color-{{ color_scheme }}{% endif %}'
  >
    <div class='product-card__header'>
      {% if show_image %}
        {% render 'product-image', placeholder_image: placeholder_image, product: false %}
      {% endif %}

      <div class='product-card__actions'>
        <xo-tooltip xo-title='{{ 'products.product.sold_out' | t }}'>
          <div class='product-card__add product-card__add--placeholder' sold-out='true'>
            {% render 'button',
              size: 'sm',
              style: 'primary',
              block: true,
              icon: 'add-to-cart',
              icon_position: 'left',
              icon_size: '26',
              product_card: true,
              data-text-unavailable: button_text_unavailable
            %}
          </div>
        </xo-tooltip>
        <xo-tooltip xo-title='{{ 'general.quick_view' | t }}'>
          <div class='product-card__quick-view-btn'>
            {% render 'button', icon: 'eye', style: 'primary', size: 'sm', icon_size: '26', product_card: true %}
          </div>
        </xo-tooltip>
      </div>
    </div>

    <div class='product-card__information'>
      {% if show_badge %}
        <div class='product-card__badge'>
          {% render 'badge-sale', product: product, use_variant: true %}
          {% render 'badge-sold-out', product: product, use_variant: true %}
          {% render 'badge-new', product: product %}
        </div>
      {% endif %}
      {% if show_vendor %}
        <div class='product-card__vendor'>
          {{ 'products.product.vendor' | t }}
        </div>
      {% endif %}
      <h2 class='product-card__title h5'>
        <a rel='preload' role='link' aria-disabled='true' class='product-card__title'>
          {{ 'products.product.title' | t }}
        </a>
      </h2>
      {% if show_description %}
        <div class='product-card__description'>
          {{ 'products.product.description' | t }}
        </div>
      {% endif %}

      {% if show_price %}
        <div class='product-card__price'>
          <div class='product-card__price-inner'>
            {% render 'price', product: false %}
          </div>
        </div>
      {% endif %}

      <div class='product-card__mobile'>
        {% if show_quick_add %}
          <xo-tooltip xo-title='{{ 'products.product.sold_out' | t }}'>
            <div class='product-card__add product-card__add--placeholder' sold-out='true'>
              {% assign button_text = 'products.product.sold_out' | t %}
              {% render 'button',
                text: button_text,
                size: 'sm',
                style: 'primary',
                block: true,
                icon: 'add-to-cart',
                icon_position: 'left',
                icon_size: '20',
                product_card: true,
                data-text-unavailable: button_text_unavailable
              %}
            </div>
          </xo-tooltip>
        {% endif %}
        {% if show_quick_view %}
          <xo-tooltip xo-title='{{ 'general.quick_view' | t }}'>
            <div class='product-card__quick-view-btn'>
              {% render 'button', icon: 'eye', style: 'primary', size: 'sm', icon_size: '20', product_card: true %}
            </div>
          </xo-tooltip>
        {% endif %}
      </div>
    </div>
  </{{ tag_name }}>
</div>
