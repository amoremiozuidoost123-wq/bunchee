{% assign random_number = 'now' | date: '%N' | modulo: 100 %}
{% assign id = 'localization_form_' | append: random_number %}
{% assign placement = placement | default: 'top-center' %}
<xo-language-select class='xo-language-select'>
  {%- if localization.available_languages.size > 1 -%}
    {%- form 'localization', id: id, class: 'xo-language-select__form' -%}
      <div class='xo-language-select__label'>
        {{ 'localization.language_label' | t }}
      </div>
      <xo-popover-trigger xo-name='{{ id }}' class='xo-language-select__trigger' role='button' tabindex='0'>
        <span>{{ localization.language.endonym_name }}</span>
        {% render 'icon', name: 'chevron-down', size: '20' %}
      </xo-popover-trigger>

      <xo-popover xo-name='{{ id }}' xo-placement='{{ placement }}' class='xo-language-select__content' xo-portal>
        {%- for language in localization.available_languages -%}
          <label class='xo-language-select__item' role='button' tabindex='0'>
            <input
              class='xo-language-select__input xo-field-checkbox__input'
              type='radio'
              name='locale_code'
              value='{{ language.iso_code }}'
              xo-label='{{ label | escape }}'
              {%- if language.iso_code == localization.language.iso_code %}
                checked
              {% endif %}
            >
            <span class='xo-field-checkbox__label'>
              {{ language.endonym_name }}
            </span>
            <span class='xo-field-checkbox__item'>
              <span class='xo-field-checkbox__icon'>{% render 'icon', name: 'check', size: '1.6rem', color: '#fff' %}</span>
            </span>
          </label>
        {%- endfor -%}
      </xo-popover>
    {%- endform -%}
  {%- endif -%}
</xo-language-select>
