{% assign random_number = 'now' | date: '%N' | modulo: 100 %}
{% assign id = 'localization_form_' | append: random_number %}
{% assign placement = placement | default: 'top-center' %}

<xo-currency-select class='xo-currency-select'>
  {% if localization.available_countries.size > 1 %}
    {%- form 'localization', id: id, class: 'xo-currency-select__form' -%}
      <div class='xo-currency-select__label'>
        {{ 'localization.country_label' | t }}
      </div>
      <xo-popover-trigger xo-name='{{ id }}' class='xo-currency-select__trigger' role='button' tabindex='0'>
        <span class='xo-currency-select__trigger-container'>
          <span class='xo-currency-select__flag'>{{ localization.country | image_url: width: 22, height: 22 | image_tag }}</span>
          (
          {{- localization.country.currency.iso_code -}}
          {{- localization.country.currency.symbol }})
        </span>
        {% render 'icon', name: 'chevron-down', size: '20' %}
      </xo-popover-trigger>

      <xo-popover xo-name='{{ id }}' xo-placement='{{ placement }}' class='xo-currency-select__content' xo-portal>
        {%- for country in localization.available_countries -%}
          <label class='xo-currency-select__item' role='button' tabindex='0'>
            <input
              class='xo-currency-select__input xo-field-checkbox__input'
              type='radio'
              name='country_code'
              value='{{ country.iso_code }}'
              {%- if country.iso_code == localization.country.iso_code %}
                checked
              {% endif %}
            >
            <span class='xo-currency-select__name'>
              <span class='xo-currency-select__flag'>{{ country | image_url: width: 22, height: 22 | image_tag }}</span>
              {{ country.currency.iso_code }}
              ({{ country.currency.symbol }})
            </span>
            <span class='xo-field-checkbox__item'>
              <span class='xo-field-checkbox__icon'>{% render 'icon', name: 'check', size: '1.6rem', color: '#fff' %}</span>
            </span>
          </label>
        {%- endfor -%}
      </xo-popover>
    {%- endform -%}
  {% endif %}
</xo-currency-select>
