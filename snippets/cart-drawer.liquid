{% capture drawer_content %}
  <cart-show-tab>
    <div class="cart-mini__header">
      <cart-show-tab-trigger cart-item-name="cart-deal" class="cart-mini__header-item" cart-active>{{ 'general.cart.title' | t }}</cart-show-tab-trigger>
      <cart-show-tab-trigger cart-item-name="cart-offer" class="cart-mini__header-item">{{ 'general.cart.offer' | t }}</cart-show-tab-trigger>
    </div>
    <cart-show-tab-content>
      <cart-show-tab-pane cart-item-name="cart-deal" cart-active>
          {% render 'cart-deal' %}
      </cart-show-tab-pane>
      <cart-show-tab-pane cart-item-name="cart-offer">
          {% render 'cart-offer' %}
      </cart-show-tab-pane>
    </cart-show-tab-content>
  </cart-show-tab>
{% endcapture %}

{% capture drawer_footer %}
  <xo-cart-will-change xo-unique-id='xo-cart-mini-drawer-footer'>
    {% if cart != empty %}
      <xo-animate xo-cascade class="cart-drawer__middle">
          {% liquid
            if settings.show_cart_drawer_note
              assign type_note = settings.cart_drawer_note_type
              render 'cart-note', uid: 'cart-drawer', type: type_note
            endif
          %}
      </xo-animate>
      {% render 'cart-mini-footer' %}
    {% endif %}
  </xo-cart-will-change>
{% endcapture %}

{% render 'modal-content',
  content_tag_name: 'xo-cart-scroll',
  content: drawer_content,
  footer: drawer_footer,
  header_height: '9.6rem',
  width: '53rem',
  full_height: true,
  animate: false,
  footer_class: 'flex-v',
  header_separator: false,
  footer_separator: false
%}
