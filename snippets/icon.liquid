    when 'clear-filter'
      render 'icon-clear-filter', size: size, color: color
    when 'address-delete'
      render 'icon-address-delete', size: size, color: color
    when 'address-edit'
      render 'icon-address-edit', size: size, color: color
    when 'address-default'
      render 'icon-address-default', size: size, color: color
    when 'address-default-active'
      render 'icon-address-default-active', size: size, color: color
    when 'copy'
      render 'icon-copy', size: size, color: color
    when 'gift-icon'
      render 'icon-gift-icon', size: size, color: color
    when 'check-with-circle'
      render 'icon-check-with-circle', size: size, color: color
    else
      render 'icon-arrow', size: size, color: color
  endcase
%}
