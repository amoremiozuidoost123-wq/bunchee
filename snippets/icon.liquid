{% comment %}
  Renders a SVG icon.

  Accepts:
  - name: {String} Name of the icon to render. Default: "arrow" (optional)
  - size: {Number} Size of the icon. Default: 1.4rem (optional)
  - color: {String} Color of the loader. Default: "currentColor" (optional)

  Usage:
  {% render 'icon',
    name: 'arrow',
    size: '1.4rem',
    color: "#000",
  %}
{% endcomment %}

{% liquid
  assign size = size | default: '1.4rem'
  assign color = color | default: 'currentColor'
  assign locale_rtl = 'ar,fa,he,ks,ps,sd,ur,'
  assign current_locale = localization.language.iso_code | append: ','

  case name
    when '3d-model'
      render 'icon-3d-model', size: size, color: color
    when 'account'
      render 'icon-account', size: size, color: color
    when 'arrow'
      render 'icon-arrow', size: size, color: color
    when 'chevron-up'
      render 'icon-chevron-up', size: size, color: color
    when 'chevron-down'
      render 'icon-chevron-down', size: size, color: color
    when 'chevron-left'
      if locale_rtl contains current_locale
        render 'icon-chevron-right', size: size, color: color
      else
        render 'icon-chevron-left', size: size, color: color
      endif
    when 'chevron-right'
      if locale_rtl contains current_locale
        render 'icon-chevron-left', size: size, color: color
      else
        render 'icon-chevron-right', size: size, color: color
      endif
    when 'cart-empty'
      render 'icon-cart-empty', size: size, color: color
    when 'cart'
      render 'icon-cart', size: size, color: color
    when 'check'
      render 'icon-check', size: size, color: color
    when 'checkmark'
      render 'icon-checkmark', size: size, color: color
    when 'clipboard'
      render 'icon-clipboard', size: size, color: color
    when 'close-small'
      render 'icon-close-small', size: size, color: color
    when 'close'
      render 'icon-close', size: size, color: color
    when 'discount'
      render 'icon-discount', size: size, color: color
    when 'error'
      render 'icon-error', size: size, color: color
    when 'eye'
      render 'icon-eye', size: size, color: color
    when 'video'
      render 'icon-video', size: size, color: color
    when 'eye-hide'
      render 'icon-eye-hide', size: size, color: color
    when 'facebook'
      render 'icon-facebook', size: size, color: color
    when 'filter'
      render 'icon-filter', size: size, color: color
    when 'hamburger'
      render 'icon-hamburger', size: size, color: color
    when 'instagram'
      render 'icon-instagram', size: size, color: color
    when 'minus'
      render 'icon-minus', size: size, color: color
    when 'padlock'
      render 'icon-padlock', size: size, color: color
    when 'pause'
      render 'icon-pause', size: size, color: color
    when 'pinterest'
      render 'icon-pinterest', size: size, color: color
    when 'play'
      render 'icon-play', size: size, color: color
    when 'plus'
      render 'icon-plus', size: size, color: color
    when 'remove'
      render 'icon-remove', size: size, color: color
    when 'share'
      render 'icon-share', size: size, color: color
    when 'snapchat'
      render 'icon-snapchat', size: size, color: color
    when 'success'
      render 'icon-success', size: size, color: color
    when 'tick'
      render 'icon-tick', size: size, color: color
    when 'tiktok'
      render 'icon-tiktok', size: size, color: color
    when 'tumblr'
      render 'icon-tumblr', size: size, color: color
    when 'twitter'
      render 'icon-twitter', size: size, color: color
    when 'unavailable'
      render 'icon-unavailable', size: size, color: color
    when 'vimeo'
      render 'icon-vimeo', size: size, color: color
    when 'youtube'
      render 'icon-youtube', size: size, color: color
    when 'zoom'
      render 'icon-zoom', size: size, color: color
    when 'search'
      render 'icon-search', size: size, color: color
    when 'shipping-fast'
      render 'icon-shipping-fast', size: size, color: color
    when 'phone-call'
      render 'icon-phone-call', size: size, color: color
    when 'trash'
      render 'icon-trash', size: size, color: color
    when 'empty'
      render 'icon-empty', size: size, color: color
    when 'note'
      render 'icon-note', size: size, color: color
    when 'estimate-shipping-rates'
      render 'icon-estimate-shipping-rates', size: size, color: color
    when 'arrow-right-breadcrumb'
      render 'icon-arrow-right-breadcrumb', size: size, color: color
    when 'arrow-testimonial-right'
      if locale_rtl contains current_locale
        render 'icon-arrow-testimonial-left', size: size, color: color
      else
        render 'icon-arrow-testimonial-right', size: size, color: color
      endif
    when 'arrow-testimonial-left'
      if locale_rtl contains current_locale
        render 'icon-arrow-testimonial-right', size: size, color: color
      else
        render 'icon-arrow-testimonial-left', size: size, color: color
      endif
    when 'category-arrow-right'
      if locale_rtl contains current_locale
        render 'icon-category-arrow-left', size: size, color: color
