      endif
    when 'add-to-cart'
      render 'icon-add-to-cart', size: size, color: color
    when 'plus-quantity'
      render 'icon-plus-quantity', size: size, color: color
    when 'minus-quantity'
      render 'icon-minus-quantity', size: size, color: color
    when 'product-carousel-prev'
      if locale_rtl contains current_locale
        render 'icon-product-carousel-next', size: size, color: color
      else
        render 'icon-product-carousel-prev', size: size, color: color
      endif
    when 'product-carousel-next'
      if locale_rtl contains current_locale
        render 'icon-product-carousel-prev', size: size, color: color
      else
        render 'icon-product-carousel-next', size: size, color: color
      endif
    when 'arrow-down-product-info'
      render 'icon-arrow-down-product-info', size: size, color: color
    when 'phone'
      render 'icon-phone', size: size, color: color
    when 'mail'
      render 'icon-mail', size: size, color: color
    when 'cart-mini-empty'
      render 'icon-cart-mini-empty', size: size, color: color
    when 'pagination-arrow-left'
      if locale_rtl contains current_locale
        render 'icon-pagination-arrow-right', size: size, color: color
      else
        render 'icon-pagination-arrow-left', size: size, color: color
      endif
    when 'pagination-arrow-right'
      if locale_rtl contains current_locale
        render 'icon-pagination-arrow-left', size: size, color: color
      else
        render 'icon-pagination-arrow-right', size: size, color: color
      endif
    when 'user'
      render 'icon-user', size: size, color: color
    when 'location'
      render 'icon-location', size: size, color: color
    when 'address-empty'
      render 'icon-address-empty', size: size, color: color
    when 'linkedin'
      render 'icon-linkedin', size: size, color: color
    when 'arrow-with-reer-left'
      render 'icon-arrow-with-reer-left', size: size, color: color
    when 'info'
