{{ 'section-get-started.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-container>
    <xo-grid>
      <div class='get-started' style='--xs: 12;--md: 12;--xl: 12;'>
        <div class='get-started__top'>
          <div class='get-started__heading'>
            {% render 'text',
              text: section.settings.text_heading,
              tag_name: section.settings.text_tag_name,
              duration: section.settings.text_duration,
              effect: section.settings.text_effect
            %}
          </div>
          <div class='get-started__description'>
            {{ section.settings.description }}
          </div>
        </div>
        <div class='get-started__bottom'>
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'text' %}
                <div class='get-started__block'>
                  <xo-animate xo-cascade class='get-started__block-number'>{{ block.settings.number }}</xo-animate>
                  <xo-animate xo-cascade class='get-started__block-heading h5'>
                    {{ block.settings.heading }}
                  </xo-animate>
                  <xo-animate xo-cascade class='get-started__block-description'>
                    {{ block.settings.description }}
                  </xo-animate>
                </div>
              {% else %}
                <xo-animate xo-cascade class='get-started__image'>
                  <div class='get-started__image-desktop'>
                    {% render 'image', image: block.settings.image %}
                  </div>
                  <div class='get-started__image-mobile'>
                    {% render 'image', image: block.settings.image_mb %}
                  </div>
                </xo-animate>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </xo-grid>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.get_started.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "t:sections.all.text_tag_name.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.text_tag_name.option__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.text_tag_name.option__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.text_tag_name.option__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.text_tag_name.option__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.text_tag_name.option__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.text_tag_name.option__6.label"
        },
        {
          "value": "d1",
          "label": "t:sections.all.text_tag_name.option__7.label"
        },
        {
          "value": "d2",
          "label": "t:sections.all.text_tag_name.option__8.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "t:sections.all.text_heading.label",
      "default": "Heading"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "t:sections.all.text_duration.label",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "t:sections.all.text_effect.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.text_effect.option__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.text_effect.option__2.label"
        },
        {
          "value": "split",
          "label": "t:sections.all.text_effect.option__3.label"
        }
      ],
      "default": "reveal"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.get_started.settings.description.label",
      "default": "<p>Description</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.get_started.blocks.text.label",
      "settings": [
        {
          "type": "number",
          "id": "number",
          "label": "t:sections.get_started.blocks.text.settings.number.label",
          "default": 1
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "t:sections.get_started.blocks.text.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "t:sections.get_started.blocks.text.settings.description.label",
          "info": "t:sections.get_started.blocks.text.settings.description.info",
          "default": "<p>Description</p>"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:sections.get_started.blocks.image.label",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.get_started.blocks.image.settings.image.label"
        },
        {
          "type": "image_picker",
          "id": "image_mb",
          "label": "t:sections.get_started.blocks.image.settings.image_mb.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.get_started.presets.name",
      "blocks": [
        {
          "type": "text"
        },
        {
          "type": "image"
        },
        {
          "type": "text"
        },
        {
          "type": "image"
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}