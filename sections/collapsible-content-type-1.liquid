{{ 'section-collapsible-content-type-1.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-collapse-provider>
    {% if section.settings.section_style == 'style-1' %}
      <xo-container>
        <div class='collapsible-content-type-1'>
          <div class='collapsible-content-type-1__left'>
            <div class='collapsible-content-type-1__heading'>
              {% render 'text',
                text: section.settings.text_heading,
                tag_name: section.settings.text_tag_name,
                duration: section.settings.text_duration,
                effect: section.settings.text_effect
              %}
            </div>
            <div class='collapsible-content-type-1__content' id='{{ section.id }}'>
              {% for block in section.blocks %}
                {% assign name = block.id %}
                <xo-animate xo-cascade>
                  {% render 'collapse-item', collapse_trigger: block.settings.collapse_trigger, collapse_content: block.settings.collapse_content, name: name %}
                </xo-animate>
              {% endfor %}
            </div>
          </div>
          <div class='collapsible-content-type-1__right'>
            <div class='collapsible-content-type-1__image'>
              {% render 'animate-image', image: section.settings.image, border_radius: 209, max_width: 418, aspect_ratio: section.settings.aspect_ratio %}
            </div>
            <xo-animate xo-cascade xo-type='fade-left' class='collapsible-content-type-1__circle'>
              <div class='collapsible-content-type-1__circle-inner'></div>
            </xo-animate>
          </div>
        </div>
      </xo-container>
    {% else %}
      <xo-container class='collapsible-content-type-2'>
        <xo-animate xo-cascade xo-type='zoom-in' class='collapse-content-type-2__decor'>
          {% render 'image', image: section.settings.image_2, aspect_ratio: section.settings.aspect_ratio_2 %}
        </xo-animate>
        <div class='collapsible-content-type-2__heading'>
          {% render 'text',
            text: section.settings.text_heading,
            tag_name: section.settings.text_tag_name,
            duration: section.settings.text_duration,
            effect: section.settings.text_effect
          %}
        </div>
        <xo-grid>
          <div class='collapsible-content-type-2__content' style='--xs: 12; --lg: 10;--start-lg: 3;'>
            <div class='collapsible-content-type-2__bottom'>
              <div class='collapsible-content-type-2__left'>
                <xo-animate xo-cascade xo-type='zoom-in' class='collapsible-content-type-2__image-1'>
                  {% render 'image', image: section.settings.image_1, aspect_ratio: section.settings.aspect_ratio %}
                </xo-animate>
                <xo-animate xo-cascade xo-type='zoom-in' class='collapsible-content-type-2__image-2'>
                  {% render 'image', image: section.settings.image, aspect_ratio: section.settings.aspect_ratio %}
                </xo-animate>
              </div>
              <xo-animate xo-cascade class='collapsible-content-type-2__collapse' id='{{ section.id }}'>
                {% for block in section.blocks %}
                  {% assign name = block.id %}
                  <xo-animate xo-cascade>
                    {% render 'collapse-item', collapse_trigger: block.settings.collapse_trigger, collapse_content: block.settings.collapse_content, name: name %}
                  </xo-animate>
                {% endfor %}
              </xo-animate>
            </div>
          </div>
        </xo-grid>
      </xo-container>
    {% endif %}
  </xo-collapse-provider>
</section>

