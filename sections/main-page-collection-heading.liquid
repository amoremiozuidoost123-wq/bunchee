{% comment %}
  Renders a page heading.

  Accepts:
  - image: {Image} Image of the page (optional)

  Usage:
  {% render 'main-page-collection-heading' %}
{% endcomment %}

<section {% render 'section-attr' %}>
  <xo-container class='main-page-collection-heading'>
    {% render 'page-collection-heading', turn_on_image: section.settings.turn_on_image %}
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.main_page_collection_heading.name",
  "enabled_on": {
    "templates": [
      "collection"
    ]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "turn_on_image",
      "label": "t:sections.main_page_collection_heading.settings.turn_on_image.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_page_collection_heading.presets.name"
    }
  ]
}
{% endschema %}