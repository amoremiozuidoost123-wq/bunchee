    },
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "t:sections.mega_menu.settings.collection_list.label",
      "limit": 8
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.mega_menu.settings.product.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.mega_menu.settings.image.label"
    },
    {
      "type": "header",
      "content": "t:sections.mega_menu.settings.header_button.content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.all.button_text.label",
      "default": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button_link.label",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "button_style",
