          "label": "t:sections.mega_menu.settings.index_nav.option_3.label"
        },
        {
          "value": "3",
          "label": "t:sections.mega_menu.settings.index_nav.option_4.label"
        },
        {
          "value": "4",
          "label": "t:sections.mega_menu.settings.index_nav.option_5.label"
        },
        {
          "value": "5",
          "label": "t:sections.mega_menu.settings.index_nav.option_6.label"
        },
        {
          "value": "6",
          "label": "t:sections.mega_menu.settings.index_nav.option_7.label"
        },
        {
          "value": "7",
          "label": "t:sections.mega_menu.settings.index_nav.option_8.label"
        },
        {
          "value": "8",
          "label": "t:sections.mega_menu.settings.index_nav.option_9.label"
        },
        {
          "value": "9",
          "label": "t:sections.mega_menu.settings.index_nav.option_10.label"
        }
      ],
      "default": "0"
    },
    {
      "type": "header",
      "content": "t:sections.mega_menu.settings.header_content.content"
    },
    {
      "type": "collection",
      "id": "collection_heading",
      "label": "t:sections.mega_menu.settings.collection_heading.label"
