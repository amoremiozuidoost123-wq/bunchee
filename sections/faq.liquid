{{ 'section-faq.css' | asset_url | stylesheet_tag }}
<section {% render 'section-attr' %}>
  <xo-collapse-provider>
    <xo-container class='faq'>
      <xo-grid>
        <div class='faq__content' style='--xs: 12;--lg: 8;--start-lg: 3;'>
          <div class='faq__top'>
            <div class='faq__heading'>
              {% render 'text',
                text: section.settings.text_heading,
                tag_name: section.settings.text_tag_name,
                duration: section.settings.text_duration,
                effect: section.settings.text_effect
              %}
            </div>
          </div>
          <div class='faq__bottom'>
            {% for block in section.blocks %}
              {% render 'accordion-item', accordion_trigger: block.settings.accordion_trigger, accordion_content: block.settings.accordion_content, name: block.id %}
            {% endfor %}
          </div>
        </div>
      </xo-grid>
    </xo-container>
  </xo-collapse-provider>
</section>

{% schema %}
{
  "name": "t:sections.faq.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "t:sections.all.text_tag_name.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.text_tag_name.option__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.text_tag_name.option__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.text_tag_name.option__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.text_tag_name.option__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.text_tag_name.option__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.text_tag_name.option__6.label"
        },
        {
          "value": "d1",
          "label": "t:sections.all.text_tag_name.option__7.label"
        },
        {
          "value": "d2",
          "label": "t:sections.all.text_tag_name.option__8.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "t:sections.all.text_heading.label",
      "default": "Heading"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "t:sections.all.text_duration.label",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "t:sections.all.text_effect.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.text_effect.option__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.text_effect.option__2.label"
        },
        {
          "value": "split",
          "label": "t:sections.all.text_effect.option__3.label"
        }
      ],
      "default": "reveal"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "accordion-item",
      "name": "t:sections.faq.blocks.accordion_item.label",
      "settings": [
        {
          "type": "text",
          "id": "accordion_trigger",
          "label": "t:sections.faq.blocks.accordion_item.settings.accordion_trigger.label",
          "default": "Accordion trigger"
        },
        {
          "type": "richtext",
          "id": "accordion_content",
          "label": "t:sections.faq.blocks.accordion_item.settings.accordion_content.label",
          "default": "<p>Accordion content</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.presets.name",
      "blocks": [
        {
          "type": "accordion-item"
        },
        {
          "type": "accordion-item"
        }
      ]
    }
  ]
}
{% endschema %}