{{ 'section-testimonial-type-4.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-container>
    <xo-carousel
      class='testimonial-type-4'
      {% if section.settings.autoplay %}
        xo-autoplay='3000'
      {% endif %}
      {% if section.settings.overflow %}
        xo-overflow='visible'
      {% endif %}
      xo-per-view='{{ section.settings.slide_per_view }}'
      xo-per-move='3'
      xo-breakpoints="
        {
          600: {
            perView: 1,
            perMove: 1,
            gap: 10,
            overflow: 'hidden'
          },
          1000: {
            perView: 2,
            perMove: 2,
            {% if section.settings.overflow %}
              overflow: 'visible'
            {% endif %}
          },
        }
      "
      xo-render-bullet="<span class='carousel-bullet'></span>"
    >
      <xo-carousel-inner>
        <div class='testimonial-type-4__top'>
          <div class='testimonial-type-4__heading'>
            {% render 'text',
              text: section.settings.text_heading,
              tag_name: section.settings.text_tag_name,
              duration: section.settings.text_duration,
              effect: section.settings.text_effect
            %}
          </div>
          {% render 'carousel-navigation', disabled: false, mobile_disabled: true %}
        </div>
        <xo-carousel-list>
          {% for block in section.blocks %}
            <xo-carousel-slide>
              {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
              {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
              {% render 'testimonial-slide-type-4',
                product: block.settings.product,
                show_image: section.settings.product_card_show_image,
                show_price: section.settings.product_card_show_price,
                media_aspect_ratio: section.settings.product_card_aspect_ratio,
                color_scheme: section.settings.card_color_scheme,
                placeholder_image: placeholder_image,
                review: block.settings.review,
                customer_name: block.settings.customer_name,
                verified_user: block.settings.verified_user
              -%}
            </xo-carousel-slide>
          {% endfor %}
        </xo-carousel-list>
        <div class='testimonial-type-4__bottom'>
          {% render 'carousel-navigation', disabled: true, mobile_disabled: false %}
        </div>
      </xo-carousel-inner>
    </xo-carousel>
  </xo-container>
</section>

