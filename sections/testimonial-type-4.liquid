      "default": false
    },
    {
      "type": "checkbox",
      "id": "overflow",
      "label": "t:sections.testimonial_type_4.settings.overflow.label",
      "default": false
    },
    {
      "type": "range",
      "id": "slide_per_view",
      "min": 3,
      "max": 5,
      "step": 1,
      "label": "t:sections.testimonial_type_4.settings.slide_per_view.label",
      "default": 3
    },
    {
      "type": "header",
      "content": "t:sections.all.product_card_heading.content"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_image",
      "default": true,
      "label": "t:sections.all.product_card_show_image.label"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_price",
      "label": "t:sections.all.product_card_show_price.label",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "t:sections.all.card_color_scheme.label"
    },
    {
