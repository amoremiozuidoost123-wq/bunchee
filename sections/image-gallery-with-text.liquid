{{ 'section-image-gallery-with-text.css' | asset_url | stylesheet_tag }}
<section {% render 'section-attr' %}>
  <div class='image-gallery-with-text'>
    <xo-container>
      <div class='image-gallery-with-text__top'>
        <div class='image-gallery-with-text__text'>
          <div class='image-gallery-with-text__heading'>
            {% render 'text',
              text: section.settings.text_heading,
              tag_name: section.settings.text_tag_name,
              duration: section.settings.text_duration,
              effect: section.settings.text_effect
            %}
          </div>
          <xo-animate xo-cascade xo-constant='35' class='image-gallery-with-text__description'>{{ section.settings.description }}</xo-animate>
        </div>
        <xo-animate xo-cascade xo-constant='40' xo-type='zoom-in' class='image-gallery-with-text__image-decor'>
          <div class='image-gallery-with-text__image-1'>
            <div class='image-gallery-with-text__image-small'>
              {% render 'image', image: section.settings.image_small %}
            </div>
            {% render 'image', image: section.settings.image_1, aspect_ratio: section.settings.aspect_ratio %}
            <div class='image-gallery-with-text__circle'></div>
          </div>
          <div class='image-gallery-with-text__image-2'>
            {% render 'image', image: section.settings.image_2, aspect_ratio: section.settings.aspect_ratio_2 %}
          </div>
        </xo-animate>
      </div>
    </xo-container>
    <xo-animate xo-cascade xo-constant='40' class='image-gallery-with-text__bottom'>
      <xo-marquee
        class='image-gallery-with-text__marquee'
        xo-speed='{{ section.settings.marquee_speed }}'
        {%- if section.settings.stop_marquee -%}
          xo-pause-on-hover='true'
        {%- endif -%}
        {%- if section.settings.marquee_right_to_left -%}
          xo-rtl='true'
        {%- endif -%}
      >
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'image-item' %}
              <div class='image-gallery-with-text__image'>
                {% render 'image', image: block.settings.item_image, aspect_ratio: '1' %}
              </div>
          {% endcase %}
        {% endfor %}
      </xo-marquee>
    </xo-animate>
  </div>
</section>

