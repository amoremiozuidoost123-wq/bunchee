{{ 'section-image-with-text-type-4.css' | asset_url | stylesheet_tag }}

<div {% render 'section-attr' %}>
  <div class='image-with-text-type-4'>
    <xo-container class='image-with-text-type-4__container'>
      <xo-animate xo-cascade>
        <div class='image-with-text-type-4__heading'>
          {% render 'text',
            text: section.settings.text_heading,
            tag_name: section.settings.text_tag_name,
            duration: section.settings.text_duration,
            effect: section.settings.text_effect
          %}
        </div>
      </xo-animate>
      <xo-animate xo-cascade xo-constant='30' xo-type='zoom-in' class='image-with-text-type-4__image'>
        {% render 'image', image: section.settings.image, aspect_ratio: section.settings.aspect_ratio %}
        <div class='image-with-text-type-4__image-decor'>
          {% render 'image', image: section.settings.image_decor, aspect_ratio: '1' %}
        </div>
      </xo-animate>
      <xo-animate xo-cascade xo-constant='40' xo-type='fade-left' class='image-with-text-type-4__box-1'>
        <h2 class='image-with-text-type-4__description image-with-text-type-4__description--1 h6'>{{ section.settings.description_1 }}</h2>
        <div class='image-with-text-type-4__icon image-with-text-type-4__icon--1'>
          {% render 'image', image: section.settings.icon_1, aspect_ratio: '1' %}
        </div>
      </xo-animate>
      <xo-animate xo-cascade xo-constant='45' xo-type='fade-right' class='image-with-text-type-4__box-2'>
        <div class='image-with-text-type-4__icon image-with-text-type-4__icon--2'>
          {% render 'image', image: section.settings.icon_2, aspect_ratio: '1' %}
        </div>
        <h2 class='image-with-text-type-4__description image-with-text-type-4__description--2 h6'>{{ section.settings.description_2 }}</h2>
      </xo-animate>
    </xo-container>
  </div>
</div>

