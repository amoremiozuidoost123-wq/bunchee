{{ 'section-main-account.css' | asset_url | stylesheet_tag }}
{{ 'account-detail.css' | asset_url | stylesheet_tag }}
{{ 'orders-table.css' | asset_url | stylesheet_tag }}

<div {% render 'section-attr' %}>
  <xo-container>
    <xo-animate xo-cascade>
      <div class='account__top'>
        <h2 class='account__heading'>{{ section.settings.heading }}</h2>
        {% assign log_out_label = 'customer.log_out' | t %}
        <div class='account__button'>
          {% render 'button', text: log_out_label, link: routes.account_logout_url, style: 'link' %}
        </div>
      </div>
      {% render 'space', value: '6rem' %}
    </xo-animate>

    <xo-grid>
      <div class='account__list-order' style='--xs: 12; --lg: 9'>
        <h6 class='account__subheading'>{{ section.settings.subheading }}</h6>
        {% render 'orders-table' %}
      </div>
      <div class='account__list-address' style='--xs: 12; --lg: 3'>
        {% render 'account-detail' %}
      </div>
    </xo-grid>
  </xo-container>
</div>

{% schema %}
{
  "name": "t:sections.main_account.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_account.settings.heading.label",
      "default": "Account"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.main_account.settings.subheading.label",
      "default": "Order history"
    },
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ]
}
{% endschema %}