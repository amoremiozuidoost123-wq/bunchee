{{ 'section-benefit.css' | asset_url | stylesheet_tag }}

{% liquid
  assign background = section.settings.background
  assign background_mobile = section.settings.background_mobile
%}

<section {% render 'section-attr' %}>
  <xo-container>
    <xo-grid>
      <div class='benefit' style='--xs: 12;--md: 12;--xl: 8; --start-xl: 3;'>
        <xo-animate xo-cascade xo-type='zoom-in' class='benefit__background'>
          {% if background != blank and background_mobile != blank %}
            <div class='benefit__background-desktop'>
              {% render 'image', image: section.settings.background %}
            </div>
            <div class='benefit__background-mobile'>
              {% render 'image', image: section.settings.background_mobile %}
            </div>

          {% elsif background != blank and background_mobile == blank %}
            <div class='benefit__background-desktop'>
              {% render 'image', image: section.settings.background %}
            </div>
            <div class='benefit__background-mobile'>
              {% render 'image', image: section.settings.background %}
            </div>
          {% elsif background == blank and background_mobile != blank %}
            <div class='benefit__background-desktop'>
              {% render 'image', image: section.settings.background_mobile %}
            </div>
            <div class='benefit__background-mobile'>
              {% render 'image', image: section.settings.background_mobile %}
            </div>
          {% else %}
            <div class='benefit__background-desktop'>
              {% render 'image' %}
            </div>
            <div class='benefit__background-mobile'>
              {% render 'image' %}
            </div>
          {% endif %}
        </xo-animate>
        <div class='benefit__heading' style="--heading-width: {{ section.settings.width }}px;--heading-width-mb: {{ section.settings.width_mb }}px;">
          {% render 'text',
            text: section.settings.text_heading,
            tag_name: section.settings.text_tag_name,
            duration: section.settings.text_duration,
            effect: section.settings.text_effect
          %}
        </div>
        <xo-grid class='benefit__list'>
          {% for block in section.blocks %}
            <xo-text-box class='benefit__block' style='--xs: 12;--lg: 6;--xxl: 4;'>
              <xo-animate xo-cascade class='benefit__block-heading h4'>{{ block.settings.heading }}</xo-animate>
              <xo-animate xo-cascade class='benefit__block-subheading'>{{ block.settings.subheading }}</xo-animate>
              {% comment %} list input here, keep display none {% endcomment %}
              <div class='benefit__text-box' aria-hidden='true'>
                {{ block.settings.content }}
              </div>
              {% comment %} Content is show here {% endcomment %}
              <xo-animate xo-cascade xo-type='fade' class='benefit__content'></xo-animate>
              <div class='benefit__icon-container'>
                <span class='benefit__icon'>{% render 'icon', name: 'check-with-circle', size: '16' %}</span>
              </div>
            </xo-text-box>
          {% endfor %}
        </xo-grid>
      </div>
    </xo-grid>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.benefit.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "t:sections.all.text_tag_name.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.text_tag_name.option__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.text_tag_name.option__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.text_tag_name.option__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.text_tag_name.option__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.text_tag_name.option__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.text_tag_name.option__6.label"
        },
        {
          "value": "d1",
          "label": "t:sections.all.text_tag_name.option__7.label"
        },
        {
          "value": "d2",
          "label": "t:sections.all.text_tag_name.option__8.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "t:sections.all.text_heading.label",
      "default": "Heading"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "t:sections.all.text_duration.label",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "t:sections.all.text_effect.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.text_effect.option__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.text_effect.option__2.label"
        },
        {
          "value": "split",
          "label": "t:sections.all.text_effect.option__3.label"
        }
      ],
      "default": "reveal"
    },
    {
      "type": "range",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "id": "width",
      "label": "t:sections.benefit.settings.width.label",
      "default": 360
    },
    {
      "type": "range",
      "min": 200,
      "max": 500,
      "step": 10,
      "unit": "px",
      "id": "width_mb",
      "label": "t:sections.benefit.settings.width_mb.label",
      "default": 300
    },
    {
      "type": "image_picker",
      "id": "background",
      "label": "t:sections.benefit.settings.background.label"
    },
    {
      "type": "image_picker",
      "id": "background_mobile",
      "label": "t:sections.benefit.settings.background_mobile.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "t:sections.benefit.blocks.tier.label",
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "t:sections.benefit.blocks.tier.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "t:sections.benefit.blocks.tier.settings.subheading.label",
          "default": "Subheading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.benefit.blocks.tier.settings.content.label",
          "info": "t:sections.benefit.blocks.tier.settings.content.info",
          "default": "<ul><li>Benefit</li><li>Benefit</li><li>Benefit</li></ul>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.benefit.presets.name",
      "blocks": [
        {
          "type": "tier"
        },
        {
          "type": "tier"
        },
        {
          "type": "tier"
        }
      ]
    }
  ]
}
{% endschema %}