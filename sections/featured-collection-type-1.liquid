{{ 'section-featured-collection-type-1.css' | asset_url | stylesheet_tag }}

{% liquid
  assign section_style = section.settings.section_style
%}

<section {% render 'section-attr' %}>
  {% if section_style == 'style-1' %}
    <xo-container class='featured-collection-type-1'>
      <div class='featured-collection-type-1__top'>
        <xo-animate xo-cascade class='featured-collection-type-1__subheading'>
          {{ section.settings.subheading }}
        </xo-animate>
        <div class='featured-collection-type-1__heading'>
          {% render 'text',
            text: section.settings.text_heading,
            tag_name: section.settings.text_tag_name,
            duration: section.settings.text_duration,
            effect: section.settings.text_effect
          %}
        </div>
      </div>
      <xo-carousel
        class='featured-collection-type-1__carousel'
        {% if section.settings.autoplay %}
          xo-autoplay='3000'
          xo-progress='true'
        {% endif %}
        xo-per-view='3'
        xo-per-view='1'
        xo-gap='0'
        xo-render-bullet='<span></span>'
        xo-breakpoints='
          {
            600: {
              perView: 1,
              perMove: 1,
              gap: 0,
            },
            1400: {
              perView: 2,
              perMove: 2,
              gap: 15,
            },
          }
        '
      >
        <xo-carousel-inner>
          <div class='featured-collection-type-1__top-inner'>
            <xo-animate xo-cascade class='featured-collection-type-1__subheading'>
              {{ section.settings.subheading }}
            </xo-animate>
            <div class='featured-collection-type-1__heading'>
              {% render 'text',
                text: section.settings.text_heading,
                tag_name: section.settings.text_tag_name,
                duration: section.settings.text_duration,
                effect: section.settings.text_effect
              %}
            </div>
          </div>
          <xo-carousel-list>
            {% if section.settings.product_list != blank %}
              {% for product in section.settings.product_list %}
                {% assign lazyload = true %}
                {% if forloop.index0 < 3 %}
                  {% assign lazyload = false %}
                {% endif %}
                <xo-carousel-slide>
                  {% render 'product-card',
                    product: product,
                    show_image: section.settings.product_card_show_image,
                    show_secondary_image: section.settings.product_card_show_secondary_image,
                    show_vendor: section.settings.product_card_show_vendor,
                    show_description: section.settings.product_card_show_description,
                    show_price: section.settings.product_card_show_price,
                    show_badge: section.settings.product_card_show_badge,
                    media_aspect_ratio: section.settings.product_card_aspect_ratio,
                    color_scheme: section.settings.card_color_scheme,
                    animate_enabled: false,
                    lazyload: lazyload,
                    price_type: 'all'
                  %}
                </xo-carousel-slide>
              {% endfor %}
            {% else %}
              {% for i in (1..4) %}
                {% assign lazyload = true %}
                {% if forloop.index0 < 3 %}
                  {% assign lazyload = false %}
                {% endif %}
                <xo-carousel-slide>
                  {% render 'product-card',
                    product: false,
                    show_image: section.settings.product_card_show_image,
                    show_secondary_image: section.settings.product_card_show_secondary_image,
                    show_vendor: section.settings.product_card_show_vendor,
                    show_description: section.settings.product_card_show_description,
                    show_price: section.settings.product_card_show_price,
                    show_badge: section.settings.product_card_show_badge,
                    media_aspect_ratio: section.settings.product_card_aspect_ratio,
                    color_scheme: section.settings.card_color_scheme,
                    animate_enabled: false,
                    lazyload: lazyload,
                    price_type: 'all'
                  %}
                </xo-carousel-slide>
              {% endfor %}
            {% endif %}
          </xo-carousel-list>
        </xo-carousel-inner>
        {% render 'carousel-navigation', style: '', align: 'center', position: 'in-content', disabled: false, mobile_disabled: true %}
        <xo-carousel-pagination
          class='
            featured-collection-type-1__pagination {% if section.settings.carousel_pag_disabled -%} featured-collection-type-1__pagination--disabled {%- endif %}
            {% if section.settings.carousel_pag_mobile_disabled -%} featured-collection-type-1__pagination--mobile-disabled {%- endif %}
          '
          style='
            --pag_align: {{ section.settings.carousel_pag_align | default: 'left'  }};
            {% if section.settings.autoplay %}
              --opacity: 0.2;
              {% else %}
                --opacity: 0.6;
            {% endif %}
          '
        ></xo-carousel-pagination>
      </xo-carousel>
    </xo-container>
  {% else %}
    <xo-container class='featured-collection'>
      <div class='featured-collection__heading'>
        {% render 'text',
          text: section.settings.text_heading,
          tag_name: section.settings.text_tag_name,
          duration: section.settings.text_duration,
          effect: section.settings.text_effect
        %}
      </div>
      {% render 'space', value: '2rem' %}
      <xo-carousel
        {% if section.settings.autoplay %}
          xo-autoplay='3000'
        {% endif %}
        xo-per-view='{{ section.settings.columns_desktop }}'
        xo-breakpoints="
          {
            600: {
              gap: 10,
              perView: '1'
            },
            992: {
              perView: '{{ section.settings.columns_desktop | minus: 1  }}'
            }
          }
        "
      >
        <xo-carousel-inner>
          <xo-carousel-list>
            {% if section.settings.collection.products != blank %}
              {%- for product in section.settings.collection.products limit: section.settings.limit -%}
                {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                {%- assign placeholder_image = 'product-apparel-' | append: placeholder_image_index -%}
                <xo-carousel-slide>
                  <div class="featured-collection__card">
                    {% render 'product-card',
                      product: product,
                      show_image: section.settings.product_card_show_image,
                      show_secondary_image: section.settings.product_card_show_secondary_image,
                      show_vendor: section.settings.product_card_show_vendor,
                      show_description: section.settings.product_card_show_description,
                      show_quick_add: section.settings.product_card_show_quick_add,
                      show_quick_view: section.settings.product_card_show_quick_view,
                      show_price: section.settings.product_card_show_price,
                      show_badge: section.settings.product_card_show_badge,
                      media_aspect_ratio: section.settings.product_card_aspect_ratio,
                      color_scheme: section.settings.card_color_scheme,
                      placeholder_image: placeholder_image,
                      price_type: 'all'
                    %}
                  </div>
                </xo-carousel-slide>
              {%- endfor -%}
            {% else %}
              {%- for i in (1..4) -%}
                {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                {%- assign placeholder_image = 'product-apparel-' | append: placeholder_image_index -%}
                <xo-carousel-slide>
                  <div class="featured-collection__card">
                    {% render 'product-card',
                      product: false,
                      show_image: section.settings.product_card_show_image,
                      show_secondary_image: section.settings.product_card_show_secondary_image,
                      show_vendor: section.settings.product_card_show_vendor,
                      show_description: section.settings.product_card_show_description,
                      show_quick_add: section.settings.product_card_show_quick_add,
                      show_quick_view: section.settings.product_card_show_quick_view,
                      show_price: section.settings.product_card_show_price,
                      show_badge: section.settings.product_card_show_badge,
                      media_aspect_ratio: section.settings.product_card_aspect_ratio,
                      color_scheme: section.settings.card_color_scheme,
                      placeholder_image: placeholder_image,
                      price_type: 'all'
                    %}
                  </div>
                </xo-carousel-slide>
              {%- endfor -%}
            {% endif %}
          </xo-carousel-list>
        </xo-carousel-inner>
        {% render 'carousel-navigation', style: '', position: 'in-content', disabled: false, mobile_disabled: true %}
        {% render 'carousel-pagination',
          align: section.settings.carousel_pag_align,
          disabled: section.settings.carousel_pag_disabled,
          mobile_disabled: section.settings.carousel_pag_mobile_disabled
        %}
      </xo-carousel>
      {% render 'space', value: '2rem' %}
    </xo-container>
  {% endif %}
</section>

