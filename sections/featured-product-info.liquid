{{ 'section-featured-product-info.css' | asset_url | stylesheet_tag }}
{{ 'product-info-media-type-1.css' | asset_url | stylesheet_tag }}
{{ 'product-info-content-type-1.css' | asset_url | stylesheet_tag }}
{% assign product = section.settings.product %}
{% assign product_handle_name = product.handle %}
{% assign decor = section.settings.decor %}

<section {% render 'section-attr' %}>
  {% if product != blank %}
    <xo-product
      xo-featured-product
      xo-product-url='{{ shop.url }}/{{ product.url }}'
      xo-product-id='{{ product.id }}'
      xo-section-id='{{ section.id }}'
      class='featured-product-info'
    >
      <show-tooltip>
        <xo-container>
          <div class='featured-product-info__heading'>
            {% render 'text',
              text: section.settings.text_heading,
              tag_name: section.settings.text_tag_name,
              duration: section.settings.text_duration,
              effect: section.settings.text_effect
            %}
          </div>
          <xo-grid class='featured-product-info'>
            <div style='--xs: 12; --lg: 6' class='featured-product-info__product-info-media-type-1'>
              <xo-animate xo-cascade>
                {% render 'product-info-media-type-1', product: product, decor: decor %}
              </xo-animate>
            </div>
            <div style='--xs: 12; --lg: 6;' class='featured-product-info__product-info-content-type-1'>
              {% render 'product-info-content-type-1', product: product %}
            </div>
          </xo-grid>
        </xo-container>
        {% render 'product-data', product: all_products[product_handle_name] %}
      </show-tooltip>
    </xo-product>
    {% render 'main-product-ld-json' %}
  {% else %}
    <xo-container class='featured-product-info__placeholder'>
      <div class='featured-product-info__heading'>
        {% render 'text',
          text: section.settings.text_heading,
          tag_name: section.settings.text_tag_name,
          duration: section.settings.text_duration,
          effect: section.settings.text_effect
        %}
      </div>
      <xo-grid class='featured-product-info'>
        <div style='--xs: 12; --lg: 6' class='featured-product-info__product-info-media-type-1'>
          <xo-animate xo-cascade>
            {% render 'product-info-media-type-1', product: false, decor: decor %}
          </xo-animate>
        </div>
        <div style='--xs: 12; --lg: 6;' class='featured-product-info__product-info-content-type-1'>
          {% render 'product-info-content-type-1', product: false %}
        </div>
      </xo-grid>
    </xo-container>
  {% endif %}
</section>

{% schema %}
{
  "name": "t:sections.featured_product_info.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "t:sections.all.text_tag_name.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.text_tag_name.option__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.text_tag_name.option__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.text_tag_name.option__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.text_tag_name.option__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.text_tag_name.option__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.text_tag_name.option__6.label"
        },
        {
          "value": "d1",
          "label": "t:sections.all.text_tag_name.option__7.label"
        },
        {
          "value": "d2",
          "label": "t:sections.all.text_tag_name.option__8.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "t:sections.all.text_heading.label",
      "default": "Heading"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "t:sections.all.text_duration.label",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "t:sections.all.text_effect.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.text_effect.option__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.text_effect.option__2.label"
        },
        {
          "value": "split",
          "label": "t:sections.all.text_effect.option__3.label"
        }
      ],
      "default": "reveal"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.featured_product_info.settings.product.label"
    },
    {
      "type": "image_picker",
      "id": "decor",
      "label": "t:sections.featured_product_info.settings.decor.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "t:sections.featured_product_info.blocks.title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "t:sections.featured_product_info.blocks.price",
      "limit": 1
    },
    {
      "type": "description",
      "name": "t:sections.featured_product_info.blocks.description",
      "limit": 1
    },
    {
      "type": "quantity_picker",
      "name": "t:sections.featured_product_info.blocks.quantity_picker",
      "limit": 1
    },
    {
      "type": "variants",
      "name": "t:sections.featured_product_info.blocks.variants.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "variant_style",
          "options": [
            {
              "value": "boxed",
              "label": "t:sections.featured_product_info.blocks.variants.settings.variant_style.option_1.label"
            },
            {
              "value": "select",
              "label": "t:sections.featured_product_info.blocks.variants.settings.variant_style.option_2.label"
            }
          ],
          "default": "boxed",
          "label": "t:sections.featured_product_info.blocks.variants.settings.variant_style.label"
        },
        {
          "type": "paragraph",
          "content": "t:sections.featured_product_info.blocks.variants.settings.paragraph.label"
        },
        {
          "type": "select",
          "id": "variant_color_style",
          "options": [
            {
              "value": "color",
              "label": "t:sections.featured_product_info.blocks.variants.settings.variant_color_style.option_1.label"
            },
            {
              "value": "variant_image",
              "label": "t:sections.featured_product_info.blocks.variants.settings.variant_color_style.option_2.label"
            }
          ],
          "default": "color",
          "label": "t:sections.featured_product_info.blocks.variants.settings.variant_color_style.label",
          "info": "t:sections.featured_product_info.blocks.variants.settings.variant_color_style.info"
        }
      ]
    },
    {
      "type": "buy_button",
      "name": "t:sections.featured_product_info.blocks.buy_button.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "t:sections.featured_product_info.blocks.buy_button.settings.show_dynamic_checkout.label",
          "info": "t:sections.featured_product_info.blocks.buy_button.settings.show_dynamic_checkout.info",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_gift_card_recipient",
          "label": "t:sections.featured_product_info.blocks.buy_button.settings.show_gift_card_recipient.label",
          "info": "t:sections.featured_product_info.blocks.buy_button.settings.show_gift_card_recipient.info",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_product_info.presets.name",
      "blocks": [
        {
          "type": "title",
          "settings": {}
        },
        {
          "type": "description",
          "settings": {}
