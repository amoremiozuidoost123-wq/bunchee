{{ 'section-main-cart.css' | asset_url | stylesheet_tag }}
{{ 'cart-item.css' | asset_url | stylesheet_tag }}
{{ 'cart-table.css' | asset_url | stylesheet_tag }}
{{ 'cart-totals.css' | asset_url | stylesheet_tag }}
{{ 'cart-free-shipping.css' | asset_url | stylesheet_tag }}
{{ 'cart-note.css' | asset_url | stylesheet_tag }}
{{ 'cart-tax-note.css' | asset_url | stylesheet_tag }}
{{ 'cart-discount-list.css' | asset_url | stylesheet_tag }}
{{ 'cart-continue-shopping.css' | asset_url | stylesheet_tag }}

{% capture continue_shopping %}
  {% render 'cart-continue-shopping' %}
{% endcapture %}

<div {% render 'section-attr' %}>
  <xo-cart id='{{ section.id }}' class='xo-main-cart section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}'>
    <xo-container class='xo-cart'>
      <xo-animate xo-cascade>
        <div class='xo-cart__heading'>
          {% render 'text',
            text: section.settings.text_heading,
            tag_name: section.settings.text_tag_name,
            duration: section.settings.text_duration,
            effect: section.settings.text_effect
          %}
        </div>
      </xo-animate>
      <xo-animate xo-cascade>
        <xo-grid>
          <xo-cart-will-change xo-unique-id='cart-table-{{ section.id }}' style='--md: 12; --xl: {% if cart != empty %}8{% else %}12{% endif %}'>
            {% if cart != empty %}
              {% render 'cart-table' %}
            {% else %}
              {% assign title = 'sections.cart.empty' | t %}
              {% render 'empty', title: title, content: continue_shopping, icon_size: '11rem' %}
            {% endif %}
          </xo-cart-will-change>
          <xo-cart-will-change xo-unique-id='cart-right-{{ section.id }}' style='--md: 12; --xl: 4;'>
            {% if cart != empty %}
              <div class='xo-cart__right'>
                {% for block in section.blocks %}
                  {% case block.type %}
                    {% when 'free_shipping' %}
                      {% render 'cart-free-shipping' %}
                    {% when 'note' %}
                      <xo-cart-will-change xo-unique-id='xo-cart-note-{{ section.id }}'>
                        {% render 'cart-note', uid: 'main-cart', type: 'collapse' %}
                      </xo-cart-will-change>
                    {% when 'subtotal' %}
                      <xo-cart-will-change xo-unique-id='xo-space-1-{{ section.id }}'>
                        {% render 'space', value: '3.3rem' %}
                      </xo-cart-will-change>
                      {% render 'cart-totals' %}
                      {% render 'cart-discount-list' %}
                      {% render 'cart-tax-note' %}
                      <xo-cart-will-change xo-unique-id='xo-space-2-{{ section.id }}'>
                        {% render 'space', value: '2.4rem' %}
                      </xo-cart-will-change>
                      {% render 'cart-actions' %}
                  {% endcase %}
                {% endfor %}
              </div>
            {% endif %}
          </xo-cart-will-change>
        </xo-grid>

        <xo-cart-will-change xo-unique-id='continue-shopping-{{ section.id }}'>
          {% if cart != empty %}
            {% render 'space', value: '1rem' %}
            {{ continue_shopping }}
          {% endif %}
        </xo-cart-will-change>
      </xo-animate>
    </xo-container>
  </xo-cart>
</div>

{% schema %}
{
  "name": "t:sections.main_cart.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "t:sections.all.text_tag_name.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.text_tag_name.option__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.text_tag_name.option__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.text_tag_name.option__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.text_tag_name.option__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.text_tag_name.option__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.text_tag_name.option__6.label"
        },
        {
          "value": "d1",
          "label": "t:sections.all.text_tag_name.option__7.label"
        },
        {
          "value": "d2",
          "label": "t:sections.all.text_tag_name.option__8.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "t:sections.all.text_heading.label",
      "default": "Heading"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "t:sections.all.text_duration.label",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "t:sections.all.text_effect.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.text_effect.option__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.text_effect.option__2.label"
        },
        {
          "value": "split",
          "label": "t:sections.all.text_effect.option__3.label"
        }
      ],
      "default": "reveal"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "subtotal",
      "name": "t:sections.main_cart.settings.subtotal.label",
      "limit": 1
    },
    {
      "type": "free_shipping",
      "name": "t:sections.main_cart.settings.free_shipping.label",
      "limit": 1
    },
    {
      "type": "note",
      "name": "t:sections.main_cart.settings.note.label",
      "limit": 1
    }
  ]
}
{% endschema %}