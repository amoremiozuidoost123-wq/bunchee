{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}

{% assign blog_limit = section.settings.blog_limit %}
<div {% render 'section-attr' %}>
  <xo-container class='main-blog'>
    <div class='main-blog__top'>
      <h1 class='main-blog__heading'>{{ blog.title }}</h1>
      <div class='main-blog__description'>{{ section.settings.description }}</div>
    </div>
    {%- paginate blog.articles by blog_limit -%}
      <xo-grid style='--xs: 1; --lg: 3;'>
        {%- for article in blog.articles -%}
          {% render 'article-card',
            article: article,
            article_card_style: section.settings.article_card_style,
            media_aspect_ratio: section.settings.article_card_media_aspect_ratio,
            show_image: section.settings.article_card_show_image,
            show_date: section.settings.article_card_show_date,
            show_author: section.settings.article_card_show_author,
            show_excerpt: section.settings.article_card_show_excerpt,
            show_tags: section.settings.article_card_show_tags,
            color_scheme: section.settings.card_color_scheme
          %}
        {%- endfor -%}
      </xo-grid>
      {%- render 'pagination', paginate: paginate -%}
    {%- endpaginate -%}
  </xo-container>
</div>

{% schema %}
{
  "name": "t:sections.main_blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "blog_limit",
      "min": 4,
      "max": 16,
      "step": 1,
      "label": "t:sections.main_blog.settings.blog_limit.label",
      "default": 9
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.main_blog.settings.description.label",
      "default": "<p>Use this text to introduce about your blog</p>"
    },
    {
      "type": "header",
      "content": "t:sections.all.article_card_header.content"
    },
    {
      "type": "select",
      "id": "article_card_style",
      "options": [
        {
          "value": "standard",
          "label": "t:sections.all.article_card_style.option_1.label"
        },
        {
          "value": "boxed",
          "label": "t:sections.all.article_card_style.option_2.label"
        }
      ],
      "default": "standard",
      "label": "t:sections.all.article_card_style.label"
    },
    {
      "type": "checkbox",
      "id": "article_card_show_image",
      "default": true,
      "label": "t:sections.all.article_card_show_image.label"
    },
    {
      "type": "checkbox",
      "id": "article_card_show_date",
      "default": true,
      "label": "t:sections.all.article_card_show_date.label"
    },
    {
      "type": "checkbox",
      "id": "article_card_show_author",
      "default": false,
      "label": "t:sections.all.article_card_show_author.label"
    },
    {
      "type": "checkbox",
      "id": "article_card_show_excerpt",
      "default": false,
      "label": "t:sections.all.article_card_show_excerpt.label"
    },
    {
      "type": "checkbox",
      "id": "article_card_show_tags",
      "default": false,
      "label": "t:sections.all.article_card_show_tags.label"
    },
    {
      "type": "select",
      "id": "article_card_media_aspect_ratio",
      "label": "t:sections.all.article_card_media_aspect_ratio.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.all.article_card_media_aspect_ratio.option_1.label"
        },
        {
          "value": "2/3",
          "label": "t:sections.all.article_card_media_aspect_ratio.option_2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.article_card_media_aspect_ratio.option_3.label"
        },
        {
          "value": "1",
          "label": "t:sections.all.article_card_media_aspect_ratio.option_4.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.article_card_media_aspect_ratio.option_5.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.article_card_media_aspect_ratio.option_6.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.article_card_media_aspect_ratio.option_7.label"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "article_color_scheme",
      "label": "t:sections.all.article_color_scheme.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ]
}
{% endschema %}