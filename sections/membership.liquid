{{ 'section-membership.css' | asset_url | stylesheet_tag }}

{% liquid
  assign background = section.settings.background
  assign background_mobile = section.settings.background_mobile
%}
<div class='membership'>
  <section {% render 'section-attr' %}>
    <xo-container>
      <div class='membership__container'>
        <xo-animate xo-cascade xo-type='zoom-in' class='membership__background'>
          {% if background != blank and background_mobile != blank %}
            <div class='membership__background-desktop'>
              {% render 'image', image: section.settings.background, aspect_ratio: section.settings.aspect_ratio %}
            </div>
            <div class='membership__background-mobile'>
              {% render 'image', image: section.settings.background_mobile, aspect_ratio: section.settings.aspect_ratio_mb %}
            </div>

          {% elsif background != blank and background_mobile == blank %}
            <div class='membership__background-desktop'>
              {% render 'image', image: section.settings.background, aspect_ratio: section.settings.aspect_ratio %}
            </div>
            <div class='membership__background-mobile'>
              {% render 'image', image: section.settings.background, aspect_ratio: section.settings.aspect_ratio %}
            </div>
          {% elsif background == blank and background_mobile != blank %}
            <div class='membership__background-desktop'>
              {% render 'image', image: section.settings.background_mobile, aspect_ratio: section.settings.aspect_ratio_mb %}
            </div>
            <div class='membership__background-mobile'>
              {% render 'image', image: section.settings.background_mobile, aspect_ratio: section.settings.aspect_ratio_mb %}
            </div>
          {% else %}
            <div class='membership__background-desktop'>
              {% render 'image' %}
            </div>
            <div class='membership__background-mobile'>
              {% render 'image' %}
            </div>
          {% endif %}
        </xo-animate>
        <div class='membership__content'>
          <div class='membership__inner'>
            <xo-animate xo-cascade class='membership__heading h2'>
              {{ section.settings.heading }}
            </xo-animate>
            <xo-animate xo-cascade class='membership__description'>{{ section.settings.description }}</xo-animate>
            <xo-animate xo-cascade class='membership__button'>
              {% render 'button',
                text: section.settings.button_text,
                link: section.settings.button_link,
                size: section.settings.button_size,
                style: section.settings.button_style,
                icon: 'arrow-testimonial-right',
                icon_position: 'right',
                icon_size: '24'
              %}
            </xo-animate>
          </div>
        </div>
      </div>
    </xo-container>
  </section>
</div>

{% schema %}
