{{ 'section-product-grid-type-2.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <div class='product-grid-type-2'>
    <div class='product-grid-type-2__left'>
      <fieldset class='product-grid-type-2__fieldset'>
        <legend class='product-grid-type-2__heading h3'>{{ section.settings.heading }}</legend>
        <div class='product-grid-type-2__content'>
          {% for block in section.blocks %}
            {% assign product_index = forloop.index %}
            <div class='product-grid-type-2__item'>
              {% render 'product-grid-card-type-2',
                product: block.settings.product,
                product_index: product_index,
                show_tag: block.settings.product_card_show_tag,
                image_1: block.settings.image_1,
                image_2: block.settings.image_2,
                tag_text_1: block.settings.tag_text_1,
                tag_text_2: block.settings.tag_text_2,
                media_aspect_ratio: section.settings.product_card_aspect_ratio,
                placeholder_image: section.settings.placeholder_image,
                animate_enabled: true,
                show_action: section.settings.show_action,
                show_index: section.settings.show_index,
                show_badge: section.settings.show_badge
              %}
            </div>
          {% endfor %}
        </div>
      </fieldset>
    </div>
    <div class='product-grid-type-2__image'>
      {% if section.settings.image_desktop != blank or section.settings.image_mobile != blank %}
        {% if section.settings.image_desktop != blank %}
          <div class='product-grid-type-2__image-desktop'>
            {% render 'image', image: section.settings.image_desktop, placeholder: 'product-1', aspect_ratio: section.settings.aspect_ratio %}
          </div>
        {% elsif section.settings.image_desktop == blank and section.settings.image_mobile != blank %}
          <div class='product-grid-type-2__image-desktop'>
            {% render 'image', image: section.settings.image_mobile, placeholder: 'product-1', aspect_ratio: section.settings.aspect_ratio %}
          </div>
        {% endif %}
        {% if section.settings.image_mobile != blank %}
          <div class='product-grid-type-2__image-mobile'>
            {% render 'image', image: section.settings.image_mobile, placeholder: 'product-1', aspect_ratio: section.settings.aspect_ratio_2 %}
          </div>
        {% elsif section.settings.image_mobile == blank and section.settings.image_desktop != blank %}
          <div class='product-grid-type-2__image-mobile'>
            {% render 'image', image: section.settings.image_desktop, placeholder: 'product-1', aspect_ratio: section.settings.aspect_ratio_2 %}
          </div>
        {% endif %}
      {% else %}
        <div class='product-grid-type-2__image-desktop'>
          {% render 'image', placeholder: 'product-1', aspect_ratio: section.settings.aspect_ratio %}
        </div>
        <div class='product-grid-type-2__image-mobile'>
          {% render 'image', placeholder: 'product-1', aspect_ratio: section.settings.aspect_ratio_2 %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

