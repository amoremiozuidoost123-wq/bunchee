{{ 'section-information.css' | asset_url | stylesheet_tag }}
<section {% render 'section-attr' %}>
  <xo-container class='information'>
    <div class='information__list'>
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'location' %}
            {% comment %} Location {% endcomment %}
            <xo-animate xo-cascade class='information__block'>
              <div class='information__heading h4'>
                {{ block.settings.heading }}
              </div>
              <div class='information__content'>
                <div class='information__location'>{{ block.settings.location_1 }}</div>
                <div class='information__location'>{{ block.settings.location_2 }}</div>
              </div>
            </xo-animate>
          {% when 'time' %}
            {% comment %} Time {% endcomment %}
            <xo-animate xo-cascade class='information__block'>
              <div class='information__heading h4'>
                {{ block.settings.heading }}
              </div>
              <div class='information__content'>
                <div class='information__item'>
                  <div class='information__day'>
                    {{ block.settings.day_1 }}
                  </div>
                  <div class='information__time'>
                    {{ block.settings.time_1 }}
                  </div>
                </div>
                <div class='information__item'>
                  <div class='information__day'>
                    {{ block.settings.day_2 }}
                  </div>
                  <div class='information__time'>
                    {{ block.settings.time_2 }}
                  </div>
                </div>
              </div>
            </xo-animate>
          {% else %}
            {% comment %} Contact {% endcomment %}
            <xo-animate xo-cascade class='information__block'>
              <div class='information__heading h4'>
                {{ block.settings.heading }}
              </div>
              <div class='information__content'>
                <div class='information__email'>{{ block.settings.email }}</div>
                <div class='information__contact'>{{ block.settings.contact }}</div>
              </div>
            </xo-animate>
        {% endcase %}
      {% endfor %}
    </div>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.information.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "t:sections.information.blocks.location.label",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.information.blocks.location.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "location_1",
          "label": "t:sections.information.blocks.location.settings.location_1.label",
          "default": "<p>Location</p>"
        },
        {
          "type": "richtext",
          "id": "location_2",
          "label": "t:sections.information.blocks.location.settings.location_2.label",
          "default": "<p>Location</p>"
        }
      ]
    },
    {
      "type": "time",
      "name": "t:sections.information.blocks.time.label",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.information.blocks.time.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "day_1",
          "label": "t:sections.information.blocks.time.settings.day_1.label",
          "default": "<p>Day</p>"
        },
        {
          "type": "richtext",
          "id": "time_1",
          "label": "t:sections.information.blocks.time.settings.time_1.label",
          "default": "<p>Time</p>"
        },
        {
          "type": "richtext",
          "id": "day_2",
          "label": "t:sections.information.blocks.time.settings.day_2.label",
          "default": "<p>Day</p>"
        },
        {
          "type": "richtext",
          "id": "time_2",
          "label": "t:sections.information.blocks.time.settings.time_2.label",
          "default": "<p>Time</p>"
        }
      ]
    },
    {
      "type": "contact",
      "name": "t:sections.information.blocks.contact.label",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.information.blocks.contact.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "email",
          "label": "t:sections.information.blocks.contact.settings.email.label",
          "default": "<p>Email</p>"
        },
        {
          "type": "richtext",
          "id": "contact",
          "label": "t:sections.information.blocks.contact.settings.contact.label",
          "default": "<p>Contact</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.information.presets.name",
      "blocks": [
        {
          "type": "location"
        },
        {
          "type": "time"
        },
        {
          "type": "contact"
        }
      ]
    }
  ]
}
{% endschema %}