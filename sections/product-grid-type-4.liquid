{{ 'section-product-grid-type-4.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-container>
    <xo-grid class='product-grid-type-4'>
      <div class='product-grid-type-4__container' style='--xs: 12; --xl: 10;--start-xl: 2;'>
        <fieldset class='product-grid-type-4__fieldset'>
          <legend class='product-grid-type-4__heading h1'>{{ section.settings.heading }}</legend>
          <xo-grid class='product-grid-type-4__content' style='--xs: 1;--lg: 3;'>
            {% for block in section.blocks %}
              <div class='product-grid-type-4__item'>
                {% render 'product-grid-card-type-1',
                  product: block.settings.product,
                  show_image: section.settings.product_card_show_image,
                  show_secondary_image: section.settings.product_card_show_secondary_image,
                  show_description: section.settings.product_card_show_description,
                  show_price: section.settings.product_card_show_price,
                  show_badge: section.settings.product_card_show_badge,
                  media_aspect_ratio: section.settings.product_card_aspect_ratio,
                  color_scheme: section.settings.card_color_scheme,
                  show_tag: block.settings.product_card_show_tag,
                  image_1: block.settings.image_1,
                  image_2: block.settings.image_2,
                  tag_text_1: block.settings.tag_text_1,
                  tag_text_2: block.settings.tag_text_2,
                  animate_enabled: true
                %}
              </div>
            {% endfor %}
          </xo-grid>
        </fieldset>
      </div>
    </xo-grid>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.product_grid_type_4.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product_grid_type_4.settings.heading.label",
      "default": "Menu"
    },
    {
      "type": "header",
      "content": "t:sections.all.product_card_heading.content"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_image",
      "default": true,
      "label": "t:sections.all.product_card_show_image.label"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_secondary_image",
      "default": true,
      "label": "t:sections.all.product_card_show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_vendor",
      "default": false,
      "label": "t:sections.all.product_card_show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_description",
      "label": "t:sections.all.product_card_show_description.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "product_card_show_price",
      "label": "t:sections.all.product_card_show_price.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "product_card_show_badge",
      "label": "t:sections.all.product_card_show_badge.label",
      "default": false
    },
    {
      "type": "select",
      "id": "product_card_aspect_ratio",
      "label": "t:sections.all.product_card_aspect_ratio.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.all.product_card_aspect_ratio.option_1.label"
        },
        {
          "value": "2/3",
          "label": "t:sections.all.product_card_aspect_ratio.option_2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.product_card_aspect_ratio.option_3.label"
        },
        {
          "value": "1",
          "label": "t:sections.all.product_card_aspect_ratio.option_4.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.product_card_aspect_ratio.option_5.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.product_card_aspect_ratio.option_6.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.product_card_aspect_ratio.option_7.label"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "t:sections.all.card_color_scheme.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.product_grid_type_4.blocks.item.label",
      "type": "item",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.product_grid_type_4.blocks.item.settings.product.label"
        },
        {
          "type": "checkbox",
          "id": "product_card_show_tag",
          "default": true,
          "label": "t:sections.product_grid_type_4.blocks.item.settings.product_card_show_tag.label"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "t:sections.product_grid_type_4.blocks.item.settings.image_1.label"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "t:sections.product_grid_type_4.blocks.item.settings.image_2.label"
        },
        {
          "type": "text",
          "id": "tag_text_1",
          "label": "t:sections.product_grid_type_4.blocks.item.settings.tag_text_1.label",
          "default": "Tag text"
        },
        {
          "type": "text",
          "id": "tag_text_2",
          "label": "t:sections.product_grid_type_4.blocks.item.settings.tag_text_2.label",
          "default": "Tag text"
        }
      ]
    }
  ]
}
{% endschema %}