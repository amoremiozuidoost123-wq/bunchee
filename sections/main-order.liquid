{% comment %} TODO: Thiếu phần properties cho order  {% endcomment %}
{{ 'section-main-order.css' | asset_url | stylesheet_tag }}
{{ 'order-table.css' | asset_url | stylesheet_tag }}
{{ 'order-bill.css' | asset_url | stylesheet_tag }}

<div {% render 'section-attr' %}>
  <xo-container class='order-detail'>
    <xo-animate xo-cascade>
      {% assign account_return = 'customer.account.return' | t %}
      <h2 class='order-detail__heading'>{{ section.settings.heading }}</h2>
      <div class='order-detail__button'>
        {% render 'button', text: account_return, link: routes.account_url, style: 'link', icon: 'arrow-with-reer-left', icon_size: '16', icon_position: 'left' %}
      </div>
    </xo-animate>

    <xo-grid class='order-detail__grid'>
      <div class='order-detail__order' style='--xs: 12;--lg: 9'>
        {% render 'order-table' %}
      </div>
      <div class='order-detail__detail' style='--xs: 12;--lg: 3'>
        {% render 'order-bill' %}
      </div>
    </xo-grid>
  </xo-container>
</div>

{% schema %}
{
  "name": "t:sections.main_order.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_order.settings.heading.label",
      "default": "Account"
    },
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ]
}
{% endschema %}