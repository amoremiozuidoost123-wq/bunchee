{{ 'section-collapsible-content-type-3.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-container class='collapsible-content-type-3'>
    <xo-grid>
      <div class='collapsible-content-type-3__content' style='--xs: 12; --lg: 12;--xxl: 10;--start-xxl: 2;'>
        <div class='collapsible-content-type-3__top'>
          <div class='collapsible-content-type-3__heading'>
            {% render 'text',
              text: section.settings.text_heading,
              tag_name: section.settings.text_tag_name,
              duration: section.settings.text_duration,
              effect: section.settings.text_effect
            %}
          </div>
          <xo-animate xo-cascade class='collapsible-content-type-3__description'>{{ section.settings.description }}</xo-animate>
        </div>
        <div class='collapsible-content-type-3__bottom'>
          {% for block in section.blocks %}
            {% assign index = forloop.index %}
            {% case block.type %}
              {% when 'address-type-1' %}
                <div class='collapsible-content-type-3__item collapsible-content-type-3__item--type-1'>
                  <div class='collapsible-content-type-3__item-left'>
                    <xo-animate xo-cascade class='collapsible-content-type-3__index'>
                      {{- 'general.address' | t }}
                      {{ index -}}
                    </xo-animate>
                    <div class='collapsible-content-type-3__text'>
                      <xo-animate xo-cascade class='collapsible-content-type-3__address'>
                        <h4>{{ block.settings.address }}</h4>
                      </xo-animate>
                      <xo-animate xo-cascade class='collapsible-content-type-3__info'>
                        <div class='collapsible-content-type-3__item-top collapsible-content-type-3__item-top--end'>
                          <div class='collapsible-content-type-3__icon'>{% render 'icon', name: 'phone', size: '22' %}</div>
                          <div class='collapsible-content-type-3__phone'>{{ block.settings.phone_number }}</div>
                        </div>
                        <div class='collapsible-content-type-3__item-bottom'>
                          {{ block.settings.time }}
                        </div>
                      </xo-animate>
                    </div>
                  </div>
                  <xo-animate xo-cascade class='collapsible-content-type-3__item-right'>
                    <div class='collapsible-content-type-3__item-top collapsible-content-type-3__item-top--end'>
                      <div class='collapsible-content-type-3__icon'>{% render 'icon', name: 'phone', size: '22' %}</div>
                      <div class='collapsible-content-type-3__phone'>{{ block.settings.phone_number }}</div>
                    </div>
                    <div class='collapsible-content-type-3__item-bottom'>
                      {{ block.settings.time }}
                    </div>
                  </xo-animate>
                </div>
                {% comment %} Type 2 {% endcomment %}
              {% when 'address-type-2' %}
                <div class='collapsible-content-type-3__item collapsible-content-type-3__item--type-2'>
                  <xo-animate xo-cascade class='collapsible-content-type-3__item-left'>
                    <div class='collapsible-content-type-3__item-top collapsible-content-type-3__item-top--start'>
                      <div class='collapsible-content-type-3__icon'>{% render 'icon', name: 'phone', size: '22' %}</div>
                      <div class='collapsible-content-type-3__phone'>{{ block.settings.phone_number }}</div>
                    </div>
                    <div class='collapsible-content-type-3__item-bottom'>
                      {{ block.settings.time }}
                    </div>
                  </xo-animate>
                  <div class='collapsible-content-type-3__item-right'>
                    <xo-animate xo-cascade class='collapsible-content-type-3__index'>
                      {{- 'general.address' | t }}
                      {{ index -}}
                    </xo-animate>
                    <div class='collapsible-content-type-3__text'>
                      <xo-animate xo-cascade class='collapsible-content-type-3__address'>
                        <h4>{{ block.settings.address }}</h4>
                      </xo-animate>
                      <xo-animate xo-cascade class='collapsible-content-type-3__info'>
                        <div class='collapsible-content-type-3__item-top collapsible-content-type-3__item-top--end'>
                          <div class='collapsible-content-type-3__icon'>{% render 'icon', name: 'phone', size: '22' %}</div>
                          <div class='collapsible-content-type-3__phone'>{{ block.settings.phone_number }}</div>
                        </div>
                        <div class='collapsible-content-type-3__item-bottom'>
                          {{ block.settings.time }}
                        </div>
                      </xo-animate>
                    </div>
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </xo-grid>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.collapsible_content_type_3.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "t:sections.all.text_tag_name.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.text_tag_name.option__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.text_tag_name.option__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.text_tag_name.option__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.text_tag_name.option__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.text_tag_name.option__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.text_tag_name.option__6.label"
        },
        {
          "value": "d1",
          "label": "t:sections.all.text_tag_name.option__7.label"
        },
        {
          "value": "d2",
          "label": "t:sections.all.text_tag_name.option__8.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "t:sections.all.text_heading.label",
      "default": "Heading"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "t:sections.all.text_duration.label",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "t:sections.all.text_effect.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.text_effect.option__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.text_effect.option__2.label"
        },
        {
          "value": "split",
          "label": "t:sections.all.text_effect.option__3.label"
        }
      ],
      "default": "reveal"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.collapsible_content_type_3.settings.description",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "address-type-1",
      "name": "t:sections.collapsible_content_type_3.blocks.address_type_1.label",
      "settings": [
        {
          "type": "richtext",
          "id": "address",
          "label": "t:sections.collapsible_content_type_3.blocks.address_type_1.settings.address.label",
          "default": "<p>Address</p>",
          "info": "t:sections.collapsible_content_type_3.blocks.address_type_1.settings.address.info"
        },
        {
          "type": "text",
          "id": "phone_number",
          "label": "t:sections.collapsible_content_type_3.blocks.address_type_1.settings.phone_number.label",
          "default": "Phone number"
        },
        {
          "type": "text",
          "id": "time",
          "label": "t:sections.collapsible_content_type_3.blocks.address_type_1.settings.time.label",
          "default": "Open time"
        }
      ]
    },
    {
      "type": "address-type-2",
      "name": "t:sections.collapsible_content_type_3.blocks.address_type_2.label",
      "settings": [
        {
          "type": "richtext",
          "id": "address",
          "label": "t:sections.collapsible_content_type_3.blocks.address_type_2.settings.address.label",
          "default": "<p>Address</p>",
          "info": "t:sections.collapsible_content_type_3.blocks.address_type_2.settings.address.info"
        },
        {
          "type": "text",
          "id": "phone_number",
          "label": "t:sections.collapsible_content_type_3.blocks.address_type_2.settings.phone_number.label",
          "default": "Phone number"
        },
        {
          "type": "text",
          "id": "time",
          "label": "t:sections.collapsible_content_type_3.blocks.address_type_2.settings.time.label",
          "default": "Open time"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible_content_type_3.presets.name",
      "blocks": [
        {
          "type": "address-type-1"
        },
        {
          "type": "address-type-2"
        }
      ]
    }
  ]
}
{% endschema %}