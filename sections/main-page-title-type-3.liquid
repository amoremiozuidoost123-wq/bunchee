{{ 'section-main-page-title-type-3.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-container class='main-page-title-type-3'>
    <xo-animate xo-cascade class='main-page-title-type-3__content'>
      <fieldset class='main-page-title-type-3__fieldset'>
        {% if section.settings.heading != blank %}
          <legend class='main-page-title-type-3__legend'>
            <h1 class='main-page-title-type-3__heading'>
              {{ section.settings.heading }}
            </h1>
          </legend>
        {% endif %}
        <div class='main-page-title-type-3__description'>{{ section.settings.description }}</div>
      </fieldset>
      <div class='main-page-title-type-3__image'>
        {% render 'image', image: section.settings.image %}
      </div>
    </xo-animate>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.main_page_title_type_3.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_page_title_type_3.settings.heading.label",
      "default": "Page heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.main_page_title_type_3.settings.description.label",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "header",
      "content": "t:sections.main_page_title_type_3.settings.header_1.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.main_page_title_type_3.settings.image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_page_title_type_3.presets.name"
    }
  ]
}
{% endschema %}