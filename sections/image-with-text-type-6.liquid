{{ 'section-image-with-text-type-6.css' | asset_url | stylesheet_tag }}

{% liquid
  assign alignment = section.settings.alignment
  assign order_desktop = 0
  assign justify_content = 'flex-end'
  if alignment == 'right'
    assign order_desktop = 2
    assign justify_content = 'flex-start'
  endif
%}

<div {% render 'section-attr' %}>
  <div class='image-with-text-type-6'>
    <xo-container class='image-with-text-type-6__container'>
      <div class='image-with-text-type-6__heading'>
        {% render 'text',
          text: section.settings.text_heading,
          duration: section.settings.text_duration,
          effect: section.settings.text_effect,
          tag_name: section.settings.text_tag_name
        %}
      </div>
      <xo-grid>
        <div
          class='image-with-text-type-6__left'
          style='
            --xs: 12; --md: 4; --lg: 4;--order-xs: 0;--order-lg: {{ order_desktop }};{% if alignment != 'right' %}
              --start-lg: 2;--start-md: 2;
              {% else %}
                --start-lg: 8;--start-md: 8;
            {% endif %} --justify-content: {{ justify_content }}
          '
        >
          <div class='image-with-text-type-6__left-container'>
            <div xo-parallax>
              <xo-parallax-scroll
                class='
                  image-with-text-type-6__decoration {% if alignment == 'right' %}
                    image-with-text-type-6__decoration--right
                  {% endif %}
                '
                xo-keyframes="
                  {
                      '0%': { y: 75 },
                      '35%': { y: 0 },
                      '100%': { y: -75 }
                  }
                "
              >
                {% render 'image', image: section.settings.image_decoration %}
              </xo-parallax-scroll>
              <xo-parallax-scroll
                xo-keyframes="
                  {
                      '0%': { y: 200 },
                      '50%': { y: 0 },
                      '100%': { y: -200 }
                  }
                "
                class='image-with-text-type-6__image'
              >
                {% render 'animate-image', image: section.settings.image, aspect_ratio: section.settings.aspect_ratio, border_radius: 284, max_width: 568 %}
              </xo-parallax-scroll>
              <div
                class='
                  image-with-text-type-6__circle-container{% if alignment == 'right' %}
                    image-with-text-type-6__circle-container--right
                  {% endif %}
                '
              >
                <xo-parallax-scroll
                  xo-keyframes="
                    {
                      '0%': { y: 75 },
                      '50%': { y: 0 },
                      '100%': { y: -75 }
                    }
                  "
                >
                  <div class='image-with-text-type-6__circle'></div>
                </xo-parallax-scroll>
              </div>
            </div>
          </div>
        </div>
        <div
          class='image-with-text-type-6__right'
          style='
            --xs: 12; --md: 6; --lg: 6;--order-lg: 1;{% if alignment == 'right' %}
              --start-lg: 2;--start-md: 2;
            {% endif %}
          '
        >
          {% for block in section.blocks %}
            <xo-animate xo-cascade class='image-with-text-type-6__content'>
              {{ block.settings.paragraph }}
            </xo-animate>
          {% endfor %}
        </div>
      </xo-grid>
    </xo-container>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image_with_text_type_6.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "alignment",
      "label": "t:sections.image_with_text_type_6.settings.alignment.label",
      "options": [
        {
          "value": "left",
          "label": "Left"
