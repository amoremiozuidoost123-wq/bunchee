  "presets": [
    {
      "name": "t:sections.image_with_text_type_6.presets.name",
      "blocks": [
        {
          "type": "content",
          "settings": {}
        },
        {
          "type": "content",
          "settings": {}
        }
      ]
    }
  ]
}
{% endschema %}