{{ 'section-image-with-text-overlay-2.css' | asset_url | stylesheet_tag }}

{% assign background_svg = section.settings.background_svg %}

<div
  class='
    image-with-text-overlay-2{%- if background_svg != 'type-1' %}
    image-with-text-overlay-2--background-none{% endif -%}
  '
>
  <div {% render 'section-attr' %}>
    <div class='image-with-text-overlay-2__svg' style='--color: {{ section.settings.color_background }}'>
      {% if background_svg == 'type-1' %}
        <div class='image-with-text-overlay-2__svg-container'></div>
      {% elsif background_svg == 'type-2' %}
        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1920 258'>
          <path d="M497.129 94.8437C252.266 199.644 63.6833 146.844 0 107.344V0H1920V150.84C1794.89 254.697 1603.54 291.054 1378.97 221.687C1167.92 156.498 1113.79 88.3437 1021.77 46.3437C929.742 4.34373 803.209 -36.1563 497.129 94.8437Z"/>
        </svg>
      {% elsif background_svg == 'type-3' %}
        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1920 283'>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M458.5 211.037C545.322 236.53 633.703 234.278 714.147 209.466C784.343 255.938 868.511 283 959 283C1049.48 283 1133.65 255.941 1203.84 209.475C1284.28 234.288 1372.67 236.541 1459.49 211.048C1546.32 185.552 1619.46 135.868 1673.72 71.4956C1757.9 72.6405 1843.87 48.9226 1920 0H0C75.7584 48.2789 160.646 72.6448 244.289 71.5059C298.547 135.869 371.68 185.545 458.5 211.037Z"/>
        </svg>
      {% elsif background_svg == 'type-4' %}
        <svg viewBox='0 0 1920 251' xmlns='http://www.w3.org/2000/svg'>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M1105.7 0H0V250.7C39.2543 248.806 49.6452 245.278 58.8815 240.45C66.1551 236.664 87.6296 226.724 102.177 221.234C107.757 219.08 112.987 216.832 118.282 214.555L118.493 214.464C120.577 213.568 122.674 212.667 124.806 211.766C129.231 210.768 133.466 209.271 137.39 207.318C144.862 203.806 153.485 200.589 162.066 197.388L162.069 197.387L162.458 197.242C164.618 196.436 166.775 195.63 168.909 194.821C169.356 194.63 169.806 194.44 170.258 194.248C172.493 193.299 174.782 192.327 176.991 191.224C183.141 188.607 189.463 186.268 195.926 184.219C206.431 180.811 216.477 177.213 225.828 173.333L284.017 154.967C305.952 148.057 329.506 141.904 354.443 136.697C368.298 133.857 382.961 131.396 398.201 129.692C426.949 126.568 456.159 124.011 485.6 122.025C491.949 121.646 498.299 121.456 504.65 121.456C518.273 121.74 531.897 121.456 545.405 120.509H550.715C567.11 120.509 583.504 120.131 599.784 119.562C614.975 119.266 630.128 118.191 645.156 116.343C649.429 115.871 653.585 115.114 657.51 114.261C671.942 111.137 685.797 107.635 699.074 103.754C703.563 102.296 708.28 100.964 712.917 99.6539L712.971 99.6388L713.402 99.5171C714.326 99.2562 715.247 98.9962 716.161 98.7357C731.39 94.2759 746.41 89.3503 761.188 83.9677C771.478 80.0622 782.084 76.349 792.745 72.6168L792.759 72.6117C795.011 71.8233 797.265 71.0341 799.519 70.2421C805.754 68.0649 811.642 65.6975 817.068 63.2368C843.183 51.0434 870.258 40.2903 898.116 31.0503C912.549 26.2223 928.481 21.9624 945.569 18.4597C963.792 14.7457 982.208 11.1894 1000.55 7.64668L1000.59 7.63931L1005.84 6.62653C1016 4.73322 1026.85 3.31327 1037.93 2.55592C1060.21 0.851973 1082.96 0 1105.7 0ZM1920 250.59V0H1105.7C1112.05 0 1118.4 0.189367 1124.64 0.567982C1130.56 1.00962 1136.59 1.28306 1142.62 1.55648L1142.81 1.56495C1145.75 1.69894 1148.71 1.83333 1151.65 1.98794C1163.31 2.65066 1174.74 3.88125 1185.48 5.77456L1202.8 8.70921C1229.16 12.7634 1254.66 19.905 1278.54 29.9143L1309.48 43.452C1318.72 47.6173 1327.49 51.9717 1335.57 56.4205C1337.67 57.6132 1339.94 58.76 1342.19 59.8928C1343.15 60.378 1344.1 60.8606 1345.04 61.3432L1373.44 74.8799C1395.38 85.4827 1418.12 95.7065 1442.14 105.741C1443.22 106.195 1444.3 106.651 1445.38 107.109L1445.54 107.174C1453.92 110.705 1462.48 114.313 1472.04 117.479C1493.16 125.053 1515.91 131.774 1539.93 137.928C1548.24 139.915 1556.32 142.187 1563.93 144.555C1581.26 150.329 1600.88 154.967 1622.13 158.47C1629.02 159.545 1635.79 160.774 1642.54 161.998L1642.69 162.025C1647.77 162.948 1652.84 163.868 1657.93 164.718C1706.26 169.482 1739.72 187.863 1773.48 206.403L1773.49 206.407L1773.5 206.411C1813.51 228.39 1853.93 250.59 1920 250.59Z"/>
        </svg>
      {% endif %}
    </div>
    <div class='image-with-text-overlay-2__container'>
      {% if section.settings.video != blank and section.settings.video_url == blank %}
        {% for video_source in section.settings.video.sources offset: 1 %}
          <div class='image-with-text-overlay-2__video'>
            <xo-video-cover xo-src='{{ video_source.url }}'></xo-video-cover>
          </div>
        {% endfor %}
      {% elsif section.settings.video_url != blank %}
        <div class='image-with-text-overlay-2__video'>
          <xo-video-cover xo-src='{{ section.settings.video_url }}'></xo-video-cover>
        </div>
      {% elsif section.settings.video == blank and section.settings.video_url == blank %}
        <div class='image-with-text-overlay-2__image'>
          {% render 'image' %}
        </div>
      {% endif %}
      <xo-container class='image-with-text-overlay-2__content'>
        <div>
          <xo-animate xo-cascade>
            <h2 class='image-with-text-overlay-2__heading h1'>
              {{ section.settings.heading }}
            </h2>
          </xo-animate>
          <xo-animate xo-cascade class='image-with-text-overlay-2__button'>
            {% render 'button',
              text: section.settings.button_text,
              link: section.settings.button_link,
              style: section.settings.button_style,
              size: section.settings.button_size,
              icon: 'arrow-testimonial-right',
              icon_position: 'right',
              icon_size: '24'
            %}
          </xo-animate>
        </div>
      </xo-container>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image_with_text_overlay_2.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "background_svg",
      "label": "t:sections.image_with_text_overlay_2.settings.background_svg.label",
      "options": [
        {
          "value": "type-1",
          "label": "t:sections.image_with_text_overlay_2.settings.background_svg.option_1.label"
        },
        {
          "value": "type-2",
          "label": "t:sections.image_with_text_overlay_2.settings.background_svg.option_2.label"
        },
        {
          "value": "type-3",
          "label": "t:sections.image_with_text_overlay_2.settings.background_svg.option_3.label"
        },
        {
          "value": "type-4",
          "label": "t:sections.image_with_text_overlay_2.settings.background_svg.option_4.label"
        }
      ],
      "default": "type-1"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "t:sections.image_with_text_overlay_2.settings.color_background.label",
      "info": "t:sections.image_with_text_overlay_2.settings.color_background.info",
      "default": "#FFFFFF"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:sections.image_with_text_overlay_2.settings.heading.label",
      "default": "<p>Heading</p>"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text_overlay_2.settings.header_button.content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.all.button_text.label",
      "default": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button_link.label",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.all.button_style.label",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button_style.option__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button_style.option__2.label"
        }
      ],
      "default": "primary"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "t:sections.all.button_size.label",
      "options": [
        {
          "value": "xs",
          "label": "t:sections.all.button_size.option__0.label"
        },
        {
          "value": "sm",
          "label": "t:sections.all.button_size.option__1.label"
        },
        {
          "value": "md",
          "label": "t:sections.all.button_size.option__2.label"
        },
        {
          "value": "lg",
          "label": "t:sections.all.button_size.option__3.label"
        },
        {
          "value": "xlg",
          "label": "t:sections.all.button_size.option__4.label"
        }
      ],
      "default": "md"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text_overlay_2.settings.header_video.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.image_with_text_overlay_2.settings.video.label"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "t:sections.image_with_text_overlay_2.settings.video_url.label",
      "accept": [
        "youtube",
        "vimeo"
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:sections.image_with_text_overlay_2.presets.name"
    }
  ]
}
{% endschema %}