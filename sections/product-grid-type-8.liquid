{{ 'section-product-grid-type-8.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <div class='product-grid-type-8'>
    <div class='product-grid-type-8__left'>
      {% if section.settings.image_desktop != blank or section.settings.image_mobile != blank %}
        {% if section.settings.image_desktop != blank %}
          <div class='product-grid-type-8__left-desktop'>
            {% render 'image', image: section.settings.image_desktop, placeholder: 'product-1' %}
          </div>
        {% elsif section.settings.image_desktop == blank and section.settings.image_mobile != blank %}
          <div class='product-grid-type-8__left-desktop'>
            {% render 'image', image: section.settings.image_mobile, placeholder: 'product-1' %}
          </div>
        {% endif %}
        {% if section.settings.image_mobile != blank %}
          <div class='product-grid-type-8__left-mobile'>
            {% render 'image', image: section.settings.image_mobile, placeholder: 'product-1' %}
          </div>
        {% elsif section.settings.image_mobile == blank and section.settings.image_desktop != blank %}
          <div class='product-grid-type-8__left-mobile'>
            {% render 'image', image: section.settings.image_desktop, placeholder: 'product-1' %}
          </div>
        {% endif %}
      {% else %}
        <div class='product-grid-type-8__left-desktop'>
          {% render 'image', placeholder: 'product-1' %}
        </div>
        <div class='product-grid-type-8__left-mobile'>
          {% render 'image', placeholder: 'product-1' %}
        </div>
      {% endif %}
    </div>
    <div class='product-grid-type-8__right'>
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'menu-card-type-1' %}
            <xo-tabs class='menu-card-type-1'>
              {% if block.settings.heading %}
                <h3 class='menu-card-type-1__heading'>{{ block.settings.heading }}</h3>
              {% endif %}
              <xo-grid class='menu-card-type-1__container'>
                <div class='menu-card-type-1__left' style='--xs: 12;--lg: 5;'>
                  <xo-tabs-trigger xo-name='{{ block.id }}-1' xo-active>
                    {%- render 'product-grid-card-type-3',
                      product: block.settings.product_1,
                      color_scheme: block.settings.card_color_scheme,
                      animate_enabled: true,
                      product_handle: true,
                      show_tag: block.settings.first_product_product_card_show_tag,
                      image_1: block.settings.first_product_image_1,
                      image_2: block.settings.first_product_image_2,
                      tag_text_1: block.settings.first_product_tag_text_1,
                      tag_text_2: block.settings.first_product_tag_text_2
                    -%}
                  </xo-tabs-trigger>
                  <xo-tabs-trigger xo-name='{{ block.id }}-2'>
                    {%- render 'product-grid-card-type-3',
                      product: block.settings.product_2,
                      color_scheme: block.settings.card_color_scheme,
                      animate_enabled: true,
                      product_handle: true,
                      show_tag: block.settings.second_product_card_show_tag,
                      image_1: block.settings.second_product_image_1,
                      image_2: block.settings.second_product_image_2,
                      tag_text_1: block.settings.second_product_tag_text_1,
                      tag_text_2: block.settings.second_product_tag_text_2
                    -%}
                  </xo-tabs-trigger>
                </div>
                <xo-tabs-content class='menu-card-type-1__right' style='--xs: 12;--lg: 5;'>
                  <xo-tabs-pane xo-name='{{ block.id }}-1' xo-active>
                    <xo-animate xo-cascade class='product-grid-type-8__image'>
                      <div class='product-grid-type-8__decor'>
                        {%- render 'image', image: block.settings.decor, placeholder: 'product-1' -%}
                      </div>
                      {%- render 'image', image: block.settings.product_1.featured_image, placeholder: 'product-1' -%}
                      <div class='menu-card-type-1__circle'></div>
                    </xo-animate>
                  </xo-tabs-pane>
                  <xo-tabs-pane xo-name='{{ block.id }}-2'>
                    <xo-animate xo-cascade class='product-grid-type-8__image'>
                      <div class='product-grid-type-8__decor'>
                        {%- render 'image', image: block.settings.decor, placeholder: 'product-1' -%}
                      </div>
                      {%- render 'image', image: block.settings.product_2.featured_image, placeholder: 'product-1' -%}
                      <div class='menu-card-type-1__circle'></div>
                    </xo-animate>
                  </xo-tabs-pane>
                </xo-tabs-content>
              </xo-grid>
            </xo-tabs>

          {% when 'menu-card-type-2' %}
            <div class='menu-card-type-2'>
              <div class='menu-card-type-2__left'>
                {% if block.settings.product.featured_image %}
                  {% render 'image', image: block.settings.product.featured_image %}
                {% else %}
                  {% render 'image', image: false, placeholder: 'product-2' %}
                {% endif %}
              </div>
              <div class='menu-card-type-2__right {% if block.settings.card_color_scheme %} color-{{ block.settings.card_color_scheme }}{% endif %}'>
                {%- render 'product-grid-card-type-4',
                  product: block.settings.product,
                  show_description: block.settings.product_card_show_description,
                  show_price: block.settings.product_card_show_price,
                  media_aspect_ratio: block.settings.product_card_aspect_ratio,
                  color_scheme: block.settings.card_color_scheme,
                  animate_enabled: true,
                  product_handle: true,
                  show_tag: block.settings.product_card_show_tag,
                  image_1: block.settings.image_1,
                  image_2: block.settings.image_2,
                  tag_text_1: block.settings.tag_text_1,
                  tag_text_2: block.settings.tag_text_2
                -%}
              </div>
            </div>
          {% when 'menu-card-type-3' %}
            <div class='menu-card-type-3'>
              {% if block.settings.heading %}
                <h3 class='menu-card-type-3__heading'>{{ block.settings.heading }}</h3>
              {% endif %}
              {% comment %} Desktop {% endcomment %}
              <div class='menu-card-type-3__desktop'>
                <xo-grid style='--xs: 1;--lg: 3;'>
                  <div class='menu-card-type-3__item'>
                    {%- render 'product-grid-card-type-4',
                      product: block.settings.product_1,
                      show_description: block.settings.product_card_show_description,
                      show_price: block.settings.product_card_show_price,
                      media_aspect_ratio: block.settings.product_card_aspect_ratio,
                      color_scheme: block.settings.card_color_scheme,
                      animate_enabled: true,
                      product_handle: true,
                      show_tag: block.settings.first_product_card_show_tag,
                      image_1: block.settings.first_product_image_1,
                      image_2: block.settings.first_product_image_2,
                      tag_text_1: block.settings.first_product_tag_text_1,
                      tag_text_2: block.settings.first_product_tag_text_2
                    -%}
                  </div>
                  <div class='menu-card-type-3__item'>
                    {%- render 'product-grid-card-type-4',
                      product: block.settings.product_2,
                      show_description: block.settings.product_card_show_description,
                      show_price: block.settings.product_card_show_price,
                      media_aspect_ratio: block.settings.product_card_aspect_ratio,
                      color_scheme: block.settings.card_color_scheme,
                      animate_enabled: true,
                      product_handle: true,
                      show_tag: block.settings.second_product_card_show_tag,
                      image_1: block.settings.second_product_image_1,
                      image_2: block.settings.second_product_image_2,
                      tag_text_1: block.settings.second_product_tag_text_1,
                      tag_text_2: block.settings.second_product_tag_text_2
                    -%}
                  </div>
                  <div class='menu-card-type-3__item'>
                    {%- render 'product-grid-card-type-4',
                      product: block.settings.product_3,
                      show_description: block.settings.product_card_show_description,
                      show_price: block.settings.product_card_show_price,
                      media_aspect_ratio: block.settings.product_card_aspect_ratio,
                      color_scheme: block.settings.card_color_scheme,
                      animate_enabled: true,
                      product_handle: true,
                      show_tag: block.settings.third_product_card_show_tag,
                      image_1: block.settings.third_product_image_1,
                      image_2: block.settings.third_product_image_2,
                      tag_text_1: block.settings.third_product_tag_text_1,
                      tag_text_2: block.settings.third_product_tag_text_2
                    -%}
                  </div>
                </xo-grid>
              </div>

              {% comment %} Mobile {% endcomment %}
              <div class='menu-card-type-3__mobile'>
                <div class='menu-card-type-3__item-mobile'>
                  {%- render 'product-grid-card-type-5',
                    product: block.settings.product_1,
                    color_scheme: block.settings.card_color_scheme,
                    animate_enabled: true,
                    product_handle: true,
                    show_tag: block.settings.first_product_card_show_tag,
                    image_1: block.settings.first_product_image_1,
                    image_2: block.settings.first_product_image_2,
                    tag_text_1: block.settings.first_product_tag_text_1,
                    tag_text_2: block.settings.first_product_tag_text_2
                  -%}
                </div>
                <div class='menu-card-type-3__item-mobile'>
                  {%- render 'product-grid-card-type-5',
                    product: block.settings.product_2,
                    color_scheme: block.settings.card_color_scheme,
                    animate_enabled: true,
                    product_handle: true,
                    show_tag: block.settings.second_product_card_show_tag,
                    image_1: block.settings.second_product_image_1,
                    image_2: block.settings.second_product_image_2,
                    tag_text_1: block.settings.second_product_tag_text_1,
                    tag_text_2: block.settings.second_product_tag_text_2
                  -%}
                </div>
                <div class='menu-card-type-3__item-mobile'>
                  {%- render 'product-grid-card-type-5',
                    product: block.settings.product_3,
                    color_scheme: block.settings.card_color_scheme,
                    animate_enabled: true,
                    product_handle: true,
                    show_tag: block.settings.third_product_card_show_tag,
                    image_1: block.settings.third_product_image_1,
                    image_2: block.settings.third_product_image_2,
                    tag_text_1: block.settings.third_product_tag_text_1,
                    tag_text_2: block.settings.third_product_tag_text_2
                  -%}
                </div>
              </div>
            </div>
          {% else %}

        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% comment %}
  {% for block in section.blocks %}
    <xo-animate xo-cascade class='product-grid-type-8__item'>

    </xo-animate>
  {% endfor %}
{% endcomment %}

