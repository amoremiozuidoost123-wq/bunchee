          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "top_mb",
          "label": "t:sections.featured_collection_type_2.blocks.hotspot.settings.top_mb.label",
          "default": 40,
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "%"
        },
        {
          "type": "range",
          "id": "left_mb",
          "label": "t:sections.featured_collection_type_2.blocks.hotspot.settings.left_mb.label",
          "default": 10,
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "%"
        },
        {
          "type": "product",
          "id": "hotspot_product",
          "label": "t:sections.featured_collection_type_2.blocks.hotspot.settings.hotspot_product.label"
        },
        {
          "type": "color_scheme",
          "id": "card_color_scheme",
          "label": "t:sections.featured_collection_type_2.blocks.hotspot.settings.card_color_scheme.label"
        },
        {
          "type": "color",
          "id": "color_trigger",
          "label": "t:sections.featured_collection_type_2.blocks.hotspot.settings.color_trigger.label",
          "default": "#C33130"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection_type_2.presets.name",
      "blocks": [
        {
          "type": "hotspot"
        },
        {
          "type": "text-item"
        },
        {
          "type": "image-item"
        }
      ]
    }
  ]
}
{% endschema %}