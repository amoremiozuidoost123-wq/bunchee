{{ 'section-featured-collection-type-3.css' | asset_url | stylesheet_tag }}

{% assign background_desktop_left = section.settings.image_desktop_left %}
{% assign background_desktop_right = section.settings.image_desktop_right %}
{% assign background_mobile_left = section.settings.image_mobile_left %}
{% assign background_mobile_right = section.settings.image_mobile_right %}
<section {% render 'section-attr' %}>
  <xo-container class='featured-collection-type-3'>
    <div class='featured-collection-type-3__heading'>
      {% render 'text',
        text: section.settings.text_heading,
        tag_name: section.settings.text_tag_name,
        duration: section.settings.text_duration,
        effect: section.settings.text_effect
      %}
    </div>
    <xo-grid class='featured-collection-type-3__grid' xo-popover-boundary>
      <div class='featured-collection-type-3__item' style='--xs: 12; --md: 12; --lg: 6'>
        <xo-animate xo-cascade xo-type='zoom-in' class='featured-collection-type-3__image featured-collection-type-3__image--left'>
          {% if background_desktop_left != blank or background_mobile_left != blank %}
            {% if background_desktop_left != blank %}
              <div class='featured-collection-type-3__desktop featured-collection-type-3__desktop--left'>
                {% render 'image', image: background_desktop_left, lazyload: false, aspect_ratio: section.settings.aspect_ratio_desktop %}
              </div>
            {% elsif background_mobile_left != blank and background_desktop_left == blank %}
              <div class='featured-collection-type-3__desktop featured-collection-type-3__desktop--left'>
                {% render 'image', image: background_mobile_left, lazyload: false, aspect_ratio: section.settings.aspect_ratio_desktop %}
              </div>
            {% endif %}
            {% if background_mobile_left != blank %}
              <div class='featured-collection-type-3__mobile featured-collection-type-3__mobile--left'>
                {% render 'image', image: background_mobile_left, lazyload: false, aspect_ratio: section.settings.aspect_ratio_mobile_left %}
              </div>
            {% elsif background_desktop_left != blank and background_mobile_left == blank %}
              <div class='featured-collection-type-3__mobile featured-collection-type-3__mobile--left'>
                {% render 'image', image: background_desktop_left, lazyload: false, aspect_ratio: section.settings.aspect_ratio_mobile_left %}
              </div>
            {% endif %}
          {% else %}
            <div class='featured-collection-type-3__desktop featured-collection-type-3__desktop--left'>
              {% render 'image', lazyload: false, aspect_ratio: section.settings.aspect_ratio_desktop %}
            </div>
            <div class='featured-collection-type-3__mobile featured-collection-type-3__mobile--left'>
              {% render 'image', lazyload: false, aspect_ratio: section.settings.aspect_ratio_mobile_left %}
            </div>
          {% endif %}
        </xo-animate>
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'left-image-hotspot' %}
              <div
                class='featured-collection-type-3__point'
                style='--top: {{ block.settings.top }}; --left: {{ block.settings.left }}; --top-mb: {{ block.settings.top_mb}}; --left-mb: {{ block.settings.left_mb }}'
              >
                <xo-animate xo-cascade>
                  {% render 'featured-collection-product-card',
                    product: block.settings.hotspot_product,
                    block_id: block.id,
                    color_scheme: section.settings.card_color_scheme,
                    color_trigger: section.settings.color_trigger
                  %}
                </xo-animate>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
      <div class='featured-collection-type-3__item' style='--xs: 12; --md: 12; --lg: 6'>
        <xo-animate xo-cascade xo-type='zoom-in' class='featured-collection-type-3__image featured-collection-type-3__image--right'>
          {% if background_desktop_right != blank or background_mobile_right != blank %}
            {% if background_desktop_right != blank %}
              <div class='featured-collection-type-3__desktop'>
                {% render 'animate-image', image: background_desktop_right, border_radius: 293, max_width: 866, aspect_ratio: section.settings.aspect_ratio_desktop %}
              </div>
            {% elsif background_mobile_right != blank and background_desktop_right == blank %}
              <div class='featured-collection-type-3__desktop'>
                {% render 'animate-image', image: background_mobile_right, border_radius: 293, max_width: 866, aspect_ratio: section.settings.aspect_ratio_desktop %}
              </div>
            {% endif %}
            {% if background_mobile_right != blank %}
              <div class='featured-collection-type-3__mobile'>
                {% render 'animate-image', image: background_mobile_right, border_radius: 113, max_width: 333, aspect_ratio: section.settings.aspect_ratio_mobile_right %}
              </div>
            {% elsif background_desktop_right != blank and background_mobile_right == blank %}
              <div class='featured-collection-type-3__mobile'>
                {% render 'animate-image', image: background_desktop_right, border_radius: 113, max_width: 333, aspect_ratio: section.settings.aspect_ratio_mobile_right %}
              </div>
            {% endif %}
          {% else %}
            <div class='featured-collection-type-3__desktop'>
              {% render 'animate-image', border_radius: 293, max_width: 866, aspect_ratio: section.settings.aspect_ratio_desktop %}
            </div>
            <div class='featured-collection-type-3__mobile'>
              {% render 'animate-image', border_radius: 113, max_width: 333, aspect_ratio: section.settings.aspect_ratio_mobile_right %}
            </div>
          {% endif %}
        </xo-animate>
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'right-image-hotspot' %}
              <div
                class='featured-collection-type-3__point'
                style='--top: {{ block.settings.top }}; --left: {{ block.settings.left }}; --top-mb: {{ block.settings.top_mb}}; --left-mb: {{ block.settings.left_mb }}'
              >
                <xo-animate xo-cascade>
                  {% render 'featured-collection-product-card',
                    product: block.settings.hotspot_product,
                    block_id: block.id,
                    color_scheme: section.settings.card_color_scheme,
                    color_trigger: section.settings.color_trigger
                  %}
                </xo-animate>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </xo-grid>
  </xo-container>
</section>

