{{ 'section-image-with-text-overlay.css' | asset_url | stylesheet_tag }}

{% liquid
  assign decor = section.settings.decor
%}

<section {% render 'section-attr' %}>
  <div class='image-with-text-overlay'>
    <div class='image-with-text-overlay__bg'>
      {% if section.settings.image_desktop != blank or section.settings.image_mobile != blank %}
        {% if section.settings.image_desktop != blank %}
          <div class='image-with-text-overlay__desktop'>
            {% render 'image', image: section.settings.image_desktop, lazyload: false, placeholder: 'hero-apparel-1' %}
          </div>
        {% elsif section.settings.image_mobile != blank and section.settings.image_desktop == blank %}
          <div class='image-with-text-overlay__desktop'>
            {% render 'image', image: section.settings.image_mobile, lazyload: false, placeholder: 'hero-apparel-1' %}
          </div>
        {% endif %}
        {% if section.settings.image_mobile != blank %}
          <div class='image-with-text-overlay__mobile'>
            {% render 'image', image: section.settings.image_mobile, lazyload: false, placeholder: 'hero-apparel-1' %}
          </div>
        {% elsif section.settings.image_desktop != blank and section.settings.image_mobile == blank %}
          <div class='image-with-text-overlay__mobile'>
            {% render 'image', image: section.settings.image_desktop, lazyload: false, placeholder: 'hero-apparel-1' %}
          </div>
        {% endif %}
      {% else %}
        <div class='image-with-text-overlay__desktop'>
          {% render 'image', lazyload: false, placeholder: 'hero-apparel-1' %}
        </div>
        <div class='image-with-text-overlay__mobile'>
          {% render 'image', lazyload: false, placeholder: 'hero-apparel-1' %}
        </div>
      {% endif %}
    </div>
    <div class='image-with-text-overlay__container'>
      <xo-container style='--justify-content: {{ section.settings.align }}'>
        <div class='image-with-text-overlay__box'>
          <div class='image-with-text-overlay__content'>
            {% if section.settings.text_heading %}
              <div>
                {% render 'text',
                  text: section.settings.text_heading,
                  tag_name: section.settings.text_tag_name,
                  duration: section.settings.text_duration,
                  effect: section.settings.text_effect
                %}
              </div>
            {% endif %}
            {% if section.settings.paragraph_1 %}
              <xo-animate xo-cascade xo-constant='25' class='image-with-text-overlay__text  image-with-text-overlay__text--top'>{{ section.settings.paragraph_1 }}</xo-animate>
            {% endif %}
            {% if section.settings.paragraph_2 %}
              <xo-animate xo-cascade xo-constant='30' class='image-with-text-overlay__text image-with-text-overlay__text--bottom'>{{ section.settings.paragraph_2 }}</xo-animate>
            {% endif %}
            {% if section.settings.button_text %}
              {% render 'button',
                text: section.settings.button_text,
                link: section.settings.button_link,
                style: section.settings.button_style,
                size: section.settings.button_size
              %}
            {% endif %}
          </div>
          {% if decor != blank %}
            <xo-animate xo-cascade class="image-with-text-overlay__decor">{% render 'image', image: decor %}</xo-animate>
          {% endif %}
        </div>
      </xo-container>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.image_with_text_overlay.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "decor",
      "label": "t:sections.image_with_text_overlay.settings.decor.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.header.content"
    },
    {
      "type": "select",
      "id": "text_tag_name",
      "label": "t:sections.all.text_tag_name.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.text_tag_name.option__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.text_tag_name.option__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.text_tag_name.option__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.text_tag_name.option__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.text_tag_name.option__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.text_tag_name.option__6.label"
        },
        {
          "value": "d1",
          "label": "t:sections.all.text_tag_name.option__7.label"
        },
        {
          "value": "d2",
          "label": "t:sections.all.text_tag_name.option__8.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "textarea",
      "id": "text_heading",
      "label": "t:sections.all.text_heading.label",
      "default": "Heading"
    },
    {
      "type": "number",
      "id": "text_duration",
      "label": "t:sections.all.text_duration.label",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "t:sections.all.text_effect.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.text_effect.option__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.text_effect.option__2.label"
        },
        {
          "value": "split",
          "label": "t:sections.all.text_effect.option__3.label"
        }
      ],
      "default": "reveal"
    },
    {
      "type": "richtext",
      "id": "paragraph_1",
      "label": "t:sections.image_with_text_overlay.settings.paragraph_1.label",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "richtext",
      "id": "paragraph_2",
      "label": "t:sections.image_with_text_overlay.settings.paragraph_2.label",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "select",
      "id": "align",
      "label": "t:sections.image_with_text_overlay.settings.align.label",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text_overlay.settings.header_button.content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.all.button_text.label",
      "default": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button_link.label",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.all.button_style.label",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button_style.option__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button_style.option__2.label"
        }
      ],
      "default": "primary"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "t:sections.all.button_size.label",
      "options": [
        {
          "value": "xs",
          "label": "t:sections.all.button_size.option__0.label"
        },
        {
          "value": "sm",
          "label": "t:sections.all.button_size.option__1.label"
        },
        {
          "value": "md",
          "label": "t:sections.all.button_size.option__2.label"
        },
        {
          "value": "lg",
          "label": "t:sections.all.button_size.option__3.label"
        },
        {
          "value": "xlg",
          "label": "t:sections.all.button_size.option__4.label"
        }
      ],
      "default": "md"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text_overlay.settings.header_image.content"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:sections.image_with_text_overlay.settings.image_desktop.label"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.image_with_text_overlay.settings.image_mobile.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "t:sections.image_with_text_overlay.presets.name"
    }
  ]
}
{% endschema %}