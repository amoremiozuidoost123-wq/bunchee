{{ 'section-product-grid-type-5.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <div class='product-grid-type-5'>
    <div class='product-grid-type-5__left {% if section.settings.color_left_scheme %} color-{{ section.settings.color_left_scheme }}{% endif %}'>
      <fieldset class='product-grid-type-5__fieldset'>
        <legend class='product-grid-type-5__heading h3'>{{ section.settings.heading }}</legend>
        <div class='product-grid-type-5__content'>
          {% for block in section.blocks %}
            {% assign product_index = forloop.index %}
            <div class='product-grid-type-5__item'>
              {% render 'product-grid-card-type-2',
                product: block.settings.product,
                product_index: product_index,
                show_tag: block.settings.product_card_show_tag,
                image_1: block.settings.image_1,
                image_2: block.settings.image_2,
                tag_text_1: block.settings.tag_text_1,
                tag_text_2: block.settings.tag_text_2,
                media_aspect_ratio: section.settings.product_card_aspect_ratio,
                color_scheme: section.settings.card_color_scheme,
                placeholder_image: section.settings.placeholder_image,
                animate_enabled: true
              %}
            </div>
          {% endfor %}
        </div>
      </fieldset>
    </div>
    <div class='product-grid-type-5__image' style='--background: {{ section.settings.background }}'>
      {% if section.settings.image_desktop != blank or section.settings.image_mobile != blank %}
        {% if section.settings.image_desktop != blank %}
          <div class='product-grid-type-5__image-desktop'>
            {% render 'image', image: section.settings.image_desktop, placeholder: 'product-1' %}
          </div>
        {% elsif section.settings.image_desktop == blank and section.settings.image_mobile != blank %}
          <div class='product-grid-type-5__image-desktop'>
            {% render 'image', image: section.settings.image_mobile, placeholder: 'product-1' %}
          </div>
        {% endif %}
        {% if section.settings.image_mobile != blank %}
          <div class='product-grid-type-5__image-mobile'>
            {% render 'image', image: section.settings.image_mobile, placeholder: 'product-1' %}
          </div>
        {% elsif section.settings.image_mobile == blank and section.settings.image_desktop != blank %}
          <div class='product-grid-type-5__image-mobile'>
            {% render 'image', image: section.settings.image_desktop, placeholder: 'product-1' %}
          </div>
        {% endif %}
      {% else %}
        <div class='product-grid-type-5__image-desktop'>
          {% render 'image', placeholder: 'product-1' %}
        </div>
        <div class='product-grid-type-5__image-mobile'>
          {% render 'image', placeholder: 'product-1' %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.product_grid_type_5.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product_grid_type_5.settings.heading.label",
      "default": "Menu"
    },
    {
      "type": "color_scheme",
      "id": "color_left_scheme",
      "label": "t:sections.product_grid_type_5.settings.color_left_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.product_grid_type_5.settings.header_1.label"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:sections.product_grid_type_5.settings.image_desktop.label"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.product_grid_type_5.settings.image_mobile.label"
    },
    {
      "type": "color_background",
      "id": "background",
      "label": "t:sections.product_grid_type_5.settings.background.label",
      "default": "linear-gradient(0deg, #A30003 10%, rgba(163, 0, 3, 0.00) 75%)"
    },
    {
      "type": "header",
      "content": "t:sections.all.product_card_heading.content"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "t:sections.all.card_color_scheme.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.product_grid_type_5.blocks.item.label",
      "type": "item",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.product_grid_type_5.blocks.item.settings.product.label"
        },
        {
          "type": "checkbox",
          "id": "product_card_show_tag",
          "default": true,
          "label": "t:sections.product_grid_type_5.blocks.item.settings.product_card_show_tag.label"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "t:sections.product_grid_type_5.blocks.item.settings.image_1.label"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "t:sections.product_grid_type_5.blocks.item.settings.image_2.label"
        },
        {
          "type": "text",
          "id": "tag_text_1",
          "label": "t:sections.product_grid_type_5.blocks.item.settings.tag_text_1.label",
          "default": "Tag text"
        },
        {
          "type": "text",
          "id": "tag_text_2",
          "label": "t:sections.product_grid_type_5.blocks.item.settings.tag_text_2.label",
          "default": "Tag text"
        }
      ]
    }
  ]
}
{% endschema %}