<header class='xo-header'>
  {% for block in section.blocks %}
    <div class='color-{{ block.settings.color_scheme }}'>
      {% render 'annoucement-bar',
        block_style: block.settings.block_style,
        annoucement_bar_discount: block.settings.annoucement_bar_discount,
        annoucement_bar_phone_number: block.settings.annoucement_bar_phone_number,
        icon_1: block.settings.icon_1,
        icon_2: block.settings.icon_2,
        color_scheme: block.settings.color_scheme
      %}
    </div>
  {% endfor %}
  <xo-sticky
    xo-direction='{{ section.settings.sticky_header_type }}'
    {% if section.settings.sticky_header_type == 'none' %}
      xo-disabled
    {% endif %}
    style='z-index: 10000'
  >
    <div class='xo-header__sticky{% if section.settings.enabled_border == false %}
      xo-header--border-none
    {% endif %}'>
      <xo-container>
        {% if section.settings.header_type == 'type-1' %}
          {% comment %} Header type 1 {% endcomment %}
          {% comment %} Desktop {% endcomment %}
          <div class='xo-header__content xo-header__content--desktop {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %} {% if section.settings.menu != blank %} xo-header__content--menu {% endif %}'>
            <div class='xo-header__left {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
              <a href='{{ routes.root_url }}'>
                {%- if section.settings.logo != blank -%}
                  {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
                  {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio -%}
                  {% capture widths %}{{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}{% endcapture %}
                  {{
                    section.settings.logo
                    | image_url: width: section.settings.width
                    | image_tag:
                      class: 'xo-header__logo-img',
                      widths: widths,
                      height: logo_height,
                      width: section.settings.logo_width,
                      alt: logo_alt
                  }}
                {%- else -%}
                  <span class='xo-header__logo-heading-logo'>{{ shop.name }}</span>
                {%- endif -%}
              </a>
            </div>
            <nav
              class='xo-header__center {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %} {% if section.settings.menu != blank %} xo-header__center--menu {% endif %}'
            >
              <menu-horizontal class='xo-header__desktop'>
                {% render 'menu-horizontal', menu: section.settings.menu %}
              </menu-horizontal>
            </nav>
            <div class='xo-header__right {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
              {% if section.settings.enable_language_selector or section.settings.enable_currency_selector %}
                <div class='xo-header__right-region'>
                  {%- if section.settings.enable_language_selector -%}
                    {% render 'language-select', placement: 'bottom-center' %}
                  {%- endif -%}
                  {%- if section.settings.enable_currency_selector -%}
                    {% render 'currency-select', placement: 'bottom-center' %}
                  {%- endif -%}
                </div>
              {% endif %}
              <xo-tooltip xo-title='{{ 'general.search.search_placeholder' | t }}'>
                <xo-modal-trigger
                  class='xo-header__right-item'
                  xo-name='search'
                  role='button'
                  tabindex='0'
                  aria-label='search'
                >
                  {% render 'icon', name: 'search', size: '18' %}
                </xo-modal-trigger>
              </xo-tooltip>
              {%- if shop.customer_accounts_enabled -%}
                <xo-tooltip xo-title='{{ 'customer.account.title' | t }}'>
                  <a href='{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}' class='xo-header__right-item' aria-label='account'>
                    {% if customer %}
                      {% render 'icon', name: 'account', size: '18' %}
                    {% else %}
                      {% render 'icon', name: 'account', size: '18' %}
                    {% endif %}
                  </a>
                </xo-tooltip>
              {%- endif -%}
              {% if settings.cart_type == 'page' %}
                <xo-tooltip xo-title='{{ 'general.cart.title' | t }}'>
                  <a class='xo-header__right-item xo-header__right-item--cart' href='{{ routes.cart_url }}'>
                    {% render 'icon', name: 'add-to-cart', size: '20' %}
                    <div class='xo-header__right-item-number'>
                      <xo-cart-size>{{ cart.item_count }}</xo-cart-size>
                    </div>
                  </a>
                </xo-tooltip>
              {% else %}
                <xo-tooltip xo-title='{{ 'general.cart.title' | t }}'>
                  <xo-modal-trigger
                    class='xo-header__right-item xo-header__right-item--cart'
                    xo-name='cart'
                    role='button'
                    tabindex='0'
                  >
                    {% render 'icon', name: 'add-to-cart', size: '20' %}
                    <div class='xo-header__right-item-number'>
                      <xo-cart-size>{{ cart.item_count }}</xo-cart-size>
                    </div>
                  </xo-modal-trigger>
                </xo-tooltip>
              {% endif %}
            </div>
          </div>

          {% comment %} Mobile {% endcomment %}
          <div class='xo-header__content xo-header__content--mobile {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
            <nav class='xo-header__center {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
              <div class='xo-header__mobile'>
                {% render 'menu-hamburger', menu: section.settings.menu, modal_scheme: section.settings.modal_scheme %}
              </div>
            </nav>
            <div class='xo-header__left {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
              <a href='{{ routes.root_url }}'>
                {%- if section.settings.logo != blank -%}
                  {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
                  {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio -%}
                  {% capture widths %}{{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}{% endcapture %}
                  {{
                    section.settings.logo
                    | image_url: width: section.settings.logo_width_mobile
                    | image_tag:
                      class: 'xo-header__logo-img',
                      widths: widths,
                      height: logo_height,
                      width: section.settings.logo_width_mobile,
                      alt: logo_alt
                  }}
                {%- else -%}
