          </div>

          {% comment %} Mobile {% endcomment %}
          <div class='xo-header__content xo-header__content--mobile {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
            <nav class='xo-header__center {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
              <div class='xo-header__mobile'>
                {% render 'menu-hamburger', menu: section.settings.menu, modal_scheme: section.settings.modal_scheme %}
              </div>
            </nav>
            <div class='xo-header__left {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
              <a href='{{ routes.root_url }}'>
                {%- if section.settings.logo != blank -%}
                  {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
                  {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio -%}
                  {% capture widths %}{{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}{% endcapture %}
                  {{
                    section.settings.logo
                    | image_url: width: section.settings.logo_width_mobile
                    | image_tag:
                      class: 'xo-header__logo-img',
                      widths: widths,
                      height: logo_height,
                      width: section.settings.logo_width_mobile,
                      alt: logo_alt
                  }}
                {%- else -%}
                  <span class='xo-header__logo-heading-logo'>{{ shop.name }}</span>
                {%- endif -%}
              </a>
            </div>
            <div class='xo-header__right {% if section.settings.color_scheme %} color-{{ section.settings.color_scheme }}{% endif %}'>
              <xo-modal-trigger
                class='xo-header__right-item'
                xo-name='search'
              >
                {% render 'icon', name: 'search', size: '17' %}
              </xo-modal-trigger>
              {%- if shop.customer_accounts_enabled -%}
                <a href='{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}' class='xo-header__right-item'>
                  {% if customer %}
                    {% render 'icon', name: 'account', size: '18' %}
                  {% else %}
                    {% render 'icon', name: 'account', size: '18' %}
                  {% endif %}
                </a>
              {%- endif -%}
              {% if settings.cart_type == 'page' %}
                <a class='xo-header__right-item xo-header__right-item--cart' href='{{ routes.cart_url }}'>
                  {% render 'icon', name: 'add-to-cart', size: '20' %}
                  <div class='xo-header__right-item-number'>
                    <xo-cart-size>{{ cart.item_count }}</xo-cart-size>
                  </div>
                </a>
              {% else %}
                <xo-modal-trigger
                  class='xo-header__right-item xo-header__right-item--cart'
                  xo-name='cart'
                  role='button'
                  tabindex='0'
                >
                  {% render 'icon', name: 'add-to-cart', size: '20' %}
                  <div class='xo-header__right-item-number'>
                    <xo-cart-size>{{ cart.item_count }}</xo-cart-size>
                  </div>
                </xo-modal-trigger>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </xo-container>
    </div>
  </xo-sticky>
</header>

{% render 'header-ld-json' %}

