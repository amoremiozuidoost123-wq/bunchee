{{ 'section-main-page-title-type-4.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <div class='main-page-title-type-4' style="--height: {{ section.settings.height }}vh;--height-mb: {{ section.settings.height_mb }}vh">
    <div class='main-page-title-type-4__content'>
      <div class='main-page-title-type-4__container'>
        <xo-animate xo-cascade>
          <h1 class='main-page-title-type-4__heading'>
            {{ section.settings.heading }}
          </h1>
        </xo-animate>
        <xo-animate xo-cascade class='main-page-title-type-4__description'>{{ section.settings.description }}</xo-animate>
      </div>
    </div>
    <div class='main-page-title-type-4__image'>
      {% render 'image', image: section.settings.image, aspect_ratio: '21/9' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.main_page_title_type_4.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ],
    "templates": [
      "index"
    ]
  },
  "settings": [
    {
      "type": "range",
      "id": "height",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "t:sections.main_page_title_type_4.settings.height.label",
      "default": 70
    },
    {
      "type": "range",
      "id": "height_mb",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "t:sections.main_page_title_type_4.settings.height_mb.label",
      "default": 55
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_page_title_type_4.settings.heading.label",
      "default": "Page heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.main_page_title_type_4.settings.description.label",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.main_page_title_type_4.settings.image.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_page_title_type_4.presets.name"
    }
  ]
}
{% endschema %}