{% liquid
  assign product_info_type = section.settings.product_info_type
  assign hide_variants = section.settings.hide_variants
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
%}
<xo-product xo-product-information xo-product-id='{{ product.id }}' xo-section-id='{{ section.id }}' xo-selected-or-first-available-variant-id="{{ product.selected_or_first_available_variant.id }}" class='main-product'>
  <show-tooltip>
    <div {% render 'section-attr', style: 'z-index: 10' %}>
      <xo-container>
        {%- if product_info_type == 'product_info_type_1' -%}
          <xo-grid class='main-product'>
            <div style='--xs: 12; --lg: 4;--order-xs: 1; --order-lg: 0;' class='main-product__product-info-content-left-type-2'>
              {% render 'product-info-content-left-type-2' %}
            </div>
            <div style='--xs: 12; --lg: 4;--order-xs: 0; --order-lg: 1;' class='main-product__product-info-media-type-1'>
              <xo-animate xo-cascade>
                {% render 'product-info-media', hide_variants: hide_variants, variant_images: variant_images %}
              </xo-animate>
            </div>
            <div style='--xs: 12; --lg: 4;--order-xs: 2; --order-lg: 2;' class='main-product__product-info-content-right-type-2'>
              {% render 'product-info-content-right-type-2' %}
            </div>
          </xo-grid>
        {%- elsif product_info_type == 'product_info_type_2' -%}
          <xo-grid class='main-product'>
            <div style='--xs: 12; --lg: 4; --start-lg: 2;' class='main-product__product-info-media-type-3'>
              <xo-animate xo-cascade>
                {% render 'product-info-media', hide_variants: hide_variants, variant_images: variant_images %}
              </xo-animate>
            </div>
            <div style='--xs: 12; --lg: 4; --start-lg: 7;' class='main-product__product-info-content-type-3'>
              {% render 'product-info-content-type-3' %}
            </div>
          </xo-grid>
        {%- endif -%}
      </xo-container>

      {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
      {%- if first_3d_model -%}
        <script type='application/json' id='xo-3d-product-json-{{ product.id }}'>
          {{ product.media | where: 'media_type', 'model' | json }}
        </script>
      {%- endif -%}
    </div>
    {% comment %} Sticky cart {% endcomment %}
    {% render 'sticky-cart' %}

    {% comment %} Data {% endcomment %}
    {% render 'product-data', product: product %}
  </show-tooltip>
</xo-product>
{% render 'main-product-ld-json' %}

