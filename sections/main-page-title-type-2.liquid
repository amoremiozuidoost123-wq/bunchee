{{ 'section-main-page-title-type-2.css' | asset_url | stylesheet_tag }}
<section {% render 'section-attr' %}>
  <xo-animate xo-cascade class='main-page-title-type-2'>
    {% render 'page-title-type-2',
      image_desktop: section.settings.image_desktop,
      image_mobile: section.settings.image_mobile,
      small_image: section.settings.small_image,
      show_image: section.settings.show_image,
      aspect_ratio_desktop: section.settings.aspect_ratio_desktop,
      aspect_ratio_mobile: section.settings.aspect_ratio_mobile,
      show_divider: section.settings.show_divider
    %}
  </xo-animate>
</section>

{% schema %}
{
  "name": "t:sections.main_page_title_type_2.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ],
    "templates": [
      "index"
    ]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "t:sections.main_page_title_type_2.settings.show_divider.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.main_page_title_type_2.settings.show_image.label",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "t:sections.main_page_title_type_2.settings.image_desktop.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "t:sections.all.image_aspect_ratio.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.all.image_aspect_ratio.options_1.label"
        },
        {
          "value": "2/3",
          "label": "t:sections.all.image_aspect_ratio.options_2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image_aspect_ratio.options_3.label"
        },
        {
          "value": "1",
          "label": "t:sections.all.image_aspect_ratio.options_4.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image_aspect_ratio.options_5.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image_aspect_ratio.options_6.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image_aspect_ratio.options_7.label"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.main_page_title_type_2.settings.image_mobile.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "t:sections.all.image_aspect_ratio.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "t:sections.all.image_aspect_ratio.options_1.label"
        },
        {
          "value": "2/3",
          "label": "t:sections.all.image_aspect_ratio.options_2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image_aspect_ratio.options_3.label"
        },
        {
          "value": "1",
          "label": "t:sections.all.image_aspect_ratio.options_4.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image_aspect_ratio.options_5.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image_aspect_ratio.options_6.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image_aspect_ratio.options_7.label"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "small_image",
      "label": "t:sections.main_page_title_type_2.settings.small_image.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_page_title_type_2.presets.name"
    }
  ]
}
{% endschema %}