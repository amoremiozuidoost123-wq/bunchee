{{ 'section-main-reset-password.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <h2 class='xo-reset__heading'>
    {{ 'customer.reset_password.title' | t }}
  </h2>
  <xo-container>
    <xo-grid>
      <div class='xo-reset-pass' style='--xs: 12'>
        {%- form 'reset_customer_password' -%}
          {% render 'form-error', form: form %}
          <xo-grid style='--xs: 12;'>
            <xo-animate xo-cascade>
              {% assign password_label = 'customer.reset_password.password' | t %}
              {% render 'field-input', type: 'password', name: 'customer[password]', label: password_label, id: 'customer[password]' %}
            </xo-animate>
            <xo-animate xo-cascade>
              {% assign password_confirm_label = 'customer.reset_password.password_confirm' | t %}
              {% render 'field-input', type: 'password', name: 'customer[password_confirmation]', label: password_confirm_label, id: 'customer[password_confirmation]' %}
            </xo-animate>
          </xo-grid>
          {% render 'space', value: '20px' %}
          <xo-animate xo-cascade>
            {% assign label = 'customer.reset_password.submit' | t %}
            {% render 'button', text: label, size: 'md', type: 'submit', block: true, effect: 'fade' %}
          </xo-animate>
        {%- endform -%}
      </div>
    </xo-grid>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.main_reset_password.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ]
}
{% endschema %}