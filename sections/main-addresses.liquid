{{ 'section-main-addresses.css' | asset_url | stylesheet_tag }}
{{ 'address-detail.css' | asset_url | stylesheet_tag }}
{{ 'address-table.css' | asset_url | stylesheet_tag }}
{{ 'address-form.css' | asset_url | stylesheet_tag }}

<div {% render 'section-attr' %}>
  <xo-container class='xo-address-list'>
    <xo-animate xo-cascade class='xo-address-list__top'>
      <h2 class='xo-address-list__heading'>{{ section.settings.heading }}</h2>
      {% liquid
        assign account_return = 'customer.account.return' | t
        render 'button', text: account_return, link: routes.account_url, style: 'link', icon: 'arrow-with-reer-left', icon_size: '16', icon_position: 'left'
      %}
    </xo-animate>

    <xo-animate xo-cascade>
      <xo-grid>
        {% if customer.addresses.size > 0 %}
          <div style='--md: 12; --lg: 9'>
            {% render 'address-table' %}
          </div>
          <div style='--md: 12; --lg: 3'>
            {% render 'address-detail' %}
          </div>
        {% else %}
          <div style='--md: 12; --lg: 12'>
            {% render 'address-table' %}
          </div>
        {% endif %}
      </xo-grid>
    </xo-animate>
  </xo-container>
</div>

{% schema %}
{
  "name": "t:sections.main_addresses.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.main_addresses.settings.heading.label",
      "default": "Address"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.main_addresses.settings.subheading.label",
      "default": "List of addresses"
    },
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ]
}
{% endschema %}