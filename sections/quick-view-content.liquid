{% liquid
  assign button_text_unavailable = 'products.product.unavailable' | t
%}

<xo-product xo-product-information xo-product-id='{{ product.id }}' xo-product-url='{{ shop.url }}/{{ product.url }}' xo-section-id='{{ section.id }}' xo-selected-or-first-available-variant-id="{{ product.selected_or_first_available_variant.id }}" class='quick-view'>
  <show-tooltip>
    {% assign featured_media = product.selected_or_first_available_variant.featured_media %}
    <xo-container>
      <div class='quick-view-content'>
        <div class='quick-view-content__product-info-media'>
          <xo-animate xo-cascade>
            <div class='product-info-media'>
              <xo-product-will-change xo-unique-id='product-info-media-{{ product.id }}'>
                <div>
                  <xo-carousel xo-autoheight>
                    <xo-carousel-inner>
                      <xo-carousel-list>
                        {% if featured_media != null %}
                          {% case featured_media.media_type %}
                            {% when 'image' %}
                              <xo-carousel-slide xo-active xo-visible>
                                {% render 'media', type: featured_media.media_type, media: featured_media, image_lazyload: false, image_widths: '375, 550, 750, 900' %}
                              </xo-carousel-slide>

                            {% when 'model' %}
                              <xo-carousel-slide data-media-id='{{ featured_media.id }}' class='xo-product-info-media-style3__slide'>
                                <div style='height: 100%; position: relative'>
                                  <div class='xb-product-model__btn' style='height: 10%;'>
                                    <button
                                      class='xb-product-model__btn-view'
                                      type='button'
                                      aria-label='{{ 'products.product.xr_button_label' | t }}'
                                      data-shopify-xr
                                      data-shopify-model3d-id='{{ featured_media.id }}'
                                      data-shopify-title='title'
                                      data-shopify-xr-hidden
                                    >
                                      <span>
                                        {% render 'icon', name: '3d-model', icon_size: '10' %}
                                      </span>
                                      {{ 'products.product.xr_button' | t }}
                                    </button>
                                  </div>
                                  <xo-product-model style='height: 90%'>
                                    <button class='xb-product-model__poster' type='button' aria-label='xr-button'>
                                      <span class='xb-product-model__poster-button'>
                                        {% render 'icon', name: '3d-model', icon_size: '20' %}
                                      </span>
                                      <div class='xb-product-model__poster-image'>
                                        <img
                                          is='xo-lazyload'
                                          width='810'
                                          height='590'
                                          src='{{ featured_media | image_url: width: 'auto', height: 'auto' }}'
                                          alt='{{ featured_media.preview_image.alt | escape }}'
                                        >
                                        <div class='xo-lazyload-overlay'></div>
                                      </div>
                                    </button>
                                    <template>{% render 'media', type: 'model', media: featured_media %}</template>
                                  </xo-product-model>
                                </div>
                              </xo-carousel-slide>
                            {% else %}
                              <xo-carousel-slide>
                                <div class='product-info-media__image'>
                                  {% render 'media', type: featured_media.media_type, media: featured_media, loop: true, controls: true, muted: true, autoplay: true %}
                                </div>
                              </xo-carousel-slide>
                          {% endcase %}
                        {% endif %}
                        {% for media in product.media %}
                          {% unless media.id == featured_media.id %}
                            {% case media.media_type %}
                              {% when 'image' %}
                                <xo-carousel-slide xo-active xo-visible>
                                  {% if media.media_type == 'image' %}
                                    <div>
                                      <div>
                                        <div class='product-info-media__image'>
                                          {% render 'media', type: media.media_type, media: media, image_lazyload: false, image_widths: '375, 550, 750, 900' %}
                                        </div>
                                      </div>
                                    </div>
                                  {% else %}
                                    {% render 'media', type: media.media_type, media: media, image_lazyload: false, image_widths: '375, 550, 750, 900' %}
                                  {% endif %}
                                </xo-carousel-slide>
                              {% when 'model' %}
                                <xo-carousel-slide data-media-id='{{ media.id }}' class='xo-product-info-media-style-3__slide'>
                                  <div style='height: 100%; position: relative'>
                                    <div class='xb-product-model__btn' style='height: 10%;'>
                                      <button
                                        class='xb-product-model__btn-view'
                                        type='button'
                                        aria-label='{{ 'products.product.xr_button_label' | t }}'
                                        data-shopify-xr
                                        data-shopify-model3d-id='{{ media.id }}'
                                        data-shopify-title='title'
                                        data-shopify-xr-hidden
                                      >
                                        <span>
                                          {% render 'icon', name: '3d-model', icon_size: '10' %}
                                        </span>
                                        {{ 'products.product.xr_button' | t }}
                                      </button>
                                    </div>
                                    <xo-product-model style='height: 90%'>
                                      <button class='xb-product-model__poster' type='button' aria-label='xr-button'>
                                        <span class='xb-product-model__poster-button'>
                                          {% render 'icon', name: '3d-model', icon_size: '20' %}
                                        </span>
                                        <div class='xb-product-model__poster-image'>
                                          <img
                                            is='xo-lazyload'
                                            width='810'
                                            height='590'
                                            src='{{ media | image_url: width: 'auto', height: 'auto' }}'
                                            alt='{{ media.preview_image.alt | escape }}'
                                          >
                                          <div class='xo-lazyload-overlay'></div>
                                        </div>
                                      </button>
                                      <template>{% render 'media', type: 'model', media: media %}</template>
                                    </xo-product-model>
                                  </div>
                                </xo-carousel-slide>
                              {% else %}
                                <xo-carousel-slide>
                                  {% render 'media', type: media.media_type, media: media, loop: true, controls: true, muted: true, autoplay: true %}
                                </xo-carousel-slide>
                            {% endcase %}
                          {% endunless %}
                        {% endfor %}
                      </xo-carousel-list>
                    </xo-carousel-inner>
                    <div class='product-info-media__content'>
                      {% if product.media.size > 1 %}
                        <xo-carousel-thumbnail class='product-info-media__thumbnails' xo-per-view='3'>
                          <xo-carousel-inner>
                            <xo-carousel-list>
                              {%- if featured_media != null -%}
                                {% case featured_media.media_type %}
                                  {%- when 'image' -%}
                                    <xo-carousel-slide class='product-info-media__thumb-slide' xo-active xo-visible>
                                      {% render 'media', type: featured_media.media_type, media: featured_media, image_lazyload: false, image_widths: '375, 550, 750, 900' %}
                                    </xo-carousel-slide>
                                {% endcase %}
                              {%- endif -%}
                              {% for media in product.media %}
                                {% unless media.id == featured_media.id %}
                                  <xo-carousel-slide class='product-info-media__thumb-slide' xo-active xo-visible>
                                    {% render 'media', type: 'image', media: media.preview_image, image_lazyload: false, image_widths: '375, 550, 750, 900' %}
                                  </xo-carousel-slide>
                                {% endunless %}
                              {% endfor %}
                            </xo-carousel-list>
                          </xo-carousel-inner>
                          <div class='carousel-navigation-controls'>
                            <xo-carousel-prev>
                              <div class='carousel-navigation-controls__icon carousel-navigation-controls__icon--prev'>
                                {% render 'icon', name: 'product-carousel-prev', size: '24' %}
                              </div>
                            </xo-carousel-prev>
                            <xo-carousel-next>
                              <div class='carousel-navigation-controls__icon carousel-navigation-controls__icon--next'>
                                {% render 'icon', name: 'product-carousel-next', size: '24' %}
                              </div>
                            </xo-carousel-next>
                          </div>
                        </xo-carousel-thumbnail>
                      {% endif %}
                    </div>
                  </xo-carousel>
                </div>
              </xo-product-will-change>
            </div>
          </xo-animate>
        </div>
        <div class='quick-view-content__product-info-content'>
          <div class='product-info-content-type-3'>
            <xo-product-will-change xo-unique-id='product-badge-{{ product.id }}' class='product-info-content-type-3__badge'>
              {% render 'badge-sale', product: product, use_variant: true %}
              {% render 'badge-sold-out', product: product, use_variant: true %}
              {% render 'badge-new', product: product %}
            </xo-product-will-change>
            <xo-animate xo-cascade>
              <h4 class='product-info-content-type-3__title'>
                {{ product.title }}
              </h4>
            </xo-animate>

            <xo-animate xo-cascade class='product-info-content-type-3__price'>
              <xo-product-will-change xo-unique-id='product-price-{{ product.id }}'>
                {% if cart.taxes_included == true %}
                  <span class='product-info-content-type-3__price-tax'>{{ 'products.product.price.include_tax' | t }}</span>
                {% endif %}
                {% render 'price', product: product, use_variant: true %}
              </xo-product-will-change>
            </xo-animate>

            <xo-animate xo-cascade class='product-info-content-type-3__description'>
              {{ product.description }}
            </xo-animate>

            {% if product.has_only_default_variant == false %}
              <xo-product-variants class='product-info-content-type-3__variant variant-list'>
                {% if product.options_with_values.size > 0 %}
                  {%- for option in product.options_with_values -%}
                    <xo-animate xo-cascade>
                      {% if option.name == 'Color' %}
                        {% render 'product-variant', option: option, style: 'variant_image', is_product_detail: true %}
                      {% else %}
                        {% render 'product-variant', option: option, style: 'boxed', is_product_detail: true %}
                      {% endif %}
                    </xo-animate>
                  {%- endfor -%}
                {% endif %}
              </xo-product-variants>
            {% endif %}

            <xo-animate xo-cascade>
              {% assign form_id = 'product_form_id-' | append: section.id %}
              {% render 'quantity', form_id: form_id %}
            </xo-animate>

            <xo-animate xo-cascade>
              {% assign form_id = 'product_form_id-' | append: section.id %}
              {%- form 'product', product, id: form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                <div class='buy-button__container'>
                  <xo-product-will-change
                    class='buy-button'
                    xo-unique-id='product-buy-now-button-{{ product.id }}'
                    {% if product.selected_or_first_available_variant.available == false %}
                      xo-disabled
                    {% endif %}
                  >
                    {{ form | payment_button }}
                    {{ form | payment_terms }}
                  </xo-product-will-change>
                  <div class='add-button add-button--unavailable add-to-cart__unavailable add-to-cart__button'>
                    <div class='add-to-cart__unavailable-text'>{{ button_text_unavailable }}</div>
                    <div class='add-button__inside'>
                      <div class='add-button__cart'>
                        {% render 'button', size: 'md', block: true, style: 'primary', icon: 'add-to-cart', icon_position: 'left', icon_size: '22', product_card: true %}
                      </div>
                    </div>
                  </div>
                  <xo-product-will-change xo-unique-id='product-add-button-text-{{ product.id }}' class='add-to-cart__container'>
                    {% if product.selected_or_first_available_variant.available == true %}
                      {% assign button_text = 'products.product.add_to_cart' | t %}
                      {% assign sold_out = false %}
                    {% elsif product.selected_or_first_available_variant.available == false %}
                      {% assign button_text = 'products.product.sold_out' | t %}
                      {% assign sold_out = true %}
                    {% endif %}
                    <div
                      class='add-button add-button--available add-to-cart__button add-to-cart__sold-out'
                      sold-out='{{ sold_out }}'
                    >
                      <div class='add-to-cart__text'>{{ button_text }}</div>
                      <xo-product-will-change
                        class='add-button__inside'
                        xo-unique-id='product-add-button-{{ product.id }}'
                        {% if product.selected_or_first_available_variant.available == false %}
                          xo-disabled
                        {% endif %}
                      >
                        <xo-cart-add
                          class='add-button__cart'
                        >
                          {% render 'button', size: 'md', block: true, style: 'primary', icon: 'add-to-cart', icon_position: 'left', icon_size: '22', product_card: true %}
                        </xo-cart-add>
                      </xo-product-will-change>
                    </div>
                  </xo-product-will-change>
                </div>
              {%- endform -%}
              {% render 'cart-add-error' %}
            </xo-animate>
          </div>
        </div>
      </div>
    </xo-container>
    {% render 'product-data', product: product %}
    {% render 'main-product-ld-json', product: product %}
  </show-tooltip>
</xo-product>

{% schema %}
{
  "name": "t:sections.quick_view_content.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay"
    ]
  },
  "settings": []
}
{% endschema %}