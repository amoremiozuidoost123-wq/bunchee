{{ 'section-image-banner-type-8.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <div class='image-banner-type-8'>
    <div class='image-banner-type-8__left'>
      <div class='image-banner-type-8__left-container'>
        {% for block in section.blocks %}
          <xo-carousel-trigger
            xo-index='{{ forloop.index0 }}'
            xo-carousel-selector='.image-banner-type-8__carousel--{{ section.id }}'
            xo-type='hover'
            class='image-banner-type-8__text'
          >
            <a href='{{ block.settings.link }}' role='button' tabindex='0'>
              {%- render 'animate-text', text: block.settings.text, type: 'hover' -%}
            </a>
          </xo-carousel-trigger>
        {% endfor %}
      </div>
    </div>
    <div class='image-banner-type-8__right'>
      <xo-carousel xo-per-view='1' xo-speed='2000' xo-gap='0' class='image-banner-type-8__carousel image-banner-type-8__carousel--{{ section.id }}' xo-type='fade'>
        <xo-carousel-inner>
          <xo-carousel-list>
            {% for block in section.blocks %}
              <xo-carousel-slide>
                {% if block.settings.background_image != blank and block.settings.background_image_mb == blank %}
                  <div class='image-banner-type-8__bg'>
                    {% render 'image', image: block.settings.background_image, lazyload: false %}
                  </div>
                  <div class='image-banner-type-8__bg image-banner-type-8__bg--mobile'>
                    {% render 'image', image: block.settings.background_image, lazyload: false %}
                  </div>
                {% elsif block.settings.background_image_mb != blank and block.settings.background_image == blank %}
                  <div class='image-banner-type-8__bg'>
                    {% render 'image', image: block.settings.background_image_mb, lazyload: false %}
                  </div>
                  <div class='image-banner-type-8__bg image-banner-type-8__bg--mobile'>
                    {% render 'image', image: block.settings.background_image_mb, lazyload: false %}
                  </div>
                {% else %}
                  <div class='image-banner-type-8__bg'>
                    {% render 'image', image: block.settings.background_image, lazyload: false %}
                  </div>
                  <div class='image-banner-type-8__bg image-banner-type-8__bg--mobile'>
                    {% render 'image', image: block.settings.background_image_mb, lazyload: false %}
                  </div>
                {% endif %}
              </xo-carousel-slide>
            {% endfor %}
          </xo-carousel-list>
        </xo-carousel-inner>
      </xo-carousel>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.image_banner_type_8.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.image_banner_type_8.blocks.item.label",
      "type": "item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.image_banner_type_8.blocks.item.settings.text.label",
          "default": "Item text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.image_banner_type_8.blocks.item.settings.link.label"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "t:sections.image_banner_type_8.blocks.item.settings.background_image.label"
        },
        {
          "type": "image_picker",
          "id": "background_image_mb",
          "label": "t:sections.image_banner_type_8.blocks.item.settings.background_image_mb.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_banner_type_8.presets.name",
      "blocks": [
        {
          "type": "item",
          "settings": {}
        },
        {
          "type": "item",
          "settings": {}
        },
        {
          "type": "item",
          "settings": {}
        }
      ]
    }
  ]
}
{% endschema %}