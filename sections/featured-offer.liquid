  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_svg",
      "label": "t:sections.featured_offer.settings.show_svg.label",
      "default": true
    },
    {
      "type": "color",
      "id": "svg_color",
      "label": "t:sections.featured_offer.settings.svg_color.label",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "justify_content",
      "label": "t:sections.featured_offer.settings.justify_content.label",
      "options": [
        {
          "value": "flex-start",
          "label": "t:sections.featured_offer.settings.justify_content.option_1"
        },
        {
          "value": "center",
          "label": "t:sections.featured_offer.settings.justify_content.option_2"
        },
        {
          "value": "flex-end",
          "label": "t:sections.featured_offer.settings.justify_content.option_3"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "align_items",
      "label": "t:sections.featured_offer.settings.align_items.label",
      "options": [
        {
          "value": "flex-start",
          "label": "t:sections.featured_offer.settings.align_items.option_1"
        },
        {
          "value": "center",
          "label": "t:sections.featured_offer.settings.align_items.option_2"
        },
        {
          "value": "flex-end",
          "label": "t:sections.featured_offer.settings.align_items.option_3"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "id": "spacing_padding_top",
      "label": "t:sections.featured_offer.settings.spacing_padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "id": "spacing_padding_top_mb",
      "label": "t:sections.featured_offer.settings.spacing_padding_top_mb.label",
      "default": 0
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:sections.featured_offer.settings.heading.label",
      "default": "<p>Heading</p>"
    },
    {
      "type": "header",
      "content": "t:sections.featured_offer.settings.header_0.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.featured_offer.settings.image.label"
    },
    {
      "type": "range",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "id": "top",
      "label": "t:sections.featured_offer.settings.top.label",
      "default": 0
    },
    {
      "type": "range",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "id": "left",
      "label": "t:sections.featured_offer.settings.left.label",
