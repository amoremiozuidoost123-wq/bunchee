{{ 'section-featured-offer.css' | asset_url | stylesheet_tag }}

{% liquid
  assign top = section.settings.top
  assign top_mb = section.settings.top_mb
  assign left = section.settings.left
  assign left_mb = section.settings.left_mb
  assign spacing_padding_top = section.settings.spacing_padding_top
  assign spacing_padding_top_mb = section.settings.spacing_padding_top_mb
  assign image = section.settings.image
  assign image_mobile = section.settings.image_mobile
  assign justify_content = section.settings.justify_content
  assign align_items = section.settings.align_items

  if justify_content == 'flex-start'
    assign text_align = 'left'
  elsif justify_content == 'flex-end'
    assign text_align = 'right'
  else
    assign text_align = 'center'
  endif
%}
<div class='featured-offer'>
  <section {% render 'section-attr' %}>
    <div class="featured-offer__wrapper-img">
      <xo-animate xo-cascade class="featured-offer__img-desktop" style="--top: {{ top }}%; --left: {{ left }}%;">
        {% if image != blank %}
          {% render 'image', image: image, lazyload: true %}
        {% else %}
          {% render 'image', image: image_mobile, lazyload: true %}
        {% endif %}
      </xo-animate>
      <xo-animate xo-cascade class="featured-offer__img-mobile" style="--top-mb: {{ top_mb }}%; --left-mb: {{ left_mb }}%;">
        {% if image_mobile != blank %}
          {% render 'image', image: image_mobile, lazyload: true %}
        {% else %}
          {% render 'image', image: image, lazyload: true %}
        {% endif %}
      </xo-animate>
    </div>
    <xo-container class='featured-offer__container'>
      <div class='featured-offer__content' style="--justify-content: {{ justify_content }};--align-items: {{ align_items }};--padding-top: {{ spacing_padding_top }}px;--padding-top-mb: {{ spacing_padding_top_mb }}px;">
        <div class='featured-offer__inner'>
          <xo-animate xo-cascade class='featured-offer__heading d2' style="--text-align: {{ text_align }};">
            {{ section.settings.heading }}
          </xo-animate>
          <xo-animate xo-cascade class='featured-offer__button'>
            {% render 'button',
              text: section.settings.button_text,
              link: section.settings.button_link,
              size: section.settings.button_size,
              style: section.settings.button_style,
              icon: 'arrow-testimonial-right',
              icon_position: 'right',
              icon_size: '24'
            %}
          </xo-animate>
        </div>
      </div>
    </xo-container>
    {% if section.settings.show_svg %}
      <div class='featured-offer__svg' style='--color: {{ section.settings.svg_color }};'>
        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1920 260'>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M1920 260V150L0 0V260H1920Z"/>
        </svg>
      </div>
    {% endif %}
    {% content_for 'blocks' %}
  </section>
</div>

{% schema %}
{
  "name": "t:sections.featured_offer.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
