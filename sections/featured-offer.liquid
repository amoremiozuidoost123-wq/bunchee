    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.featured_offer.settings.image_mobile.label"
    },
    {
      "type": "range",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "id": "top_mb",
      "label": "t:sections.featured_offer.settings.top_mb.label",
      "default": 50
    },
    {
