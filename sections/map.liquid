{{ 'section-map.css' | asset_url | stylesheet_tag }}
<section {% render 'section-attr' %}>
  <xo-tabs>
    <xo-container>
      <div class='map'>
        <xo-tabs-content class='map__image'>
          {% for block in section.blocks %}
            <xo-tabs-pane
              xo-name='{{ block.id }}'
              {% if forloop.index0 == 0 %}
                xo-active
              {% endif %}
            >
              {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
              {%- assign placeholder_image = 'hero-apparel-' | append: placeholder_image_index -%}
              <xo-animate xo-cascade xo-type='zoom-out'>
                {%- render 'image', image: block.settings.image, placeholder: placeholder_image -%}
              </xo-animate>
            </xo-tabs-pane>
          {% endfor %}
        </xo-tabs-content>
        <div class='map__list'>
          {% for block in section.blocks %}
            <div class='map__block'>
              <xo-tabs-trigger
                xo-name='{{ block.id }}'
                {% if forloop.index0 == 0 %}
                  xo-active
                {% endif %}
                role='button'
                tabindex='0'
              >
                <xo-animate xo-cascade class='map__heading h5'>
                  {{ block.settings.heading }}
                </xo-animate>
              </xo-tabs-trigger>
              <div class='map__block-list'>
                <xo-animate xo-cascade class='map__first-line'>
                  <div class='map__location'>
                    {{ block.settings.location }}
                  </div>
                  <div class='map__circle'></div>
                  <a href='{{ block.settings.url }}' class='map__link'>
                    {{ block.settings.link }}
                  </a>
                </xo-animate>
                <xo-animate xo-cascade class='map__second-line'>
                  <div class='map__item'>
                    <div class='map__day'>
                      {{ block.settings.day_1 }}
                    </div>
                    <div class='map__time'>
                      {{ block.settings.time_1 }}
                    </div>
                  </div>
                  <div class='map__item'>
                    <div class='map__day'>
                      {{ block.settings.day_2 }}
                    </div>
                    <div class='map__time'>
                      {{ block.settings.time_2 }}
                    </div>
                  </div>
                </xo-animate>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </xo-container>
  </xo-tabs>
</section>

{% schema %}
{
  "name": "t:sections.map.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "t:sections.map.blocks.location.label",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.map.blocks.location.settings.image.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.map.blocks.location.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "textarea",
          "id": "location",
          "label": "t:sections.map.blocks.location.settings.location.label",
          "default": "Location"
        },
        {
          "type": "textarea",
          "id": "link",
          "label": "t:sections.map.blocks.location.settings.link.label",
          "default": "Direction"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:sections.map.blocks.location.settings.url.label"
        },
        {
          "type": "textarea",
          "id": "day_1",
          "label": "t:sections.map.blocks.location.settings.day_1.label",
          "default": "Day"
        },
        {
          "type": "textarea",
          "id": "time_1",
          "label": "t:sections.map.blocks.location.settings.time_1.label",
          "default": "Time"
        },
        {
          "type": "textarea",
          "id": "day_2",
          "label": "t:sections.map.blocks.location.settings.day_2.label",
          "default": "Day"
        },
        {
          "type": "textarea",
          "id": "time_2",
          "label": "t:sections.map.blocks.location.settings.time_2.label",
          "default": "Time"
        },
        {
          "type": "text",
          "id": "phone_number",
          "label": "t:sections.map.blocks.location.settings.phone_number.label",
          "default": "Phone number"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.map.presets.name",
      "blocks": [
        {
          "type": "location"
        },
        {
          "type": "location"
        }
      ]
    }
  ]
}
{% endschema %}