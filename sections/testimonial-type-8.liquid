{{ 'section-testimonial-type-8.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-container class='testimonial-type-8'>
    {% render 'section-bg-image' %}
    <xo-carousel
      {% if section.settings.autoplay %}
        xo-autoplay='3000'
      {% endif %}
      xo-per-view='1'
      xo-per-move='1'
      xo-type='none'
    >
      <div class='testimonial-type-8__top'>
        <h3 class='testimonial-type-8__heading'>{{ section.settings.heading }}</h3>
        <div class='testimonial-type-8__description'>{{ section.settings.description }}</div>
        <div class='testimonial-type-8__group-button'>
          <xo-carousel-prev role='button' tabindex='0' aria-label='previous'>
            <div class='testimonial-type-8__button  testimonial-type-8__button--previous'>
              {% render 'icon', name: 'arrow-testimonial-left', size: '22' %}
              {% render 'icon', name: 'arrow-testimonial-left', size: '22' %}
            </div>
          </xo-carousel-prev>
          <xo-carousel-next role='button' tabindex='0' aria-label='next'>
            <div class='testimonial-type-8__button'>
              {% render 'icon', name: 'arrow-testimonial-right', size: '22' %}
              {% render 'icon', name: 'arrow-testimonial-right', size: '22' %}
            </div>
          </xo-carousel-next>
        </div>
      </div>
      <xo-carousel-inner>
        <xo-carousel-list>
          {% for block in section.blocks %}
            {% render 'testimonial-slide-type-8',
              review: block.settings.review,
              customer_name: block.settings.customer_name,
              verified_user: block.settings.verified_user,
              color_scheme: section.settings.box_color_scheme
            -%}
          {% endfor %}
        </xo-carousel-list>
      </xo-carousel-inner>
    </xo-carousel>
  </xo-container>
</section>

{% schema %}
{
  "name": "t:sections.testimonial_type_8.name",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonial_type_8.settings.heading.label",
      "default": "Testimonial"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.testimonial_type_8.settings.description.label",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.testimonial_type_8.settings.autoplay.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "box_color_scheme",
      "label": "t:sections.testimonial_type_8.settings.box_color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.header_1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.bg_color.label"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.bg_gradient.label"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:sections.all.padding_top_mobile.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.testimonial_type_8.blocks.slide.label",
      "type": "testimonial-slide",
      "settings": [
        {
          "type": "richtext",
          "id": "review",
          "label": "t:sections.testimonial_type_8.blocks.slide.settings.review.label",
          "default": "<p>Slide review</p>"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "t:sections.testimonial_type_8.blocks.slide.settings.customer_name.label",
          "default": "Customer name"
        },
        {
          "type": "checkbox",
          "id": "verified_user",
          "label": "t:sections.testimonial_type_8.blocks.slide.settings.verified_user.label",
          "default": true
        }
      ]
    }
  ]
}
{% endschema %}