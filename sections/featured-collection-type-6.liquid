{{ 'section-featured-collection-type-6.css' | asset_url | stylesheet_tag }}

<section {% render 'section-attr' %}>
  <xo-container class='featured-collection-type-6'>
    <xo-grid>
      <xo-animate xo-cascade xo-type='zoom-out' class='featured-collection-type-6__left' style='--xs: 12; --md: 12; --lg: 6;'>
        {% render 'image', image: section.settings.image, placeholder: 'product-1', aspect_ratio: '1' %}
      </xo-animate>
      <div class='featured-collection-type-6__right' style='--xs: 12; --md: 12; --lg: 6;'>
        <xo-carousel
          class='featured-collection-type-6__carousel'
          xo-speed='100'
          xo-type='none'
          xo-per-view='1'
          xo-per-view='1'
          xo-breakpoints='
            {
              600: {
                perView: 1,
                perMove: 1,
                gap: 10,
                overflow: visible
              },
              1000: {
                perView: 1,
                perMove: 1,
              },
            }
          '
        >
          <xo-carousel-inner>
            <xo-carousel-list>
              {% for block in section.blocks %}
                {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                {%- assign placeholder_image = 'product-' | append: placeholder_image_index -%}
                {% render 'featured-collection-slide-type-6',
                  tag: block.settings.tag,
                  subheading: section.settings.subheading,
                  description: block.settings.description,
                  image: block.settings.image,
                  button_text: block.settings.button_text,
                  button_link: block.settings.button_link,
                  button_style: section.settings.button_style,
                  placeholder_image: placeholder_image,
                  aspect_ratio: section.settings.aspect_ratio,
                  heading: block.settings.heading
                %}
              {% endfor %}
            </xo-carousel-list>
          </xo-carousel-inner>
        </xo-carousel>
      </div>
    </xo-grid>
  </xo-container>
</section>

{% schema %}
{
