    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:sections.all.padding_bottom_mobile.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.featured_collection_type_6.blocks.item.label",
      "type": "item",
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "t:sections.featured_collection_type_6.blocks.item.settings.heading.label",
