{{ 'section-sale-countdown.css' | asset_url | stylesheet_tag }}

{% liquid
  assign fixed_time = section.settings.timer_year | append: '-' | append: section.settings.timer_month | append: '-' | append: section.settings.timer_day | append: ' ' | append: section.settings.timer_hour | append: ':' | append: section.settings.timer_minute | append: ':' | append: section.settings.timer_minute | append: ':00'
  case section.settings.evergreen_unit
    when 'days'
      assign evergreen_time = 86400000 | times: section.settings.evergreen_value
    when 'hours'
      assign evergreen_time = 3600000 | times: section.settings.evergreen_value
    when 'minutes'
      assign evergreen_time = 60000 | times: section.settings.evergreen_value
    else
      assign evergreen_time = 1000 | times: section.settings.evergreen_value
  endcase

  if section.settings.timer_mode == 'fixed'
    assign timestamp = fixed_time | date: '%s000'
  else
    assign timestamp = 'now' | date: '%s000' | plus: evergreen_time
  endif
%}

<section {% render 'section-attr' %}>
  <div class='sale-countdown'>
    <xo-animate xo-cascade class='sale-countdown__time'>
      <xo-countdown
        class='sale-countdown__timer'
        xo-timestamp='{{ timestamp }}'
        xo-zero-pad='2'
      >
        <div class='sale-countdown__timer-item'>
          <xo-countdown-day class='sale-countdown__timer-value h5'></xo-countdown-day>
          <h2 class='sale-countdown__timer-label h5'>{{ 'general.count_down.day_time' | t }}</h2>
        </div>
        <div class='sale-countdown__timer-item'>
          <xo-countdown-hour class='sale-countdown__timer-value h5'></xo-countdown-hour>
          <h2 class='sale-countdown__timer-label h5'>{{ 'general.count_down.hour_time' | t }}</h2>
        </div>
        <div class='sale-countdown__timer-item'>
          <xo-countdown-minute class='sale-countdown__timer-value h5'></xo-countdown-minute>
          <h2 class='sale-countdown__timer-label h5'>{{ 'general.count_down.minutes_time' | t }}</h2>
        </div>
        <div class='sale-countdown__timer-item'>
          <xo-countdown-second class='sale-countdown__timer-value h5'></xo-countdown-second>
          <h2 class='sale-countdown__timer-label h5'>{{ 'general.count_down.seconds_time' | t }}</h2>
        </div>
      </xo-countdown>
    </xo-animate>
    <xo-marquee
      class='sale-countdown__marquee'
      xo-speed='{{ section.settings.marquee_speed |  default: 4}}'
      {%- if section.settings.stop_marquee -%}
        xo-pause-on-hover='true'
      {%- endif -%}
      {%- if section.settings.marquee_right_to_left -%}
        xo-rtl='true'
      {%- endif -%}
    >
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'text' %}
            <h2 class='sale-countdown__text'>{{ block.settings.text }}</h2>
        {% endcase %}
      {% endfor %}
    </xo-marquee>
    <xo-container class='sale-countdown__container'>
      <xo-grid>
        {% for block in section.blocks %}
          {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
          {%- assign placeholder_image = 'product-apparel-' | append: placeholder_image_index -%}
          {% case block.type %}
            {% when 'product' %}
              {% if block.settings.product_list != blank %}
                {% for product in block.settings.product_list %}
                  <div class='sale-countdown__product' style='--xs: 12;--lg: 3;'>
                    {% render 'product-card',
                      product: product,
                      show_image: block.settings.product_card_show_image,
                      show_secondary_image: block.settings.product_card_show_secondary_image,
                      show_vendor: block.settings.product_card_show_vendor,
                      show_description: block.settings.product_card_show_description,
                      show_quick_add: block.settings.product_card_show_quick_add,
                      show_quick_view: block.settings.product_card_show_quick_view,
                      show_price: block.settings.product_card_show_price,
                      show_badge: block.settings.product_card_show_badge,
                      media_aspect_ratio: block.settings.product_card_aspect_ratio,
                      color_scheme: block.settings.card_color_scheme,
                      lazyload: false,
                      placeholder_image: placeholder_image,
                      price_type: 'all'
                    -%}
                  </div>
                {% endfor %}
              {% else %}
                {% for i in (1..4) %}
                  <div class='sale-countdown__product' style='--xs: 12;--lg: 3;'>
                    {% render 'product-card',
                      product: false,
                      show_image: block.settings.product_card_show_image,
                      show_secondary_image: block.settings.product_card_show_secondary_image,
                      show_vendor: block.settings.product_card_show_vendor,
                      show_description: block.settings.product_card_show_description,
                      show_quick_add: block.settings.product_card_show_quick_add,
                      show_quick_view: block.settings.product_card_show_quick_view,
                      show_price: block.settings.product_card_show_price,
                      show_badge: block.settings.product_card_show_badge,
                      media_aspect_ratio: block.settings.product_card_aspect_ratio,
                      color_scheme: block.settings.card_color_scheme,
                      placeholder_image: placeholder_image,
                      price_type: 'all'
                    -%}
                  </div>
                {% endfor %}
              {% endif %}
          {% endcase %}
        {% endfor %}
      </xo-grid>
    </xo-container>
  </div>
</section>

