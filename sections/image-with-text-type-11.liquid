{{ 'section-image-with-text-type-11.css' | asset_url | stylesheet_tag }}

<div {% render 'section-attr' %}>
  <xo-container class='image-with-text-type-11'>
    <div class='image-with-text-type-11__content'>
      <div class='image-with-text-type-11__heading'>
        {% render 'text',
          text: section.settings.text_heading,
          tag_name: section.settings.text_tag_name,
          duration: section.settings.text_duration,
          effect: section.settings.text_effect
        %}
      </div>
      <xo-animate xo-cascade class='image-with-text-type-11__button'>
        {% render 'button',
          text: section.settings.button_text,
          link: section.settings.button_link,
          size: section.settings.button_size,
          style: section.settings.button_style,
          class: 'xo-btn--outline',
          icon: 'arrow-testimonial-right',
          icon_position: 'right',
          icon_size: '24'
        %}
      </xo-animate>
      <xo-animate xo-cascade xo-type='zoom-in' class='image-with-text-type-11__image'>
        {% render 'animate-image', image: section.settings.image, border_radius: 70, max_width: 1165, aspect_ratio: section.settings.aspect_ratio %}
      </xo-animate>
      <div class='image-with-text-type-11__wrapper'>
        <xo-animate xo-cascade class='image-with-text-type-11__description'>{{ section.settings.description }}</xo-animate>
      </div>
    </div>
  </xo-container>
</div>

{% schema %}
{
