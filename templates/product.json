      "blocks": {
        "collapse_item_6QMPEa": {
          "type": "collapse-item",
          "settings": {
            "collapse_trigger": "Quality ingredients",
            "collapse_content": "<p>National raw ham, a rich filling, fresh eggs from free-range hens and a thin pastry for a fresh, quality product without the addition of preservatives.</p>"
          }
        },
        "collapse_item_HNphea": {
          "type": "collapse-item",
          "settings": {
            "collapse_trigger": "Soft and tasty filling",
            "collapse_content": "<p>Each bite is a perfect balance of delicate pasta and a savory filling. Made with premium cheeses, herbs, and fresh ingredients, our pasta melts in your mouth for a truly indulgent experience.</p>"
          }
        },
        "collapse_item_eiyXwe": {
          "type": "collapse-item",
          "settings": {
            "collapse_trigger": "Easier to cook completely",
            "collapse_content": "<p>No more worrying about uneven cooking—our pasta is expertly crafted to cook thoroughly and evenly every time. Whether you’re a home chef or just starting out, perfect pasta is effortless.</p>"
          }
        },
        "collapse_item_WjdHtL": {
          "type": "collapse-item",
          "settings": {
            "collapse_trigger": "Good to taste in 4 minutes",
            "collapse_content": "<p>Short on time? No problem. Our pasta cooks to perfection in just <strong>4 minutes</strong>, delivering restaurant-quality taste in record time. Fast, flavorful, and always satisfying.</p>"
          }
        }
      },
