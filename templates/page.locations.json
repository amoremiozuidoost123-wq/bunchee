    "faq_QHcjQc": {
      "type": "faq",
      "blocks": {
        "accordion_item_4FwCQX": {
          "type": "accordion-item",
          "settings": {
            "accordion_trigger": "Are there any vegetarian or vegan options?",
            "accordion_content": "<p>We sure do have some satisfying veggie & vegan spaghetti bowls to serve you! Discover all options on our menu.</p>"
          }
        },
        "accordion_item_AMrWQY": {
          "type": "accordion-item",
          "settings": {
            "accordion_trigger": "Where can I buy gift vouchers?",
            "accordion_content": "<p>You can purchase our gift vouchers directly at any Pastarina restaurant or conveniently online through our website. </p>"
          }
        },
        "accordion_item_3AV7jC": {
          "type": "accordion-item",
          "settings": {
            "accordion_trigger": "What payment methods are accepted?",
            "accordion_content": "<p>We accept all major credit and debit cards, as well as mobile payments like Apple Pay and Google Pay. Cash is, of course, also welcome.</p>"
          }
        },
        "accordion_item_3RFCaU": {
          "type": "accordion-item",
          "settings": {
            "accordion_trigger": "Are dogs (or other animals) allowed in the restaurants?",
            "accordion_content": "<p>Well-behaved dogs are welcome in our outdoor seating areas. Please check with your local Pastarina for specific pet-friendly arrangements.</p>"
          }
        },
        "accordion_item_gWrCnF": {
          "type": "accordion-item",
          "settings": {
            "accordion_trigger": "Is your restaurant accessible for people in a wheelchair?",
            "accordion_content": "<p>Yes, all Pastarina locations are designed to be accessible. We have step-free entrances and accessible restrooms to ensure everyone feels at home.</p>"
          }
        },
        "accordion_item_hFaHP7": {
          "type": "accordion-item",
          "settings": {
            "accordion_trigger": "Is Pastarina child friendly?",
            "accordion_content": "<p>Absolutely! We welcome families and have high chairs, children’s menu options, and friendly staff ready to make dining with little ones easy and enjoyable.</p>"
          }
        }
      },
